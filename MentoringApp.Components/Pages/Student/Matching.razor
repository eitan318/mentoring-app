@page "/student/matching"
@inject IAuthService Auth
@inject PairApiClient PairApi
@inject MatchingApiClient MatchingApi
@inject NavigationManager Nav

<h2>Matching</h2>

@if (_loading)
{
    <p>Loading...</p>
}
else if (_pair is not null)
{
    <div class="card pair-card">
        <h4>You are paired</h4>
        <p>Mentor ID: @_pair.MentorId</p>
        <p>Mentee ID: @_pair.MenteeId</p>
        <p>Supervisor ID: @_pair.SupervisorId</p>
        <p>Tier: @_pair.MatchTier</p>
        <p>Since: @_pair.CreatedAt</p>
    </div>
}
else
{
    @if (!string.IsNullOrEmpty(_error)) { <div class="alert alert-error">@_error</div> }

    <!-- Tier 3: Gallery Recommendations -->
    @if (_recommendations.Any())
    {
        <section>
            <h3>Recommended Mentors</h3>
            <div class="mentor-gallery">
                @foreach (var rec in _recommendations.Take(3))
                {
                    <div class="mentor-card">
                        <h5>@rec.MentorName</h5>
                        <p>Subject: @rec.MentorSubjectName</p>
                        <div class="score-bar">
                            <div class="score-fill" style="width: @rec.ScorePercent%"></div>
                        </div>
                        <span>@rec.ScorePercent.ToString("F0")% match</span>
                        <button class="btn btn-primary" @onclick="() => GalleryPickAsync(rec.MentorId)">Choose</button>
                    </div>
                }
            </div>
        </section>
    }

    <!-- Tier 1: Direct Requests -->
    <section>
        <h3>Send a Request</h3>
        <div class="form-row">
            <input type="number" @bind="_requestMentorId" placeholder="Mentor ID" />
            <button class="btn btn-primary" @onclick="SendRequestAsync">Send Request</button>
        </div>
        @if (!string.IsNullOrEmpty(_requestMsg)) { <p class="msg">@_requestMsg</p> }
    </section>

    @if (_outgoingRequests.Any())
    {
        <section>
            <h4>My Outgoing Requests</h4>
            <table class="data-table">
                <thead><tr><th>Mentor ID</th><th>Status</th><th></th></tr></thead>
                <tbody>
                    @foreach (var r in _outgoingRequests)
                    {
                        <tr>
                            <td>@r.MentorId</td>
                            <td>@r.Status</td>
                            <td>
                                @if (r.Status == "Pending")
                                {
                                    <button class="btn btn-sm" @onclick="() => CancelRequestAsync(r.Id)">Cancel</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    }

    <!-- Mentor Inbox (if this student is also a mentor) -->
    @if (_incomingRequests.Any())
    {
        <section>
            <h4>Incoming Mentee Requests</h4>
            <table class="data-table">
                <thead><tr><th>Mentee ID</th><th>Status</th><th>Actions</th></tr></thead>
                <tbody>
                    @foreach (var r in _incomingRequests.Where(r => r.Status == "Pending"))
                    {
                        <tr>
                            <td>@r.MenteeId</td>
                            <td>@r.Status</td>
                            <td>
                                <button class="btn btn-success btn-sm" @onclick="() => AcceptRequestAsync(r.Id)">Accept</button>
                                <button class="btn btn-danger btn-sm" @onclick="() => RejectRequestAsync(r.Id)">Reject</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    }
}

@code {
    private PairResponse? _pair;
    private IEnumerable<MatchRecommendationResponse> _recommendations = [];
    private IEnumerable<PairRequestResponse> _outgoingRequests = [];
    private IEnumerable<PairRequestResponse> _incomingRequests = [];
    private int _requestMentorId;
    private bool _loading = true;
    private string _error = string.Empty;
    private string _requestMsg = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (Auth.UserId is null) { Nav.NavigateTo("/login"); return; }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = string.Empty;
        try
        {
            var userId = Auth.UserId!.Value;
            var pairTask = PairApi.GetByMenteeAsync(userId);
            var recsTask = MatchingApi.GetRecommendationsAsync(userId);
            var outTask = MatchingApi.GetRequestsForMenteeAsync(userId);
            var inTask = MatchingApi.GetRequestsForMentorAsync(userId);

            await Task.WhenAll(
                WrapNullable(pairTask, r => _pair = r),
                WrapList(recsTask, r => _recommendations = r),
                WrapList(outTask, r => _outgoingRequests = r),
                WrapList(inTask, r => _incomingRequests = r));
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private static async Task WrapNullable<T>(Task<T> task, Action<T?> setter) where T : class
    {
        try { setter(await task); }
        catch { setter(null); }
    }

    private static async Task WrapList<T>(Task<IEnumerable<T>> task, Action<IEnumerable<T>> setter)
    {
        try { setter(await task); }
        catch { setter([]); }
    }

    private async Task SendRequestAsync()
    {
        _requestMsg = string.Empty;
        if (_requestMentorId <= 0) { _requestMsg = "Enter a valid Mentor ID."; return; }
        try
        {
            await MatchingApi.SendPairRequestAsync(new SendPairRequestBody(Auth.UserId!.Value, _requestMentorId));
            _requestMsg = "Request sent.";
            _outgoingRequests = await MatchingApi.GetRequestsForMenteeAsync(Auth.UserId!.Value);
        }
        catch (Exception ex) { _requestMsg = ex.Message; }
    }

    private async Task CancelRequestAsync(int requestId)
    {
        try
        {
            await MatchingApi.CancelRequestAsync(requestId);
            _outgoingRequests = await MatchingApi.GetRequestsForMenteeAsync(Auth.UserId!.Value);
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task GalleryPickAsync(int mentorId)
    {
        try
        {
            await MatchingApi.GalleryPickAsync(new GalleryPickRequest(Auth.UserId!.Value, mentorId, 0));
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task AcceptRequestAsync(int requestId)
    {
        try
        {
            await MatchingApi.AcceptRequestAsync(requestId, new AcceptRequestBody(0));
            _incomingRequests = await MatchingApi.GetRequestsForMentorAsync(Auth.UserId!.Value);
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task RejectRequestAsync(int requestId)
    {
        try
        {
            await MatchingApi.RejectRequestAsync(requestId);
            _incomingRequests = await MatchingApi.GetRequestsForMentorAsync(Auth.UserId!.Value);
        }
        catch (Exception ex) { _error = ex.Message; }
    }
}
