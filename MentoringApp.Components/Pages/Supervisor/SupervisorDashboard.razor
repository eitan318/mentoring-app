@page "/supervisor"
@inject IAuthService Auth
@inject PairApiClient PairApi
@inject IssueApiClient IssueApi
@inject NavigationManager Nav

<h2>Supervisor Dashboard</h2>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-error">@_error</div>
}

<h3>My Pairs</h3>
@if (_loadingPairs)
{
    <p>Loading pairs...</p>
}
else if (!_pairs.Any())
{
    <p>No pairs assigned to you.</p>
}
else
{
    <table class="data-table">
        <thead>
            <tr><th>Pair ID</th><th>Mentor ID</th><th>Mentee ID</th><th>Tier</th><th>Status</th></tr>
        </thead>
        <tbody>
            @foreach (var p in _pairs)
            {
                <tr class="@(p.IsProfileIncomplete ? "row-warning" : "")">
                    <td>@p.Id</td>
                    <td>@p.MentorId</td>
                    <td>@p.MenteeId</td>
                    <td>@p.MatchTier</td>
                    <td>@(p.IsProfileIncomplete ? "⚠ Incomplete" : "Active")</td>
                </tr>
            }
        </tbody>
    </table>
}

<h3>Issues Queue</h3>
@if (_loadingIssues)
{
    <p>Loading issues...</p>
}
else if (!_issues.Any())
{
    <p>No issues assigned to you.</p>
}
else
{
    <table class="data-table">
        <thead>
            <tr><th>ID</th><th>Description</th><th>Category</th><th>Created</th><th>Status</th><th>Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var issue in _issues)
            {
                <tr>
                    <td>@issue.Id</td>
                    <td>@issue.Description</td>
                    <td>@issue.CategoryId</td>
                    <td>@issue.CreationDate</td>
                    <td>@(issue.IsResolved == 1 ? "Resolved" : "Open")</td>
                    <td>
                        @if (issue.IsResolved == 0)
                        {
                            <button class="btn btn-sm btn-success" @onclick="() => ResolveAsync(issue.Id)">
                                Resolve
                            </button>
                            <button class="btn btn-sm btn-warning" @onclick="() => ForwardAsync(issue.Id)">
                                Forward to Admin
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private IEnumerable<PairResponse> _pairs = [];
    private IEnumerable<IssueResponse> _issues = [];
    private bool _loadingPairs = true;
    private bool _loadingIssues = true;
    private string _error = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (Auth.Role != "Supervisor" || Auth.UserId is null)
        {
            Nav.NavigateTo("/login");
            return;
        }

        await Task.WhenAll(LoadPairsAsync(), LoadIssuesAsync());
    }

    private async Task LoadPairsAsync()
    {
        _loadingPairs = true;
        try { _pairs = await PairApi.GetBySupervisorAsync(Auth.UserId!.Value); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loadingPairs = false; }
    }

    private async Task LoadIssuesAsync()
    {
        _loadingIssues = true;
        try { _issues = await IssueApi.GetBySupervisorAsync(Auth.UserId!.Value); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loadingIssues = false; }
    }

    private async Task ResolveAsync(int id)
    {
        try
        {
            await IssueApi.ResolveAsync(id);
            await LoadIssuesAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task ForwardAsync(int id)
    {
        try
        {
            await IssueApi.ForwardAsync(id, new ForwardIssueRequest(Auth.UserId!.Value));
            await LoadIssuesAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
    }
}
