@page "/admin/create-pair"
@inject IAuthService Auth
@inject PairApiClient PairApi
@inject UserApiClient UserApi
@inject MatchingApiClient MatchingApi
@inject NavigationManager Nav

<h2>Create Pair</h2>
<a href="/admin/pairs" class="btn btn-link ps-0 mb-3">&larr; Back to Pairs</a>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}

@if (!string.IsNullOrEmpty(_successMsg))
{
    <div class="alert alert-success">@_successMsg</div>
}

@if (_loading)
{
    <p>Loading users...</p>
}
else
{
    <div class="row g-3" style="max-width:900px">

        @* Supervisor *@
        <div class="col-md-4">
            <label class="form-label fw-bold">Supervisor</label>
            <input class="form-control mb-1" placeholder="Search supervisor..." @bind="_supervisorSearch" @bind:event="oninput" />
            <select class="form-select" size="8" @onchange="OnSupervisorSelected">
                <option value="">— none —</option>
                @foreach (var u in FilteredSupervisors)
                {
                    <option value="@u.Id" selected="@(_selectedSupervisorId == u.Id)">@u.UserName</option>
                }
            </select>
            @if (_selectedSupervisorId.HasValue)
            {
                <p class="text-muted mt-1">Selected: <strong>@NameOf(_selectedSupervisorId.Value)</strong></p>
            }
        </div>

        @* Mentor *@
        <div class="col-md-4">
            <label class="form-label fw-bold">Mentor (available)</label>
            <input class="form-control mb-1" placeholder="Search mentor..." @bind="_mentorSearch" @bind:event="oninput" />
            <select class="form-select" size="8" @onchange="OnMentorSelected">
                <option value="">— none —</option>
                @foreach (var m in FilteredMentors)
                {
                    <option value="@m.Id" selected="@(_selectedMentorId == m.Id)">@m.UserName</option>
                }
            </select>
            @if (_selectedMentorId.HasValue)
            {
                <p class="text-muted mt-1">Selected: <strong>@NameOf(_selectedMentorId.Value)</strong></p>
            }
        </div>

        @* Mentee *@
        <div class="col-md-4">
            <label class="form-label fw-bold">Mentee (available)</label>
            <input class="form-control mb-1" placeholder="Search mentee..." @bind="_menteeSearch" @bind:event="oninput" />
            <select class="form-select" size="8" @onchange="OnMenteeSelected">
                <option value="">— none —</option>
                @foreach (var m in FilteredMentees)
                {
                    <option value="@m.Id" selected="@(_selectedMenteeId == m.Id)">@m.UserName</option>
                }
            </select>
            @if (_selectedMenteeId.HasValue)
            {
                <p class="text-muted mt-1">Selected: <strong>@NameOf(_selectedMenteeId.Value)</strong></p>
            }
        </div>
    </div>

    <div class="mt-3">
        <button class="btn btn-primary"
                disabled="@(!CanCreate)"
                @onclick="CreateAsync">
            Create Pair
        </button>
    </div>
}

@code {
    private IEnumerable<UserResponse> _supervisors = [];
    private IEnumerable<AvailableMentorResponse> _mentors = [];
    private IEnumerable<AvailableMenteeResponse> _mentees = [];
    private Dictionary<int, string> _nameCache = new();

    private string _supervisorSearch = string.Empty;
    private string _mentorSearch = string.Empty;
    private string _menteeSearch = string.Empty;

    private int? _selectedSupervisorId;
    private int? _selectedMentorId;
    private int? _selectedMenteeId;

    private bool _loading = true;
    private bool _creating;
    private string _error = string.Empty;
    private string _successMsg = string.Empty;

    private bool CanCreate => _selectedSupervisorId.HasValue && _selectedMentorId.HasValue && _selectedMenteeId.HasValue && !_creating;

    private IEnumerable<UserResponse> FilteredSupervisors =>
        string.IsNullOrWhiteSpace(_supervisorSearch)
            ? _supervisors
            : _supervisors.Where(s => s.UserName.Contains(_supervisorSearch, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<AvailableMentorResponse> FilteredMentors =>
        string.IsNullOrWhiteSpace(_mentorSearch)
            ? _mentors
            : _mentors.Where(m => m.UserName.Contains(_mentorSearch, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<AvailableMenteeResponse> FilteredMentees =>
        string.IsNullOrWhiteSpace(_menteeSearch)
            ? _mentees
            : _mentees.Where(m => m.UserName.Contains(_menteeSearch, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        if (Auth.Role != "Admin") { Nav.NavigateTo("/login"); return; }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = string.Empty;
        try
        {
            var usersTask = UserApi.GetAllAsync();
            var mentorsTask = MatchingApi.GetAvailableMentorsAsync();
            var menteesTask = MatchingApi.GetAvailableMenteesAsync();
            await Task.WhenAll(usersTask, mentorsTask, menteesTask);

            var allUsers = usersTask.Result;
            _supervisors = allUsers.Where(u => u.Role == "Supervisor").ToList();
            _mentors = mentorsTask.Result;
            _mentees = menteesTask.Result;

            // Build name lookup for selected-item display
            _nameCache = allUsers.ToDictionary(u => u.Id, u => u.UserName);
            foreach (var m in _mentors) _nameCache.TryAdd(m.Id, m.UserName);
            foreach (var m in _mentees) _nameCache.TryAdd(m.Id, m.UserName);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private void OnSupervisorSelected(ChangeEventArgs e) =>
        _selectedSupervisorId = int.TryParse(e.Value?.ToString(), out var v) ? v : null;

    private void OnMentorSelected(ChangeEventArgs e) =>
        _selectedMentorId = int.TryParse(e.Value?.ToString(), out var v) ? v : null;

    private void OnMenteeSelected(ChangeEventArgs e) =>
        _selectedMenteeId = int.TryParse(e.Value?.ToString(), out var v) ? v : null;

    private string NameOf(int id) => _nameCache.GetValueOrDefault(id, $"#{id}");

    private async Task CreateAsync()
    {
        if (!CanCreate) return;
        _creating = true;
        _error = string.Empty;
        _successMsg = string.Empty;
        try
        {
            await PairApi.CreateAsync(new CreatePairRequest(
                _selectedSupervisorId!.Value,
                _selectedMentorId!.Value,
                _selectedMenteeId!.Value));

            _successMsg = "Pair created successfully.";
            _selectedSupervisorId = null;
            _selectedMentorId = null;
            _selectedMenteeId = null;
            await LoadAsync(); // refresh available lists
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _creating = false; }
    }
}
