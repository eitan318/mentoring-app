@page "/admin/pairs"
@inject IAuthService Auth
@inject PairApiClient PairApi
@inject UserApiClient UserApi
@inject NavigationManager Nav

<h2>Manage Pairs</h2>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}

<div class="d-flex gap-2 align-items-center mb-3">
    <input class="form-control w-auto" type="text" placeholder="Search by mentor or mentee name..."
           @bind="_search" @bind:event="oninput" />
    <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/admin/create-pair")'>+ Create Pair</button>
</div>

@if (_loading)
{
    <p>Loading pairs...</p>
}
else if (!_pairs.Any())
{
    <p class="text-muted">No pairs found.</p>
}
else
{
    <p class="text-muted">@FilteredRows.Count() of @_pairs.Count() pair(s)</p>
    <table class="table table-sm table-bordered table-hover">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Mentor</th>
                <th>Mentee</th>
                <th>Supervisor</th>
                <th>Tier</th>
                <th>Created</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in FilteredRows)
            {
                <tr class="@(row.Pair.IsProfileIncomplete ? "table-warning" : "")">
                    <td>@row.Pair.Id</td>
                    <td>@row.MentorName</td>
                    <td>@row.MenteeName</td>
                    <td>@row.SupervisorName</td>
                    <td>@row.Pair.MatchTier</td>
                    <td>@row.Pair.CreatedAt</td>
                    <td>
                        @if (row.Pair.IsProfileIncomplete)
                        {
                            <span class="badge bg-warning text-dark">Incomplete Profile</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Active</span>
                        }
                    </td>
                    <td>
                        @if (_confirmDeleteId == row.Pair.Id)
                        {
                            <span>Sure? </span>
                            <button class="btn btn-danger btn-sm" @onclick="() => ConfirmDeleteAsync(row.Pair.Id)">Yes</button>
                            <button class="btn btn-secondary btn-sm" @onclick="() => _confirmDeleteId = null">No</button>
                        }
                        else
                        {
                            <button class="btn btn-danger btn-sm" @onclick="() => _confirmDeleteId = row.Pair.Id">Separate</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private record PairRow(PairResponse Pair, string MentorName, string MenteeName, string SupervisorName);

    private IEnumerable<PairResponse> _pairs = [];
    private Dictionary<int, string> _userNames = new();
    private bool _loading = true;
    private string _error = string.Empty;
    private string _search = string.Empty;
    private int? _confirmDeleteId;

    private IEnumerable<PairRow> _rows = [];

    private IEnumerable<PairRow> FilteredRows =>
        string.IsNullOrWhiteSpace(_search)
            ? _rows
            : _rows.Where(r =>
                r.MentorName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                r.MenteeName.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        if (Auth.Role != "Admin") { Nav.NavigateTo("/login"); return; }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = string.Empty;
        try
        {
            var pairsTask = PairApi.GetAllAsync();
            var usersTask = UserApi.GetAllAsync();
            await Task.WhenAll(pairsTask, usersTask);
            _pairs = pairsTask.Result;
            _userNames = usersTask.Result.ToDictionary(u => u.Id, u => u.UserName);
            _rows = _pairs.Select(p => new PairRow(
                p,
                _userNames.GetValueOrDefault(p.MentorId, $"#{p.MentorId}"),
                _userNames.GetValueOrDefault(p.MenteeId, $"#{p.MenteeId}"),
                _userNames.GetValueOrDefault(p.SupervisorId, $"#{p.SupervisorId}")
            )).ToList();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task ConfirmDeleteAsync(int id)
    {
        _confirmDeleteId = null;
        try
        {
            await PairApi.DeleteAsync(id);
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
    }
}
