@page "/admin/matching"
@inject IAuthService Auth
@inject MatchingApiClient MatchingApi
@inject PairApiClient PairApi
@inject NavigationManager Nav

<h2>Matching Pipeline</h2>

<div class="pipeline-cards">
    <div class="card">
        <h4>Generate Scores</h4>
        <p>Compute compatibility scores for all unmatched students.</p>
        <button class="btn btn-primary" @onclick="GenerateScoresAsync" disabled="@_generatingScores">
            @(_generatingScores ? "Running..." : "Generate Scores")
        </button>
        @if (!string.IsNullOrEmpty(_scoresMsg)) { <p class="msg">@_scoresMsg</p> }
    </div>

    <div class="card">
        <h4>Auto-Match</h4>
        <p>Automatically create pairs from the top score matches.</p>
        <button class="btn btn-primary" @onclick="AutoMatchAsync" disabled="@_autoMatching">
            @(_autoMatching ? "Running..." : "Auto-Match")
        </button>
        @if (!string.IsNullOrEmpty(_autoMatchMsg)) { <p class="msg">@_autoMatchMsg</p> }
    </div>

    <div class="card">
        <h4>Fallback Match</h4>
        <p>Assign remaining unmatched students via fallback rules.</p>
        <button class="btn btn-warning" @onclick="FallbackMatchAsync" disabled="@_fallbackMatching">
            @(_fallbackMatching ? "Running..." : "Fallback Match")
        </button>
        @if (!string.IsNullOrEmpty(_fallbackMsg)) { <p class="msg">@_fallbackMsg</p> }
    </div>
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-error">@_error</div>
}

<h3>All Pairs</h3>
@if (_loadingPairs)
{
    <p>Loading pairs...</p>
}
else
{
    <table class="data-table">
        <thead>
            <tr>
                <th>ID</th><th>Mentor ID</th><th>Mentee ID</th><th>Supervisor ID</th><th>Tier</th><th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in _pairs)
            {
                <tr class="@(p.IsProfileIncomplete ? "row-warning" : "")">
                    <td>@p.Id</td>
                    <td>@p.MentorId</td>
                    <td>@p.MenteeId</td>
                    <td>@p.SupervisorId</td>
                    <td>@p.MatchTier</td>
                    <td>@(p.IsProfileIncomplete ? "⚠ Incomplete Profile" : "OK")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private IEnumerable<PairResponse> _pairs = [];
    private bool _loadingPairs = true;
    private bool _generatingScores;
    private bool _autoMatching;
    private bool _fallbackMatching;
    private string _error = string.Empty;
    private string _scoresMsg = string.Empty;
    private string _autoMatchMsg = string.Empty;
    private string _fallbackMsg = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (Auth.Role != "Admin") { Nav.NavigateTo("/login"); return; }
        await LoadPairsAsync();
    }

    private async Task LoadPairsAsync()
    {
        _loadingPairs = true;
        try { _pairs = await PairApi.GetAllAsync(); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loadingPairs = false; }
    }

    private async Task GenerateScoresAsync()
    {
        _generatingScores = true; _scoresMsg = string.Empty;
        try { await MatchingApi.GenerateScoresAsync(); _scoresMsg = "Scores generated successfully."; }
        catch (Exception ex) { _scoresMsg = $"Error: {ex.Message}"; }
        finally { _generatingScores = false; }
    }

    private async Task AutoMatchAsync()
    {
        _autoMatching = true; _autoMatchMsg = string.Empty;
        try
        {
            var r = await MatchingApi.RunAutoMatchAsync();
            _autoMatchMsg = $"Created {r.PairsCreated} pair(s).";
            await LoadPairsAsync();
        }
        catch (Exception ex) { _autoMatchMsg = $"Error: {ex.Message}"; }
        finally { _autoMatching = false; }
    }

    private async Task FallbackMatchAsync()
    {
        _fallbackMatching = true; _fallbackMsg = string.Empty;
        try
        {
            var r = await MatchingApi.RunFallbackMatchAsync();
            _fallbackMsg = $"Created {r.PairsCreated} pair(s).";
            await LoadPairsAsync();
        }
        catch (Exception ex) { _fallbackMsg = $"Error: {ex.Message}"; }
        finally { _fallbackMatching = false; }
    }
}
