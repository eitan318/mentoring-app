@page "/admin"
@inject IAuthService Auth
@inject UserApiClient UserApi
@inject IssueApiClient IssueApi
@inject NavigationManager Nav

<h2>Admin Dashboard</h2>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}

@* ── Quick-action cards ── *@
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100 shadow-sm card-action" @onclick='() => Nav.NavigateTo("/admin/users")' style="cursor:pointer">
            <div class="card-body text-center">
                <div class="fs-2 mb-2">👥</div>
                <h5 class="card-title">Manage Users</h5>
                <p class="card-text text-muted small">Add, view and delete user accounts</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm card-action" @onclick='() => Nav.NavigateTo("/admin/pairs")' style="cursor:pointer">
            <div class="card-body text-center">
                <div class="fs-2 mb-2">🔗</div>
                <h5 class="card-title">Manage Pairs</h5>
                <p class="card-text text-muted small">View, create and separate mentor–mentee pairs</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm card-action" @onclick='() => Nav.NavigateTo("/admin/settings")' style="cursor:pointer">
            <div class="card-body text-center">
                <div class="fs-2 mb-2">⚙️</div>
                <h5 class="card-title">System Settings</h5>
                <p class="card-text text-muted small">Grades, classes and system configuration</p>
            </div>
        </div>
    </div>
</div>

@* ── Supervisor Overview ── *@
<div class="mb-4">
    <h4>Supervisor Overview</h4>
    @if (_loadingStats)
    {
        <p>Loading supervisor stats...</p>
    }
    else if (!_supervisorStats.Any())
    {
        <p class="text-muted">No supervisors found.</p>
    }
    else
    {
        <table class="table table-sm table-bordered table-hover">
            <thead class="table-light">
                <tr>
                    <th>ID</th><th>Name</th><th>Pairs</th><th>Pending Issues</th><th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in _supervisorStats)
                {
                    <tr>
                        <td>@s.Id</td>
                        <td>@s.UserName</td>
                        <td>@s.PairsCount</td>
                        <td>
                            @if (s.PendingIssuesCount > 0)
                            {
                                <span class="badge bg-warning text-dark">@s.PendingIssuesCount</span>
                            }
                            else
                            {
                                <span class="text-muted">0</span>
                            }
                        </td>
                        <td>
                            <button class="btn btn-outline-primary btn-sm"
                                    @onclick="() => Nav.NavigateTo($\"/admin/supervisor/{s.Id}\")">
                                Inspect
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@* ── Forwarded Issues ── *@
<div class="mb-4">
    <h4>Forwarded Issues</h4>
    @if (_loadingForwarded)
    {
        <p>Loading forwarded issues...</p>
    }
    else if (!_forwardedIssues.Any())
    {
        <p class="text-muted">No forwarded issues.</p>
    }
    else
    {
        <table class="table table-sm table-bordered">
            <thead class="table-light">
                <tr>
                    <th>ID</th><th>Description</th><th>Category</th><th>Reported By</th><th>Date</th><th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var issue in _forwardedIssues)
                {
                    <tr>
                        <td>@issue.Id</td>
                        <td>@issue.Description</td>
                        <td>@issue.CategoryId</td>
                        <td>@issue.ReportedByUserId</td>
                        <td>@issue.CreationDate</td>
                        <td>
                            @if (issue.IsResolved == 0)
                            {
                                <button class="btn btn-success btn-sm" @onclick="() => ResolveIssueAsync(issue.Id)">
                                    Resolve
                                </button>
                            }
                            else
                            {
                                <span class="badge bg-success">Resolved</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private IEnumerable<SupervisorStatsResponse> _supervisorStats = [];
    private IEnumerable<IssueResponse> _forwardedIssues = [];

    private bool _loadingStats = true;
    private bool _loadingForwarded = true;
    private string _error = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (Auth.Role != "Admin") { Nav.NavigateTo("/login"); return; }
        await Task.WhenAll(LoadSupervisorStatsAsync(), LoadForwardedIssuesAsync());
    }

    private async Task LoadSupervisorStatsAsync()
    {
        _loadingStats = true;
        try { _supervisorStats = await UserApi.GetSupervisorStatsAsync(); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loadingStats = false; }
    }

    private async Task LoadForwardedIssuesAsync()
    {
        _loadingForwarded = true;
        try { _forwardedIssues = await IssueApi.GetForwardedAsync(); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loadingForwarded = false; }
    }

    private async Task ResolveIssueAsync(int id)
    {
        try
        {
            await IssueApi.ResolveAsync(id);
            await LoadForwardedIssuesAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
    }
}
