<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:views="clr-namespace:MentoringApp.View"
                    xmlns:vm="clr-namespace:MentoringApp.ViewModel.ViewModelPage;assembly=MentoringApp.ViewModel">

    <DataTemplate DataType="{x:Type vm:LoginViewModel}">
        <views:LoginView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:AdminDashboardViewModel}">
        <views:AdminDashboardView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:SupervisorDashboardViewModel}">
        <views:SupervisorDashboardView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:StudentHomeViewModel}">
        <views:StudentHomeView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:RegistrationViewModel}">
        <views:RegistrationView/>
    </DataTemplate>

</ResourceDictionary>