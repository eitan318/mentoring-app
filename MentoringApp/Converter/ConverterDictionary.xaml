<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:MentoringApp.Converter"
    xmlns:loc="clr-namespace:MentoringApp.Localization">
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
    <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
    <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
    <conv:StringToImageSourceConverter x:Key="StringToImage" />
    <loc:DbTranslationConverter x:Key="DbTranslation" />
    <conv:LocalizedClassCountConverter x:Key="LocalizedClassCount" />
</ResourceDictionary>