<UserControl
    x:Class="MentoringApp.View.Supervisor.SupervisorDashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600" d:DesignWidth="800" mc:Ignorable="d">

    <UserControl.Resources>
        <CollectionViewSource x:Key="PendingFilter" 
                      Source="{Binding AllIssues}" 
                      Filter="FilterPending" />

        <CollectionViewSource x:Key="ResolvedFilter" 
                      Source="{Binding AllIssues}" 
                      Filter="FilterResolved" />

        <DataTemplate x:Key="IssueItemTemplate">
            <StackPanel Margin="5">
                <TextBlock x:Name="Desc" Text="{Binding Description}" FontSize="14" FontWeight="Medium" TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Opacity="0.7">
                    <TextBlock Text="{Binding Category.Name}" FontStyle="Italic" Margin="0,0,10,0"/>
                    <TextBlock x:Name="Stat" Text="Pending" FontSize="10" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CreationDate, StringFormat='{} | Created: {0:d}'}" FontSize="10" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsResolved}" Value="True">
                    <Setter TargetName="Desc" Property="TextDecorations" Value="Strikethrough" />
                    <Setter TargetName="Desc" Property="Foreground" Value="Gray" />
                    <Setter TargetName="Stat" Property="Text" Value="Resolved" />
                    <Setter TargetName="Stat" Property="Foreground" Value="DarkGreen" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,15">
            <TextBlock FontSize="28" FontWeight="Bold" Text="{Binding SelectedSupervisor.UserName}" />
            <TextBlock Text="{Binding PairsSupervised.Count, StringFormat='Total Pairs Supervised: {0}'}" FontWeight="Medium" />
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="2">
            <DockPanel Margin="0,0,5,0">
                <TextBlock DockPanel.Dock="Top" Text="Pending Issues" FontWeight="Bold" Foreground="DarkRed" Margin="0,0,0,5"/>
                <ListView ItemsSource="{Binding Source={StaticResource PendingFilter}}" 
                          ItemTemplate="{StaticResource IssueItemTemplate}"
                          SelectedItem="{Binding SelectedIssue}">
                    <ListView.InputBindings>
                        <MouseBinding Gesture="LeftClick" Command="{Binding SelectIssueCommand}" CommandParameter="{Binding SelectedIssue}" />
                    </ListView.InputBindings>
                </ListView>
            </DockPanel>

            <DockPanel Margin="5,0,0,0">
                <TextBlock DockPanel.Dock="Top" Text="Resolved Issues" FontWeight="Bold" Foreground="DarkGreen" Margin="0,0,0,5"/>
                <ListView ItemsSource="{Binding Source={StaticResource ResolvedFilter}}" 
                          ItemTemplate="{StaticResource IssueItemTemplate}"
                          SelectedItem="{Binding SelectedIssue}">
                    <ListView.InputBindings>
                        <MouseBinding Gesture="LeftClick" Command="{Binding SelectIssueCommand}" CommandParameter="{Binding SelectedIssue}" />
                    </ListView.InputBindings>
                </ListView>
            </DockPanel>
        </UniformGrid>

        <TextBlock Grid.Row="2" Text="Managed Mentoring Pairs" FontSize="18" FontWeight="SemiBold" Margin="0,15,0,5" />

        <ListView Grid.Row="3" ItemsSource="{Binding PairsSupervised}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <DockPanel LastChildFill="True" Margin="5">
                        <Button DockPanel.Dock="Right" Content="Separate Pair" Padding="10,2"
                                Command="{Binding DataContext.SeparateCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                CommandParameter="{Binding}" />
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontWeight="Bold" Text="Mentor: " />
                            <TextBlock Text="{Binding Mentor.UserName}" Margin="0,0,15,0" />
                            <TextBlock FontWeight="Bold" Text="Mentee: " />
                            <TextBlock Text="{Binding Mentee.UserName}" />
                        </StackPanel>
                    </DockPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>