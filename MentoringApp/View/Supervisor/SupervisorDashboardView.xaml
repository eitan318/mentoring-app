<UserControl
    x:Class="MentoringApp.View.Supervisor.SupervisorDashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:components="clr-namespace:MentoringApp.View.Components"
    xmlns:loc="clr-namespace:MentoringApp.Localization"
    d:DesignHeight="600"
    d:DesignWidth="800"
    mc:Ignorable="d"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <DataTemplate x:Key="IssueItemTemplate">
            <StackPanel Margin="5">
                <TextBlock
                    x:Name="Desc"
                    FontSize="14"
                    FontWeight="Medium"
                    Text="{Binding Description}"
                    TextWrapping="Wrap" />
                <StackPanel Opacity="0.7" Orientation="Horizontal">
                    <TextBlock Margin="0,0,10,0" FontStyle="Italic">
                        <TextBlock.Text>
                            <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Category_">
                                <Binding Path="Category.Name" />
                                <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock
                        x:Name="Stat"
                        VerticalAlignment="Center"
                        FontSize="10"
                        Text="{Binding [Supervisor_IssuePending], Source={x:Static loc:TranslationSource.Instance}}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="10"
                        Text="{Binding CreationDate, StringFormat='{} | Created: {0:d}'}" />
                </StackPanel>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsResolved}" Value="True">
                    <Setter TargetName="Desc" Property="TextDecorations" Value="Strikethrough" />
                    <Setter TargetName="Desc" Property="Foreground" Value="Gray" />
                    <Setter TargetName="Stat" Property="Tag" Value="resolved" />
                    <Setter TargetName="Stat" Property="Foreground" Value="DarkGreen" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <Style x:Key="IssueListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />

            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnIssueItemClick" />

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E0E0E0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PairListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />

            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnPairItemClick" />

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E0E0E0" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,15">
            <TextBlock
                FontSize="28"
                FontWeight="Bold"
                Text="{Binding SelectedSupervisor.UserName}" />
            <TextBlock FontWeight="Medium">
                <TextBlock.Text>
                    <MultiBinding StringFormat="{}{1}{0}">
                        <Binding Path="PairsSupervised.Count"/>
                        <Binding Path="[Supervisor_TotalPairs_Label]" Source="{x:Static loc:TranslationSource.Instance}"/>
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="2">
            <DockPanel Margin="0,0,5,0">
                <TextBlock
                    Margin="0,0,0,5"
                    DockPanel.Dock="Top"
                    FontWeight="Bold"
                    Foreground="DarkRed"
                    Text="{Binding [Supervisor_PendingIssues_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                <ListView
                    ItemContainerStyle="{StaticResource IssueListViewItemStyle}"
                    ItemTemplate="{StaticResource IssueItemTemplate}"
                    ItemsSource="{Binding PendingIssues}" />
            </DockPanel>

            <DockPanel Margin="5,0,0,0">
                <TextBlock Margin="0,0,0,5" DockPanel.Dock="Top" FontWeight="Bold" Foreground="DarkGreen"
                           Text="{Binding [Supervisor_ResolvedIssues_Label], Source={x:Static loc:TranslationSource.Instance}}" />

                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock FontSize="14" Text="{Binding [Supervisor_TotalResolved_Label], Source={x:Static loc:TranslationSource.Instance}}" VerticalAlignment="Center"/>
                    <TextBlock FontSize="14" FontWeight="Bold" Text="{Binding ResolvedIssuesCount}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Button Command="{Binding ToggleResolvedIssuesCommand}" Padding="8,4" VerticalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="{Binding [Supervisor_ViewResolved_Button], Source={x:Static loc:TranslationSource.Instance}}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowResolvedIssues}" Value="True">
                                        <Setter Property="Content" Value="{Binding [Supervisor_HideResolved_Button], Source={x:Static loc:TranslationSource.Instance}}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <ListView ItemContainerStyle="{StaticResource IssueListViewItemStyle}"
                          ItemTemplate="{StaticResource IssueItemTemplate}"
                          ItemsSource="{Binding ResolvedIssues}"
                          Visibility="{Binding ShowResolvedIssues, Converter={StaticResource BoolToVis}}" />
            </DockPanel>
        </UniformGrid>

        <TextBlock
            Grid.Row="2"
            Margin="0,15,0,5"
            FontSize="18"
            FontWeight="SemiBold"
            Text="{Binding [Supervisor_ManagedPairs_Label], Source={x:Static loc:TranslationSource.Instance}}" />

        <ListView Grid.Row="3" ItemsSource="{Binding PairsSupervised}" ItemContainerStyle="{StaticResource PairListViewItemStyle}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <DockPanel Margin="5" LastChildFill="True">
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <!--  Mentor mini avatar  -->
                            <components:ProfilePictureControl Width="32" Height="32" Margin="0,0,6,0" VerticalAlignment="Center" ImagePath="{Binding Mentor.ProfilePicturePath}" />
                            <TextBlock FontWeight="Bold" Text="{Binding [Supervisor_MentorPrefix], Source={x:Static loc:TranslationSource.Instance}}" />
                            <TextBlock Margin="0,0,12,0" Text="{Binding Mentor.UserName}" />

                            <!--  Mentee mini avatar  -->
                            <components:ProfilePictureControl Width="32" Height="32" Margin="0,0,6,0" VerticalAlignment="Center" ImagePath="{Binding Mentee.ProfilePicturePath}" />
                            <TextBlock FontWeight="Bold" Text="{Binding [Supervisor_MenteePrefix], Source={x:Static loc:TranslationSource.Instance}}" />
                            <TextBlock Text="{Binding Mentee.UserName}" />
                        </StackPanel>
                    </DockPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>