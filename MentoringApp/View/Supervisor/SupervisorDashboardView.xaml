<UserControl
    x:Class="MentoringApp.View.Supervisor.SupervisorDashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:components="clr-namespace:MentoringApp.View.Components"
    xmlns:loc="clr-namespace:MentoringApp.Localization"
    d:DesignHeight="600"
    d:DesignWidth="800"
    mc:Ignorable="d"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <DataTemplate x:Key="IssueItemTemplate">
            <StackPanel Margin="5">
                <TextBlock
                    x:Name="Desc"
                    FontSize="14"
                    FontWeight="Medium"
                    Text="{Binding Description}"
                    TextWrapping="Wrap" />
                <StackPanel Opacity="0.7" Orientation="Horizontal">
                    <TextBlock Margin="0,0,10,0" FontStyle="Italic">
                        <TextBlock.Text>
                            <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Category_">
                                <Binding Path="Category.Name" />
                                <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock
                        x:Name="Stat"
                        VerticalAlignment="Center"
                        FontSize="10"
                        Text="{Binding [Supervisor_IssuePending], Source={x:Static loc:TranslationSource.Instance}}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="10"
                        Text="{Binding CreationDate, StringFormat='{} | Created: {0:d}'}" />
                </StackPanel>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsResolved}" Value="True">
                    <Setter TargetName="Desc" Property="TextDecorations" Value="Strikethrough" />
                    <Setter TargetName="Desc" Property="Foreground" Value="Gray" />
                    <Setter TargetName="Stat" Property="Tag" Value="resolved" />
                    <Setter TargetName="Stat" Property="Foreground" Value="DarkGreen" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <Style x:Key="IssueListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />

            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnIssueItemClick" />

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E0E0E0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PairListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />

            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnPairItemClick" />

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E0E0E0" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- ── MASTER PANE (LEFT) ── -->
        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="1.5*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Supervisor MetaData -->
            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <TextBlock FontSize="28" FontWeight="Bold" Text="{Binding SelectedSupervisor.UserName}" />
                <TextBlock FontWeight="Medium" Foreground="Gray">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{1} {0}">
                            <Binding Path="PairsSupervised.Count"/>
                            <Binding Path="[Supervisor_TotalPairs_Label]" Source="{x:Static loc:TranslationSource.Instance}"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>

            <!-- ── Matching Control Panel ── -->
            <Expander Grid.Row="1" Header="⚙ Matching Flow Controls" Margin="0,0,0,12"
                      BorderBrush="#E0E0E0" BorderThickness="1">
                <Border Background="#FAFAFA" Padding="12">
                    <StackPanel>
                        <!-- Current Phase label -->
                        <Border Background="#E3F2FD" CornerRadius="4" Padding="8,6" Margin="0,0,0,10">
                            <TextBlock FontWeight="SemiBold" Foreground="#1976D2" Text="{Binding MatchingStatusLabel}" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Operation result -->
                        <Border Visibility="{Binding HasMatchingResult, Converter={StaticResource BoolToVis}}"
                                Background="#E8F5E9" BorderBrush="#4CAF50" BorderThickness="1"
                                CornerRadius="4" Padding="8,6" Margin="0,0,0,10">
                            <TextBlock Text="{Binding MatchingOperationResult}" Foreground="#1B5E20" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Tier 1 Deadline -->
                        <TextBlock Text="Tier 1 Deadline:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <DatePicker Grid.Column="0" SelectedDate="{Binding Tier1Deadline, Mode=TwoWay}" Margin="0,0,6,0"/>
                            <Button Grid.Column="1" Content="Save" Padding="10,5"
                                    Command="{Binding SaveTier1DeadlineCommand}"/>
                        </Grid>

                        <!-- Tier 3 Deadline -->
                        <TextBlock Text="Tier 3 Deadline:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <DatePicker Grid.Column="0" SelectedDate="{Binding Tier3Deadline, Mode=TwoWay}" Margin="0,0,6,0"/>
                            <Button Grid.Column="1" Content="Save" Padding="10,5"
                                    Command="{Binding SaveTier3DeadlineCommand}"/>
                        </Grid>

                        <!-- Tier trigger buttons -->
                        <Separator Margin="0,0,0,10"/>
                        <Button Content="▶ Run Tier 2 – Generate Score Matrix" Padding="10,7" Margin="0,0,0,6"
                                Command="{Binding RunTier2MatrixCommand}" Background="#1565C0" Foreground="White" BorderThickness="0"/>
                        <Button Content="▶ Run Tier 4 – Algorithmic Auto-Match" Padding="10,7" Margin="0,0,0,6"
                                Command="{Binding RunTier4AutoMatchCommand}" Background="#6A1B9A" Foreground="White" BorderThickness="0"/>
                        <Button Content="▶ Run Tier 5 – Fallback Random Assignment" Padding="10,7"
                                Command="{Binding RunTier5FallbackCommand}" Background="#BF360C" Foreground="White" BorderThickness="0"/>

                        <!-- Tier 5 Warnings -->
                        <Border Visibility="{Binding HasIncompleteProfileWarnings, Converter={StaticResource BoolToVis}}"
                                Background="#FFF3E0" BorderBrush="#E65100" BorderThickness="1"
                                CornerRadius="4" Padding="10" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" Foreground="#BF360C" Margin="0,0,0,6"
                                           Text="{Binding IncompleteProfileCount, StringFormat='⚠ {0} Randomly Matched – Profile Incomplete'}"/>
                                <ItemsControl ItemsSource="{Binding IncompleteProfilePairs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock FontSize="11" Foreground="#7F3B08" Margin="0,2,0,0">
                                                <Run Text="• "/>
                                                <Run Text="{Binding Mentor.UserName}"/>
                                                <Run Text=" ↔ "/>
                                                <Run Text="{Binding Mentee.UserName}"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Expander>

            <!-- Managed Pairs -->
            <DockPanel Grid.Row="2" Margin="0,0,0,15">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,5">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding [Supervisor_ManagedPairs_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                    <Button HorizontalAlignment="Right" Content="Clear Selection" Background="Transparent" BorderThickness="0" Foreground="Blue" Cursor="Hand" Command="{Binding SelectPairCommand}" CommandParameter="{x:Null}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IssueFilterPair}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </DockPanel>
                <ListView ItemsSource="{Binding PairsSupervised}" ItemContainerStyle="{StaticResource PairListViewItemStyle}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="5" LastChildFill="True">
                                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                    <components:ProfilePictureControl Width="32" Height="32" Margin="0,0,6,0" VerticalAlignment="Center" ImagePath="{Binding Mentor.ProfilePicturePath}" />
                                    <TextBlock FontWeight="Bold" Text="{Binding [Supervisor_MentorPrefix], Source={x:Static loc:TranslationSource.Instance}}" />
                                    <TextBlock Margin="0,0,12,0" Text="{Binding Mentor.UserName}" />

                                    <components:ProfilePictureControl Width="32" Height="32" Margin="0,0,6,0" VerticalAlignment="Center" ImagePath="{Binding Mentee.ProfilePicturePath}" />
                                    <TextBlock FontWeight="Bold" Text="{Binding [Supervisor_MenteePrefix], Source={x:Static loc:TranslationSource.Instance}}" />
                                    <TextBlock Text="{Binding Mentee.UserName}" />

                                    <!-- Tier badge -->
                                    <Border Margin="10,0,0,0" CornerRadius="3" Padding="5,2" Background="#E3F2FD">
                                        <TextBlock FontSize="10" Foreground="#1565C0" Text="{Binding MatchTier}"/>
                                    </Border>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>

            <!-- Pending / Resolved Issues -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="DarkRed" Text="{Binding [Supervisor_PendingIssues_Label], Source={x:Static loc:TranslationSource.Instance}}" VerticalAlignment="Center" Margin="0,0,15,0" />
                <Button Command="{Binding ToggleResolvedIssuesCommand}" Padding="8,4" VerticalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content" Value="{Binding [Supervisor_ViewResolved_Button], Source={x:Static loc:TranslationSource.Instance}}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowResolvedIssues}" Value="True">
                                    <Setter Property="Content" Value="{Binding [Supervisor_HideResolved_Button], Source={x:Static loc:TranslationSource.Instance}}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
            
            <Grid Grid.Row="4">
                <ListView ItemsSource="{Binding FilteredPendingIssues}" ItemContainerStyle="{StaticResource IssueListViewItemStyle}" ItemTemplate="{StaticResource IssueItemTemplate}">
                    <ListView.Style>
                        <Style TargetType="ListView">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowResolvedIssues}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.Style>
                </ListView>
                <ListView ItemsSource="{Binding FilteredResolvedIssues}" ItemContainerStyle="{StaticResource IssueListViewItemStyle}" ItemTemplate="{StaticResource IssueItemTemplate}" Visibility="{Binding ShowResolvedIssues, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Grid>

        <!-- ── DETAIL PANE (RIGHT) ── -->
        <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1" Background="#FAFAFA" CornerRadius="4" Padding="0">
            <Grid>
                <!-- Placeholder text when no detail is selected -->
                <TextBlock Text="Select a pair or an issue from the lists to view its details." Foreground="#AAA" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Medium">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedPaneContent}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                
                <!-- Injected Child ViewModel View -->
                <ContentControl Content="{Binding SelectedPaneContent}" Margin="10" />
            </Grid>
        </Border>
    </Grid>
</UserControl>