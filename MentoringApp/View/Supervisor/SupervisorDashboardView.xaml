<UserControl
    x:Class="MentoringApp.View.Supervisor.SupervisorDashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:components="clr-namespace:MentoringApp.View.Components"
    xmlns:loc="clr-namespace:MentoringApp.Localization"
    d:DesignHeight="600"
    d:DesignWidth="800"
    mc:Ignorable="d"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <DataTemplate x:Key="IssueItemTemplate">
            <StackPanel Margin="5">
                <TextBlock
                    x:Name="Desc"
                    FontSize="14"
                    FontWeight="Medium"
                    Text="{Binding Description}"
                    TextWrapping="Wrap" />
                <StackPanel Opacity="0.7" Orientation="Horizontal">
                    <TextBlock Margin="0,0,10,0" FontStyle="Italic">
                        <TextBlock.Text>
                            <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Category_">
                                <Binding Path="Category.Name" />
                                <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock
                        x:Name="Stat"
                        VerticalAlignment="Center"
                        FontSize="10"
                        Text="{Binding [Supervisor_IssuePending], Source={x:Static loc:TranslationSource.Instance}}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="10"
                        Text="{Binding CreationDate, StringFormat='{} | Created: {0:d}'}" />
                </StackPanel>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsResolved}" Value="True">
                    <Setter TargetName="Desc" Property="TextDecorations" Value="Strikethrough" />
                    <Setter TargetName="Desc" Property="Foreground" Value="Gray" />
                    <Setter TargetName="Stat" Property="Tag" Value="resolved" />
                    <Setter TargetName="Stat" Property="Foreground" Value="DarkGreen" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <Style x:Key="IssueListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnIssueItemClick" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E0E0E0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Underline-tab style for RadioButtons used as issue tab toggles -->
        <Style x:Key="IssueTabStyle" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" Padding="6,3,6,5"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <TextBlock x:Name="Label"
                                       Text="{TemplateBinding Content}"
                                       FontSize="13"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                                <Setter TargetName="Label" Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="Label" Property="Foreground"
                                        Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Label" Property="Foreground"
                                        Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PairListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnPairItemClick" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E0E0E0" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- ── MASTER PANE (LEFT) ── -->
        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <!-- 0: Phase notification -->
                <RowDefinition Height="Auto"/>
                <!-- 1: Supervisor name (admin-only) -->
                <RowDefinition Height="Auto"/>
                <!-- 2: Stats / progress -->
                <RowDefinition Height="Auto"/>
                <!-- 3: Tier 5 warnings -->
                <RowDefinition Height="Auto"/>
                <!-- 4: Pairs list -->
                <RowDefinition Height="1.5*"/>
                <!-- 5: Issues header -->
                <RowDefinition Height="Auto"/>
                <!-- 6: Issues list -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Row 0: Phase notification ── -->
            <Border Grid.Row="0"
                    Visibility="{Binding IsPhaseBannerVisible, Converter={StaticResource BoolToVis}}"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                    BorderThickness="1"
                    Padding="10,8"
                    Margin="0,0,0,12">
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Content="🛈"
                            Command="{Binding ShowPhaseInfoCommand}"
                            ToolTip="Click for details about the current phase"
                            Background="Transparent" BorderThickness="0"
                            FontSize="13" Cursor="Hand"
                            VerticalAlignment="Top" Margin="8,0,0,0"/>
                    <StackPanel>
                        <TextBlock Text="{Binding BannerTitle}"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding BannerSubtitle}"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   FontSize="11" TextWrapping="Wrap" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding BannerTimer}" FontSize="11" FontWeight="Medium"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ── Row 1: Supervisor name (admin viewing only) ── -->
            <StackPanel Grid.Row="1"
                        Visibility="{Binding IsAdminViewing, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,10">
                <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding SelectedSupervisor.UserName}"/>
                <TextBlock Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="12">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{1} {0}">
                            <Binding Path="PairsSupervised.Count"/>
                            <Binding Path="[Supervisor_TotalPairs_Label]" Source="{x:Static loc:TranslationSource.Instance}"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>

            <!-- ── Row 2: Class progress + inactive students (registration phase only) ── -->
            <StackPanel Grid.Row="2" Margin="0,0,0,12"
                        Visibility="{Binding IsPhase1Active, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding ClassProgressInfo}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ProgressBar Minimum="0" Maximum="100" Value="{Binding ClassProgressPercent}" Height="10" Margin="0,0,0,8"/>
                <TextBlock Text="Students with incomplete profiles:"
                           FontWeight="SemiBold" Margin="0,0,0,4">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding InactiveStudents.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <ItemsControl ItemsSource="{Binding InactiveStudents}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,1,0,0">
                                <Run Text="• " FontWeight="Bold"/>
                                <Run Text="{Binding UserName}"/>
                                <Run Text=" ("/>
                                <Run Text="{Binding Email}"/>
                                <Run Text=")"/>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- ── Row 3: Tier 5 warnings ── -->
            <Border Grid.Row="3"
                    Visibility="{Binding HasIncompleteProfileWarnings, Converter={StaticResource BoolToVis}}"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                    BorderThickness="1"
                    Padding="10,8" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontWeight="Bold" Margin="0,0,0,5"
                               Text="{Binding IncompleteProfileCount, StringFormat='⚠ {0} Randomly Matched – Profile Incomplete'}"/>
                    <ItemsControl ItemsSource="{Binding IncompleteProfilePairs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="11" Margin="0,2,0,0">
                                    <Run Text="• "/>
                                    <Run Text="{Binding Mentor.UserName}"/>
                                    <Run Text=" ↔ "/>
                                    <Run Text="{Binding Mentee.UserName}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ── Row 4: Managed pairs ── -->
            <DockPanel Grid.Row="4" Margin="0,0,0,12">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,5">
                    <TextBlock FontSize="14" FontWeight="SemiBold"
                               Text="{Binding [Supervisor_ManagedPairs_Label], Source={x:Static loc:TranslationSource.Instance}}"
                               VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" Content="Clear Selection"
                            Background="Transparent" BorderThickness="0" Foreground="Blue"
                            Cursor="Hand" Command="{Binding SelectPairCommand}" CommandParameter="{x:Null}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IssueFilterPair}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </DockPanel>
                <TextBlock Text="No pairs assigned yet." FontSize="12" Foreground="Gray" Margin="0,8,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PairsSupervised.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <ListView ItemsSource="{Binding PairsSupervised}"
                          ItemContainerStyle="{StaticResource PairListViewItemStyle}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="5" LastChildFill="True">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <components:ProfilePictureControl Width="28" Height="28" Margin="0,0,6,0"
                                        VerticalAlignment="Center" ImagePath="{Binding Mentor.ProfilePicturePath}"
                                        Gender="{Binding Mentor.Gender}"/>
                                    <TextBlock FontWeight="Bold"
                                               Text="{Binding [Supervisor_MentorPrefix], Source={x:Static loc:TranslationSource.Instance}}"/>
                                    <TextBlock Margin="0,0,12,0" Text="{Binding Mentor.UserName}"/>

                                    <components:ProfilePictureControl Width="28" Height="28" Margin="0,0,6,0"
                                        VerticalAlignment="Center" ImagePath="{Binding Mentee.ProfilePicturePath}"
                                        Gender="{Binding Mentee.Gender}"/>
                                    <TextBlock FontWeight="Bold"
                                               Text="{Binding [Supervisor_MenteePrefix], Source={x:Static loc:TranslationSource.Instance}}"/>
                                    <TextBlock Text="{Binding Mentee.UserName}"/>

                                    <Border Margin="10,0,0,0" BorderBrush="#AAAAAA" BorderThickness="1" Padding="4,1">
                                        <TextBlock FontSize="10" Text="{Binding MatchTier}"/>
                                    </Border>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>

            <!-- ── Row 5: Issues header ── -->
            <DockPanel Grid.Row="5" Margin="0,0,0,2">
                <!-- Tab toggles -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <RadioButton Content="Pending"
                                 Style="{StaticResource IssueTabStyle}"
                                 IsChecked="{Binding IsShowingPending, Mode=OneWay}"
                                 Command="{Binding ShowPendingCommand}"
                                 ToolTip="Show unresolved issues"/>
                    <RadioButton Content="Resolved"
                                 Style="{StaticResource IssueTabStyle}"
                                 IsChecked="{Binding IsShowingResolved, Mode=OneWay}"
                                 Command="{Binding ShowResolvedCommand}"
                                 Margin="4,0,0,0"
                                 ToolTip="Show resolved issues"/>
                </StackPanel>
                <!-- Context title -->
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding IssuesSectionContextTitle}"
                           FontSize="12" FontStyle="Italic"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                           Margin="0,0,0,5"/>
            </DockPanel>

            <!-- ── Row 6: Issues list ── -->
            <Grid Grid.Row="6">
                <TextBlock Text="No pending issues." FontSize="12" Foreground="Gray" Margin="0,8,0,0"
                           VerticalAlignment="Top" Panel.ZIndex="1">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding FilteredPendingIssues.Count}" Value="0"/>
                                        <Condition Binding="{Binding ShowResolvedIssues}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="No resolved issues." FontSize="12" Foreground="Gray" Margin="0,8,0,0"
                           VerticalAlignment="Top" Panel.ZIndex="1">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding FilteredResolvedIssues.Count}" Value="0"/>
                                        <Condition Binding="{Binding ShowResolvedIssues}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <ListView ItemsSource="{Binding FilteredPendingIssues}"
                          ItemContainerStyle="{StaticResource IssueListViewItemStyle}"
                          ItemTemplate="{StaticResource IssueItemTemplate}">
                    <ListView.Style>
                        <Style TargetType="ListView">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowResolvedIssues}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.Style>
                </ListView>
                <ListView ItemsSource="{Binding FilteredResolvedIssues}"
                          ItemContainerStyle="{StaticResource IssueListViewItemStyle}"
                          ItemTemplate="{StaticResource IssueItemTemplate}"
                          Visibility="{Binding ShowResolvedIssues, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Grid>

        <!-- ── DETAIL PANE (RIGHT) ── -->
        <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1" Padding="0">
            <Grid>
                <TextBlock Text="Select a pair or an issue from the lists to view its details."
                           Foreground="#AAA" FontSize="14" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontWeight="Medium">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedPaneContent}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <ContentControl Content="{Binding SelectedPaneContent}" Margin="10"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
