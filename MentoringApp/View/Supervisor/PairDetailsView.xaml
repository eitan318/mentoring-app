<UserControl x:Class="MentoringApp.View.Supervisor.PairDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MentoringApp.View.Supervisor"
             xmlns:components="clr-namespace:MentoringApp.View.Components"
             xmlns:loc="clr-namespace:MentoringApp.Localization"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: Full Card Presentation + Meeting Hours Progress -->
        <Border Grid.Row="0" Margin="0,0,0,20" Padding="15" Background="#FFFFFF" BorderBrush="#EAEAEA" BorderThickness="1" CornerRadius="8">
            <StackPanel>
                <TextBlock Text="{Binding [PairDetails_Title], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="SemiBold" Foreground="#555" FontSize="18" Margin="0,0,0,15"/>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Mentor Card -->
                    <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="1" Padding="10" Background="#F9F9F9" CornerRadius="6">
                        <StackPanel Orientation="Horizontal">
                            <components:ProfilePictureControl Width="60" Height="60" Margin="0,0,12,0"
                                                              VerticalAlignment="Center"
                                                              ImagePath="{Binding CurrentPair.Mentor.ProfilePicturePath}"
                                                              Gender="{Binding CurrentPair.Mentor.Gender}"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding [Admin_ManagePair_Mentor], Source={x:Static loc:TranslationSource.Instance}}" FontSize="11" Foreground="#888" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding CurrentPair.Mentor.UserName}" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="{Binding CurrentPair.Mentor.Email}" Foreground="Gray" FontSize="12" Margin="0,2,0,0"/>
                                <TextBlock FontSize="12" Foreground="DarkGray" Margin="0,2,0,0">
                                    <Run Text="{Binding [Admin_ManagePair_Grade], Source={x:Static loc:TranslationSource.Instance}, Mode=OneWay}" />
                                    <Run Text=" " />
                                    <Run>
                                        <Run.Text>
                                            <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Grade_">
                                                <Binding Path="CurrentPair.Mentor.Grade.Name" />
                                                <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture" />
                                            </MultiBinding>
                                        </Run.Text>
                                    </Run>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock Grid.Column="1" Text="&amp;" FontSize="24" FontWeight="Bold" Foreground="#CCC" VerticalAlignment="Center" Margin="15,0,15,0"/>
                    
                    <!-- Mentee Card -->
                    <Border Grid.Column="2" BorderBrush="#DDD" BorderThickness="1" Padding="10" Background="#F9F9F9" CornerRadius="6">
                        <StackPanel Orientation="Horizontal">
                            <components:ProfilePictureControl Width="60" Height="60" Margin="0,0,12,0"
                                                              VerticalAlignment="Center"
                                                              ImagePath="{Binding CurrentPair.Mentee.ProfilePicturePath}"
                                                              Gender="{Binding CurrentPair.Mentee.Gender}"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding [Admin_ManagePair_Mentee], Source={x:Static loc:TranslationSource.Instance}}" FontSize="11" Foreground="#888" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding CurrentPair.Mentee.UserName}" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="{Binding CurrentPair.Mentee.Email}" Foreground="Gray" FontSize="12" Margin="0,2,0,0"/>
                                <TextBlock FontSize="12" Foreground="DarkGray" Margin="0,2,0,0">
                                    <Run Text="{Binding [Admin_ManagePair_Grade], Source={x:Static loc:TranslationSource.Instance}, Mode=OneWay}" />
                                    <Run Text=" " />
                                    <Run>
                                        <Run.Text>
                                            <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Grade_">
                                                <Binding Path="CurrentPair.Mentee.Grade.Name" />
                                                <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture" />
                                            </MultiBinding>
                                        </Run.Text>
                                    </Run>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
                <!-- Meeting Hours Progress -->
                <StackPanel>
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock DockPanel.Dock="Left" FontSize="12" Foreground="#555" Text="{Binding [PairDetails_MeetingProgress_Label], Source={x:Static loc:TranslationSource.Instance}}"/>
                        <TextBlock DockPanel.Dock="Right" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right">
                            <Run Text="{Binding TotalMeetingHours, StringFormat='{}{0:0.#}'}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding RequiredMeetingHours, StringFormat='{}{0:0} hrs'}"/>
                        </TextBlock>
                    </DockPanel>
                    <ProgressBar Height="10" Minimum="0" Maximum="100" Value="{Binding HoursProgress}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Content: Dashboard Layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column: Reviews (Smaller) -->
            <DockPanel Grid.Column="0">
                <DockPanel.Style>
                    <Style TargetType="DockPanel">
                        <Setter Property="Grid.ColumnSpan" Value="1"/>
                        <Setter Property="Margin" Value="0,0,15,0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowIssues}" Value="False">
                                <Setter Property="Grid.ColumnSpan" Value="2"/>
                                <Setter Property="Margin" Value="0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DockPanel.Style>
                <TextBlock DockPanel.Dock="Top" FontSize="16" FontWeight="SemiBold"
                           Text="{Binding [PairDetails_RecentReviews_Label], Source={x:Static loc:TranslationSource.Instance}}"
                           Margin="0,0,0,10"/>
                <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Background="White">
                    <ListView ItemsSource="{Binding PairReviews}" BorderThickness="0" Background="Transparent">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5,8,5,8">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left" Text="{Binding Date, StringFormat='{}{0:MMM dd, yyyy}'}" FontWeight="Medium" Foreground="#666" FontSize="12"/>
                                        <TextBlock DockPanel.Dock="Right" FontSize="11" Foreground="#2E7D32" HorizontalAlignment="Right"
                                                   Text="{Binding AmountOfHours, StringFormat='{}{0:0.#} hrs'}"/>
                                    </DockPanel>
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Margin="0,5,0,0" FontSize="13"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </DockPanel>

            <!-- Right Column: Issues (Larger) -->
            <DockPanel Grid.Column="1" Visibility="{Binding ShowIssues, Converter={StaticResource BoolToVis}}">
                <TextBlock DockPanel.Dock="Top" FontSize="16" FontWeight="SemiBold"
                           Text="{Binding [PairDetails_ActiveIssues_Label], Source={x:Static loc:TranslationSource.Instance}}"
                           Margin="0,0,0,10"/>
                <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Background="White">
                    <ListView ItemsSource="{Binding PairIssues}" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="5,8">
                                    <StackPanel>
                                        <TextBlock FontWeight="Medium" Text="{Binding Description}" TextWrapping="Wrap" FontSize="14" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal" Opacity="0.8">
                                            <Border Background="#E8F4FD" CornerRadius="3" Padding="6,2" Margin="0,0,10,0">
                                                <TextBlock Foreground="#005A9E" FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Category_">
                                                            <Binding Path="Category.Name" />
                                                            <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </Border>
                                            <TextBlock Text="{Binding CreationDate, StringFormat='{}Created: {0:MMM dd}'}" VerticalAlignment="Center" FontSize="12" Foreground="Gray"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
