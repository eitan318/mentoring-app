<UserControl
    x:Class="MentoringApp.View.User.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MentoringApp.View.User"
    xmlns:loc="clr-namespace:MentoringApp.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">
    <Grid Margin="20">
        <!-- Top-Right Language Picker -->
        <ComboBox 
            HorizontalAlignment="Right" 
            VerticalAlignment="Top" 
            Width="80" 
            ItemsSource="{Binding AvailableLanguages}"
            SelectedItem="{Binding SelectedLanguage}"
            Margin="0,0,10,0"/>

        <!-- Centered Login Form -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Visibility="{Binding WasCodeSent, Converter={StaticResource InverseBoolToVis}}">
                <TextBlock Margin="0,5"
                           Text="{Binding [Login_NationalId_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                <TextBox Width="200" Text="{Binding NationalId, UpdateSourceTrigger=PropertyChanged}" />
                <Button
                    Margin="0,10"
                    Command="{Binding SendVerificationCodeCommand}"
                    Content="{Binding [Login_SendCode_Button], Source={x:Static loc:TranslationSource.Instance}}" />
                <TextBlock
                    MaxWidth="200"
                    Foreground="Red"
                    Text="{Binding ErrorMessage}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Visibility="{Binding WasCodeSent, Converter={StaticResource BoolToVis}}">
                <TextBlock Margin="0,5"
                           Text="{Binding [Login_VerificationCode_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                <TextBox Width="200" Text="{Binding VerificationCode, UpdateSourceTrigger=PropertyChanged}" />
                <Button
                    Margin="0,10"
                    Command="{Binding LoginCommand}"
                    Content="{Binding [Login_Login_Button], Source={x:Static loc:TranslationSource.Instance}}" />
                <TextBlock
                    MaxWidth="200"
                    Foreground="Red"
                    Text="{Binding ErrorMessage}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>