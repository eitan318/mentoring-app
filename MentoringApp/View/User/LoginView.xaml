<UserControl
    x:Class="MentoringApp.View.User.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MentoringApp.View.User"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel>
            <StackPanel Visibility="{Binding WasCodeSent, Converter={StaticResource InverseBoolToVis}}">
                <TextBlock Margin="0,5" Text="National Id:" />
                <TextBox Width="200" Text="{Binding NationalId, UpdateSourceTrigger=PropertyChanged}" />
                <Button
                    Margin="0,10"
                    Command="{Binding SendVerificationCodeCommand}"
                    Content="Send Verification Code" />
                <TextBlock
                    MaxWidth="200"
                    Foreground="Red"
                    Text="{Binding ErrorMessage}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Visibility="{Binding WasCodeSent, Converter={StaticResource BoolToVis}}">
                <TextBlock Margin="0,5" Text="Verification code:" />
                <TextBox Width="200" Text="{Binding VerificationCode, UpdateSourceTrigger=PropertyChanged}" />
                <Button
                    Margin="0,10"
                    Command="{Binding LoginCommand}"
                    Content="Login" />
                <TextBlock
                    MaxWidth="200"
                    Foreground="Red"
                    Text="{Binding ErrorMessage}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </StackPanel>

    </Grid>
</UserControl>