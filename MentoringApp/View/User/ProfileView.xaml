<UserControl x:Class="MentoringApp.View.User.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <StackPanel>
            <Label Content="Username" />
            <TextBox IsReadOnly="{Binding IsReadOnly}" 
                     Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

            <Label Content="Email Address" Margin="0,10,0,0"/>
            <TextBox IsReadOnly="{Binding IsReadOnly}" 
                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

            <Label Content="National ID (Locked)" Margin="0,10,0,0"/>
            <TextBox IsReadOnly="True" Text="{Binding NationalId}" Background="#F0F0F0" />

            <StackPanel Visibility="{Binding IsSupervisor, Converter={StaticResource InverseBoolToVis}}">

                <Label Content="Grade" Margin="0,10,0,0"/>
                <ComboBox IsEnabled="{Binding IsEditMode}"
                          ItemsSource="{Binding Grades}"
                          DisplayMemberPath="Name"
                          SelectedValue="{Binding SelectedGrade, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

                <StackPanel Visibility="{Binding HasMentorProfile, Converter={StaticResource BoolToVis}}">
                    <Label Content="Subject to Teach" Margin="0,10,0,0"/>
                    <ComboBox IsEnabled="{Binding IsEditMode}"
                              ItemsSource="{Binding Subjects}"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding SubjectToTeach, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />
                </StackPanel>

                <StackPanel Visibility="{Binding HasMenteeProfile, Converter={StaticResource BoolToVis}}">
                    <Label Content="Subject to Learn" Margin="0,10,0,0"/>
                    <ComboBox IsEnabled="{Binding IsEditMode}"
                              ItemsSource="{Binding Subjects}"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding SubjectToLearn, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />
                </StackPanel>
            </StackPanel>

            <Grid Margin="0,20,0,0">
                <Button Content="Edit Profile" 
                        Command="{Binding ToggleEditCommand}"
                        Visibility="{Binding IsReadOnly, Converter={StaticResource BoolToVis}}" 
                        Height="35"/>

                <Button Content="Save Changes" 
                        Command="{Binding SaveCommand}" 
                        Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"
                        Height="35" Background="LightGreen"/>
            </Grid>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" Margin="0,10" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>