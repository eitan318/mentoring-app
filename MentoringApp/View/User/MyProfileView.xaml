<UserControl
    x:Class="MentoringApp.View.User.MyProfileView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:MentoringApp.View.Components">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <StackPanel>

                <!--  ── Profile Picture Section ──  -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Grid Width="100" Height="100">
                        <components:ProfilePictureControl ImagePath="{Binding ProfilePicturePath}" />
                        <!--  Camera overlay button  -->
                        <Button
                            Width="28" Height="28"
                            VerticalAlignment="Bottom" HorizontalAlignment="Right"
                            Background="#444" Foreground="White"
                            BorderThickness="0" 
                            Content="📷"
                            FontSize="14"
                            Cursor="Hand"
                            ToolTip="Upload / Change Profile Picture"
                            Command="{Binding UploadProfilePictureCommand}" />
                    </Grid>
                    <TextBlock
                        Margin="0,6,0,0"
                        HorizontalAlignment="Center"
                        FontSize="12" Foreground="Gray"
                        Text="Click 📷 to change photo" />
                </StackPanel>

                <Label Content="Username" />
                <TextBox IsReadOnly="{Binding IsReadOnly}" Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

                <Label Margin="0,10,0,0" Content="Email Address" />
                <TextBox IsReadOnly="{Binding IsReadOnly}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

                <Label Margin="0,10,0,0" Content="National ID (Locked)" />
                <TextBox
                    Background="#F0F0F0"
                    IsReadOnly="True"
                    Text="{Binding NationalId}" />

                <StackPanel Visibility="{Binding IsSupervisor, Converter={StaticResource InverseBoolToVis}}">

                    <Label Margin="0,10,0,0" Content="Grade" />
                    <ComboBox
                        DisplayMemberPath="Name"
                        TextSearch.TextPath="Name"
                        IsEnabled="{Binding IsEditMode}"
                        ItemsSource="{Binding Grades}"
                        SelectedItem="{Binding SelectedGrade, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

                    <StackPanel Visibility="{Binding HasMentorProfile, Converter={StaticResource BoolToVis}}">
                        <Label Margin="0,10,0,0" Content="Subject to Teach" />
                        <ComboBox
                            DisplayMemberPath="Name"
                            TextSearch.TextPath="Name"
                            IsEnabled="{Binding IsEditMode}"
                            ItemsSource="{Binding Subjects}"
                            SelectedValue="{Binding SubjectToTeach, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                            SelectedValuePath="Id" />
                    </StackPanel>

                    <StackPanel Visibility="{Binding HasMenteeProfile, Converter={StaticResource BoolToVis}}">
                        <Label Margin="0,10,0,0" Content="Subject to Learn" />
                        <ComboBox
                            DisplayMemberPath="Name"
                            TextSearch.TextPath="Name"
                            IsEnabled="{Binding IsEditMode}"
                            ItemsSource="{Binding Subjects}"
                            SelectedValue="{Binding SubjectToLearn, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                            SelectedValuePath="Id" />
                    </StackPanel>
                </StackPanel>

                <Grid Margin="0,20,0,0">
                    <Button
                        Height="35"
                        Command="{Binding ToggleEditCommand}"
                        Content="Edit Profile"
                        Visibility="{Binding IsReadOnly, Converter={StaticResource BoolToVis}}" />

                    <Button
                        Height="35"
                        Background="LightGreen"
                        Command="{Binding SaveCommand}"
                        Content="Save Changes"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}" />
                </Grid>

                <TextBlock
                    Margin="0,10"
                    HorizontalAlignment="Center"
                    Foreground="Red"
                    Text="{Binding ErrorMessage}" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>