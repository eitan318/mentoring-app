<UserControl
    x:Class="MentoringApp.View.User.IssueView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MentoringApp.View.User"
    xmlns:loc="clr-namespace:MentoringApp.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock
                FontSize="22"
                FontWeight="Bold"
                Text="{Binding [Issue_Title], Source={x:Static loc:TranslationSource.Instance}}" />

            <TextBlock
                FontSize="14"
                Foreground="#005A9E"
                Margin="0,5,0,15"
                FontStyle="Italic"
                Text="{Binding RelatedPairName}" />

            <Border
                Padding="0,0,0,10"
                BorderBrush="LightGray"
                BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock
                        FontSize="12"
                        Foreground="Gray"
                        Text="{Binding [Issue_Category_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                    <!-- Category.Name is user-typed/DB data — not translated -->
                    <TextBlock FontSize="16" Text="{Binding CurrentIssue.Category.Name}" />
                </StackPanel>
            </Border>

            <StackPanel>
                <TextBlock
                    FontSize="12"
                    Foreground="Gray"
                    Text="{Binding [Issue_Description_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                <!-- Description is user-typed — not translated -->
                <TextBlock
                    FontSize="16"
                    Text="{Binding CurrentIssue.Description}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <!-- Forwarded badge -->
            <Border Margin="0,12,0,0" Background="#FFF3E0" BorderBrush="#FFB300" BorderThickness="1"
                    CornerRadius="4" Padding="10,6" HorizontalAlignment="Left"
                    Visibility="{Binding CurrentIssue.IsForwardedToAdmin, Converter={StaticResource BoolToVis}}">
                <TextBlock FontSize="12" Foreground="#E65100"
                           Text="{Binding [Issue_ForwardedBadge], Source={x:Static loc:TranslationSource.Instance}}"/>
            </Border>

            <StackPanel
                Margin="0,20,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    Padding="10,6"
                    Margin="5"
                    Background="#1565C0"
                    Foreground="White"
                    Cursor="Hand"
                    ToolTip="{Binding [Issue_Forward_Tooltip], Source={x:Static loc:TranslationSource.Instance}}"
                    Command="{Binding ForwardToAdminCommand}"
                    Content="{Binding [Issue_Forward_Button], Source={x:Static loc:TranslationSource.Instance}}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding CanForward}" Value="True"/>
                                        <Condition Binding="{Binding CurrentIssue.IsForwardedToAdmin}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button
                    Padding="10,6"
                    Margin="5"
                    Background="DarkGreen"
                    Cursor="Hand"
                    ToolTip="{Binding [Issue_Resolve_Tooltip], Source={x:Static loc:TranslationSource.Instance}}"
                    Command="{Binding ResolveIssueCommand}"
                    Content="{Binding [Issue_Resolve_Button], Source={x:Static loc:TranslationSource.Instance}}"
                    Foreground="White"
                    Visibility="{Binding CurrentIssue.IsResolved, Converter={StaticResource InverseBoolToVis}}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
