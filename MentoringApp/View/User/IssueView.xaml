<UserControl
    x:Class="MentoringApp.View.User.IssueView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MentoringApp.View.User"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="30">
        <StackPanel>
            <TextBlock
                FontSize="22"
                FontWeight="Bold"
                Text="Issue Details" />

            <Border
                Padding="0,0,0,10"
                BorderBrush="LightGray"
                BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock
                        FontSize="12"
                        Foreground="Gray"
                        Text="Category" />
                    <TextBlock FontSize="16" Text="{Binding CurrentIssue.Category.Name}" />
                </StackPanel>
            </Border>

            <StackPanel>
                <TextBlock
                    FontSize="12"
                    Foreground="Gray"
                    Text="Description" />
                <TextBlock
                    FontSize="16"
                    Text="{Binding CurrentIssue.Description}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel
                Margin="0,20,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    Width="100"
                    Margin="5"
                    Command="{Binding BackCommand}"
                    Content="Back" />
                <Button
                    Width="120"
                    Margin="5"
                    Background="DarkGreen"
                    Content="Mark as Resolved"
                    Foreground="White"
                    Command="{Binding ResolveIssueCommand}"
                    Visibility="{Binding CurrentIssue.IsResolved, Converter={StaticResource InverseBoolToVis}}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
