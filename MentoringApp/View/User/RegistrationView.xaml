<UserControl
    x:Class="MentoringApp.View.User.RegistrationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="clr-namespace:MentoringApp.Localization"
    xmlns:model="clr-namespace:MentoringApp.Model;assembly=MentoringApp.Model"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <Grid Margin="20">
        <StackPanel>
            <!-- Info banner: admin does not need to fill every field -->
            <Border Background="#EEF4FF" BorderBrush="#9ABFFF" BorderThickness="1"
                    CornerRadius="4" Padding="10,8" Margin="0,0,0,14">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ℹ " FontSize="14" VerticalAlignment="Top" Foreground="#1A56DB"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#1E3A6E" FontSize="12"
                               Text="Only the required fields (marked with *) must be filled. Everything else is optional — the user can complete their profile after their first login."/>
                </StackPanel>
            </Border>

            <TextBox Tag="{Binding [Register_Username_Tag], Source={x:Static loc:TranslationSource.Instance}}"
                     Text="{Binding UserName}" />
            <TextBox Tag="{Binding [Register_Email_Tag], Source={x:Static loc:TranslationSource.Instance}}"
                     Text="{Binding Email}" />
            <TextBox Tag="{Binding [Register_NationalId_Tag], Source={x:Static loc:TranslationSource.Instance}}"
                     Text="{Binding NationalId}" />

            <TextBox Tag="Phone Number (optional)"
                     Text="{Binding PhoneNumber}"
                     Margin="0,5" />

            <Label Content="Gender (optional)" Margin="0,5,0,0" />
            <ComboBox
                ItemsSource="{Binding GenderOptions}"
                SelectedValue="{Binding SelectedGenderValue, UpdateSourceTrigger=PropertyChanged}"
                SelectedValuePath="Value"
                DisplayMemberPath="Display"
                Margin="0,5" />

            <!-- Grade and Class Num (for Student only) -->
            <StackPanel Visibility="{Binding SupervisorOrStudentIsSupervisor, Converter={StaticResource InverseBoolToVis}}">
                <ComboBox
                    ItemsSource="{Binding Grades}"
                    SelectedItem="{Binding SelectedGrade, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                    Tag="{Binding [Register_Grade_Tag], Source={x:Static loc:TranslationSource.Instance}}"
                    Margin="0,5">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Grade_">
                                        <Binding Path="Name" />
                                        <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBox Tag="Class Number (optional)"
                         Text="{Binding ClassNum}"
                         Margin="0,5" />

                <!-- Mentor / Mentee role selection -->
                <CheckBox
                    Margin="0,5"
                    Content="{Binding [Register_IsMentor_Check], Source={x:Static loc:TranslationSource.Instance}}"
                    IsChecked="{Binding IsMentor}" />
                <CheckBox
                    Margin="0,5"
                    Content="{Binding [Register_IsMentee_Check], Source={x:Static loc:TranslationSource.Instance}}"
                    IsChecked="{Binding IsMentee}" />
            </StackPanel>

            <!-- Mentor-specific fields: subject to teach, max mentees, preferred mentee gender -->
            <StackPanel Visibility="{Binding IsMentor, Converter={StaticResource BoolToVis}}">
                <ComboBox
                    ItemsSource="{Binding Subjects}"
                    SelectedValue="{Binding SubjectToTeach, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                    SelectedValuePath="Id"
                    Tag="{Binding [Register_SubjectToTeach_Tag], Source={x:Static loc:TranslationSource.Instance}}"
                    Margin="0,5">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Subject_">
                                        <Binding Path="Name" />
                                        <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Label Content="Max Mentees (optional)" Margin="0,5,0,0" />
                <TextBox Text="{Binding MaxMentees, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,5" />

                <Label Content="Preferred Mentee Gender (optional)" Margin="0,5,0,0" />
                <ComboBox
                    ItemsSource="{Binding GenderPreferenceOptions}"
                    SelectedValue="{Binding SelectedPreferredMenteeGenderValue, UpdateSourceTrigger=PropertyChanged}"
                    SelectedValuePath="Value"
                    DisplayMemberPath="Display"
                    Margin="0,5" />
            </StackPanel>

            <!-- Mentee-specific fields: subject to learn, preferred mentor gender -->
            <StackPanel Visibility="{Binding IsMentee, Converter={StaticResource BoolToVis}}">
                <ComboBox
                    ItemsSource="{Binding Subjects}"
                    SelectedValue="{Binding SubjectToLearn, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                    SelectedValuePath="Id"
                    Tag="{Binding [Register_SubjectToLearn_Tag], Source={x:Static loc:TranslationSource.Instance}}"
                    Margin="0,5">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Subject_">
                                        <Binding Path="Name" />
                                        <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Label Content="Preferred Mentor Gender (optional)" Margin="0,5,0,0" />
                <ComboBox
                    ItemsSource="{Binding GenderPreferenceOptions}"
                    SelectedValue="{Binding SelectedPreferredMentorGenderValue, UpdateSourceTrigger=PropertyChanged}"
                    SelectedValuePath="Value"
                    DisplayMemberPath="Display"
                    Margin="0,5" />
            </StackPanel>

            <TextBlock Text="* Required field" FontSize="10" Foreground="Gray" Margin="0,6,0,0" />
            <Button
                Height="35"
                Margin="0,10,0,0"
                Cursor="Hand"
                IsDefault="True"
                Command="{Binding RegisterCommand}"
                Content="{Binding [Register_Submit_Button], Source={x:Static loc:TranslationSource.Instance}}" />

            <TextBlock
                Margin="0,5"
                Foreground="Red"
                Text="{Binding ErrorMessage}"
                TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</UserControl>
