<UserControl
    x:Class="MentoringApp.View.User.AuthenticatedDashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:MentoringApp.View.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MentoringApp.View.User"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <DockPanel>
        <Grid
            Height="40"
            Background="#F5F5F5"
            DockPanel.Dock="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Left: Back button  -->
            <StackPanel
                Grid.Column="0"
                Margin="8,0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    Command="{Binding BackCommand}"
                    Content="← Back"
                    Visibility="{Binding IsBackVisible, Converter={StaticResource BoolToVis}}" />
            </StackPanel>

            <!--  Center: App title  -->
            <TextBlock
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontWeight="Bold"
                Text="MENTOR APP" />

            <!--  Right: Profile + Logout  -->
            <StackPanel
                Grid.Column="2"
                Margin="8,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    Margin="0,0,6,0"
                    Command="{Binding NavigateProfileCommand}"
                    Visibility="{Binding IsProfileButtonVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <components:ProfilePictureControl
                            Width="28"
                            Height="28"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            ImagePath="{Binding CurrentUser.ProfilePicturePath}" />
                        <TextBlock VerticalAlignment="Center" Text="{Binding CurrentUser.UserName}" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding LogoutCommand}" Content="Logout" />
            </StackPanel>
        </Grid>

        <ContentControl Content="{Binding ActiveSubPage}" />
    </DockPanel>
</UserControl>