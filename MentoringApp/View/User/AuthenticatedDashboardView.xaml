<UserControl
    x:Class="MentoringApp.View.User.AuthenticatedDashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:MentoringApp.View.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MentoringApp.View.User"
    xmlns:loc="clr-namespace:MentoringApp.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">
    <DockPanel>
        <Grid
            Height="40"
            Background="#F5F5F5"
            DockPanel.Dock="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Left: Back button  -->
            <StackPanel
                Grid.Column="0"
                Margin="8,0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    Command="{Binding BackCommand}"
                    Content="{Binding [Nav_Back], Source={x:Static loc:TranslationSource.Instance}}"
                    Visibility="{Binding IsBackVisible, Converter={StaticResource BoolToVis}}" />
            </StackPanel>

            <!--  Center: App title  -->
            <TextBlock
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontWeight="Bold"
                Text="{Binding [App_Title], Source={x:Static loc:TranslationSource.Instance}}" />

            <!--  Right: Language toggle + Profile + Logout  -->
            <StackPanel
                Grid.Column="2"
                Margin="8,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal">

                <!--  Language toggle  -->
                <ComboBox
                    Margin="0,0,8,0"
                    Width="55"
                    VerticalAlignment="Center"
                    ItemsSource="{Binding AvailableLanguages}"
                    SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                    ToolTip="{Binding [Language_Label], Source={x:Static loc:TranslationSource.Instance}}" />

                <Button
                    Margin="0,0,6,0"
                    Command="{Binding NavigateProfileCommand}"
                    Visibility="{Binding IsProfileButtonVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <components:ProfilePictureControl
                            Width="28"
                            Height="28"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            ImagePath="{Binding CurrentUser.ProfilePicturePath}"
                            Gender="{Binding CurrentUser.Gender}" />
                        <TextBlock VerticalAlignment="Center" Text="{Binding CurrentUser.UserName}" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding LogoutCommand}"
                        Content="{Binding [Nav_Logout], Source={x:Static loc:TranslationSource.Instance}}" />
            </StackPanel>
        </Grid>

        <ContentControl Content="{Binding ActiveSubPage}" />
    </DockPanel>
</UserControl>