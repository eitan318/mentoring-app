<UserControl x:Class="MentoringApp.View.RegistrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:model="clr-namespace:MentoringApp.Model;assembly=MentoringApp.Model">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Username:"/>
            <TextBox Text="{Binding UserName}"/>
            <TextBlock Text="Email:"/>
            <TextBox Text="{Binding Email}"/>
            <TextBlock Text="National ID:"/>
            <TextBox Text="{Binding NationalId}"/>

            <StackPanel Visibility="{Binding SupervisorOrStudentIsSupervisor, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Supervisor data: no data"/>
            </StackPanel>

            <StackPanel Visibility="{Binding SupervisorOrStudentIsSupervisor, Converter={StaticResource InverseBoolToVis}}">
                <TextBlock Text="Grade:"/>
                <TextBox Text="{Binding Grade}"/>
                <CheckBox Content="Is Mentor" IsChecked="{Binding IsMentor}"/>
                <CheckBox Content="Is Mentee" IsChecked="{Binding IsMentee}"/>
            </StackPanel>

            <StackPanel Visibility="{Binding IsMentor, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Subject to Teach:"/>
                <TextBox Text="{Binding SubjectToTeach}"/>
            </StackPanel>

            <StackPanel Visibility="{Binding IsMentee, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Subject to Learn:"/>
                <TextBox Text="{Binding SubjectToLearn}"/>
            </StackPanel>

            <Button Content="Submit Registration" 
                    Command="{Binding RegisterCommand}" 
                    Margin="0,20,0,0" Height="30"/>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" Margin="0,5"/>
        </StackPanel>
    </Grid>
</UserControl>