<UserControl x:Class="MentoringApp.View.Admin.ManagePairViewModel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MentoringApp.View.Admin"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel>
            <Button Content="Create new pair" 
            Command="{Binding CreatePairCommand}" 
            Margin="5"/>

            <ListView Grid.Row="1" ItemsSource="{Binding PairList}" Margin="5">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5">
                            <TextBlock Text="Mentor: " FontWeight="Bold"/>
                            <TextBlock Text="{Binding Mentor.UserName}" Margin="0,0,10,0"/>

                            <TextBlock Text="Mentee: " FontWeight="Bold"/>
                            <TextBlock Text="{Binding Mentee.UserName}" Margin="0,0,10,0"/>

                            <Button Content="Separate" 
                            Command="{Binding DataContext.SeparateCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                            CommandParameter="{Binding}"
                            Padding="10,2"/>

                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>

    </Grid>
</UserControl>
