<UserControl
    x:Class="MentoringApp.View.Admin.ManagePairViewModel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MentoringApp.View.Admin"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <StackPanel>
            <Button
                Margin="5"
                Command="{Binding CreatePairCommand}"
                Content="Create new pair" />

            <ListView
                Grid.Row="1"
                Margin="5"
                ItemsSource="{Binding PairList}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5" Orientation="Horizontal">
                            <TextBlock FontWeight="Bold" Text="Mentor: " />
                            <TextBlock Margin="0,0,10,0" Text="{Binding Mentor.UserName}" />

                            <TextBlock FontWeight="Bold" Text="Mentee: " />
                            <TextBlock Margin="0,0,10,0" Text="{Binding Mentee.UserName}" />

                            <Button
                                Padding="10,2"
                                Command="{Binding DataContext.SeparateCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                CommandParameter="{Binding}"
                                Content="Separate" />

                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>

    </Grid>
</UserControl>
