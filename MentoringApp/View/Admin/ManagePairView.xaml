<UserControl
    x:Class="MentoringApp.View.Admin.ManagePairViewModel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="clr-namespace:MentoringApp.Model;assembly=MentoringApp.Model"
    xmlns:components="clr-namespace:MentoringApp.View.Components"
    xmlns:loc="clr-namespace:MentoringApp.Localization"
    d:DesignHeight="600" d:DesignWidth="800"
    mc:Ignorable="d"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Action bar (Create Pair) -->
            <RowDefinition Height="*"/>    <!-- Main split content -->
        </Grid.RowDefinitions>

        <!-- ── TOP BAR ──────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Command="{Binding CreatePairCommand}" Content="{Binding [Admin_ManagePair_Create], Source={x:Static loc:TranslationSource.Instance}}" Cursor="Hand" Padding="8,4"/>
        </StackPanel>

        <!-- ── MAIN SPLIT ─────────────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>  <!-- Pairs List -->
                <ColumnDefinition Width="2*"/>  <!-- Details Sidebar -->
            </Grid.ColumnDefinitions>

            <!-- LEFT: Search + Pairs List -->
            <Grid Grid.Column="0" Margin="0,0,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search bar -->
                <TextBox Grid.Row="0" Margin="0,0,0,8" Padding="4,3"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Tag="{Binding [Admin_ManagePair_SearchHint], Source={x:Static loc:TranslationSource.Instance}}"/>

                <!-- Pairs ListBox -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding FilteredPairs}"
                         SelectedItem="{Binding SelectedPair}"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type model:Pair}">
                            <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="10">
                                <StackPanel Orientation="Horizontal">
                                    <!-- Mentor -->
                                    <components:ProfilePictureControl Width="32" Height="32" Margin="0,0,6,0"
                                                                      VerticalAlignment="Center"
                                                                      ImagePath="{Binding Mentor.ProfilePicturePath}"
                                                                      Gender="{Binding Mentor.Gender}"/>
                                    <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="{Binding Mentor.UserName}" Margin="0,0,6,0"/>

                                    <TextBlock VerticalAlignment="Center" Text="→" Foreground="Gray" Margin="0,0,6,0"/>

                                    <!-- Mentee -->
                                    <components:ProfilePictureControl Width="32" Height="32" Margin="0,0,6,0"
                                                                      VerticalAlignment="Center"
                                                                      ImagePath="{Binding Mentee.ProfilePicturePath}"
                                                                      Gender="{Binding Mentee.Gender}"/>
                                    <TextBlock VerticalAlignment="Center" Text="{Binding Mentee.UserName}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- RIGHT: Details Sidebar -->
            <GroupBox Header="{Binding [Admin_ManagePair_DetailsHeader], Source={x:Static loc:TranslationSource.Instance}}" Grid.Column="1" Padding="10">
                <Grid>
                    <!-- Placeholder when nothing selected -->
                    <TextBlock Text="{Binding [Admin_ManagePair_SelectHint], Source={x:Static loc:TranslationSource.Instance}}"
                               Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPair}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Detail pane -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPair}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>

                        <StackPanel DataContext="{Binding SelectedPair}">
                            <!-- Mentor Card -->
                            <TextBlock Text="{Binding [Admin_ManagePair_Mentor], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="Bold" Margin="0,0,0,5"/>
                            <Border BorderBrush="#DDD" BorderThickness="1" Padding="10" Background="#FAFAFA" Margin="0,0,0,15">
                                <StackPanel Orientation="Horizontal">
                                    <components:ProfilePictureControl Width="50" Height="50" Margin="0,0,10,0"
                                                                      VerticalAlignment="Center"
                                                                      ImagePath="{Binding Mentor.ProfilePicturePath}"
                                                                      Gender="{Binding Mentor.Gender}"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Mentor.UserName}" FontWeight="Bold" FontSize="15"/>
                                        <TextBlock Text="{Binding Mentor.Email}" Foreground="Gray" FontSize="12"/>
                                        <TextBlock FontSize="12" Foreground="DarkGray">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource GradeClassDisplay}">
                                                    <Binding Path="Mentor.Grade.Name"/>
                                                    <Binding Path="Mentor.ClassNum"/>
                                                    <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Mentee Card -->
                            <TextBlock Text="{Binding [Admin_ManagePair_Mentee], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="Bold" Margin="0,0,0,5"/>
                            <Border BorderBrush="#DDD" BorderThickness="1" Padding="10" Background="#FAFAFA" Margin="0,0,0,20">
                                <StackPanel Orientation="Horizontal">
                                    <components:ProfilePictureControl Width="50" Height="50" Margin="0,0,10,0"
                                                                      VerticalAlignment="Center"
                                                                      ImagePath="{Binding Mentee.ProfilePicturePath}"
                                                                      Gender="{Binding Mentee.Gender}"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Mentee.UserName}" FontWeight="Bold" FontSize="15"/>
                                        <TextBlock Text="{Binding Mentee.Email}" Foreground="Gray" FontSize="12"/>
                                        <TextBlock FontSize="12" Foreground="DarkGray">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource GradeClassDisplay}">
                                                    <Binding Path="Mentee.Grade.Name"/>
                                                    <Binding Path="Mentee.ClassNum"/>
                                                    <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Separator Margin="0,0,0,10"/>

                            <!-- Summary Section -->
                            <StackPanel Margin="0,0,0,15">
                                <TextBlock Text="{Binding [Admin_ManagePair_RecentActivity], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBlock Foreground="#555" Margin="0,0,0,2">
                                    <Run Text="{Binding [Admin_ManagePair_TotalReviews], Source={x:Static loc:TranslationSource.Instance}, Mode=OneWay}"/>
                                    <Run Text="{Binding DataContext.SelectedPairReviewCount, RelativeSource={RelativeSource AncestorType=UserControl}}" FontWeight="Bold"/>
                                </TextBlock>
                                <TextBlock Foreground="#555">
                                    <Run Text="{Binding [Admin_ManagePair_ActiveIssues], Source={x:Static loc:TranslationSource.Instance}, Mode=OneWay}"/>
                                    <Run Text="{Binding DataContext.SelectedPairActiveIssueCount, RelativeSource={RelativeSource AncestorType=UserControl}}" FontWeight="Bold"/>
                                </TextBlock>
                            </StackPanel>

                            <Separator Margin="0,0,0,10"/>

                            <!-- Actions  -->
                            <TextBlock Text="{Binding [Admin_ManagePair_Actions], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <Button Content="{Binding [Admin_ManagePair_ViewDetails], Source={x:Static loc:TranslationSource.Instance}}"
                                    Command="{Binding DataContext.SelectPairCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Cursor="Hand"
                                    Margin="0,0,0,10" Padding="5,8"/>
                            <Button Content="{Binding [Admin_ManagePair_Separate], Source={x:Static loc:TranslationSource.Instance}}"
                                    Command="{Binding DataContext.SeparateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Background="#FFEDD4D4" Foreground="#8A1515" BorderBrush="#8A1515"
                                    Cursor="Hand"
                                    ToolTip="{Binding [ManagePairs_Separate_Tooltip], Source={x:Static loc:TranslationSource.Instance}}"
                                    Padding="5,8"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
