<UserControl
    x:Class="MentoringApp.View.Admin.ManagePairViewModel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MentoringApp.View.Admin"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:components="clr-namespace:MentoringApp.View.Components"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="PairListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />

            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnPairItemClick" />

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E0E0E0" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <StackPanel>
            <Button
                Margin="5"
                Command="{Binding CreatePairCommand}"
                Content="Create new pair" />

            <ListView
                Grid.Row="1"
                Margin="5"
                ItemsSource="{Binding PairList}"
                ItemContainerStyle="{StaticResource PairListViewItemStyle}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <DockPanel Margin="5" LastChildFill="True">
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <!--  Mentor mini avatar  -->
                                <components:ProfilePictureControl Width="32" Height="32" Margin="0,0,6,0" VerticalAlignment="Center" ImagePath="{Binding Mentor.ProfilePicturePath}" />
                                <TextBlock FontWeight="Bold" Text="Mentor: " />
                                <TextBlock Margin="0,0,12,0" Text="{Binding Mentor.UserName}" />

                                <!--  Mentee mini avatar  -->
                                <components:ProfilePictureControl Width="32" Height="32" Margin="0,0,6,0" VerticalAlignment="Center" ImagePath="{Binding Mentee.ProfilePicturePath}" />
                                <TextBlock FontWeight="Bold" Text="Mentee: " />
                                <TextBlock Margin="0,0,10,0" Text="{Binding Mentee.UserName}" />

                                <Button
                                    Padding="10,2"
                                    Command="{Binding DataContext.SeparateCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                    CommandParameter="{Binding}"
                                    Content="Separate" />

                            </StackPanel>
                        </DockPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>

    </Grid>
</UserControl>
