<UserControl
    x:Class="MentoringApp.View.Admin.CreatePairView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MentoringApp.View.Admin"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="Select Supervisor:" />
            <ComboBox
                Margin="0,0,0,10"
                DisplayMemberPath="UserName"
                ItemsSource="{Binding AvailableSupervisors}"
                SelectedItem="{Binding SelectedSupervisor}" />

            <TextBlock Text="Select Mentor:" />
            <ComboBox
                Margin="0,0,0,10"
                DisplayMemberPath="UserName"
                ItemsSource="{Binding AvailableMentors}"
                SelectedItem="{Binding SelectedMentor}" />

            <TextBlock Text="Select Mentee:" />
            <ComboBox
                Margin="0,0,0,10"
                DisplayMemberPath="UserName"
                ItemsSource="{Binding AvailableMentees}"
                SelectedItem="{Binding SelectedMentee}" />

            <Button
                Height="30"
                Margin="0,10,0,0"
                Command="{Binding CreatePairCommand}"
                Content="Create Pair" />
        </StackPanel>
    </Grid>
</UserControl>
