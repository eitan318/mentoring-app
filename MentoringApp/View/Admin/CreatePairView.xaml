<UserControl x:Class="MentoringApp.View.Admin.CreatePairView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:MentoringApp.Localization"
             mc:Ignorable="d" d:DesignHeight="400" d:DesignWidth="800"
             FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="10">
                <TextBlock Text="{Binding [Admin_CreatePair_SearchSupervisor], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="Bold"/>
                <TextBox Text="{Binding SupervisorSearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,5" />
                <ListBox Height="150" DisplayMemberPath="UserName"
                         ItemsSource="{Binding FilteredSupervisors}"
                         SelectedItem="{Binding SelectedSupervisor}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="10">
                <TextBlock Text="{Binding [Admin_CreatePair_SearchMentor], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="Bold"/>
                <TextBox Text="{Binding MentorSearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,5" />
                <ListBox Height="150" DisplayMemberPath="UserName"
                         ItemsSource="{Binding FilteredMentors}"
                         SelectedItem="{Binding SelectedMentor}" />
            </StackPanel>

            <StackPanel Grid.Column="2" Margin="10">
                <TextBlock Text="{Binding [Admin_CreatePair_SearchMentee], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="Bold"/>
                <TextBox Text="{Binding MenteeSearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,5" />
                <ListBox Height="150" DisplayMemberPath="UserName"
                         ItemsSource="{Binding FilteredMentees}"
                         SelectedItem="{Binding SelectedMentee}" />
            </StackPanel>
        </Grid>

        <Button Grid.Row="1"
                Content="{Binding [Admin_CreatePair_Button], Source={x:Static loc:TranslationSource.Instance}}"
                Command="{Binding CreatePairCommand}"
                Height="40"
                Width="200"
                Margin="0,20,0,0"
                HorizontalAlignment="Center"
                FontWeight="Bold"
                IsDefault="True"
                Cursor="Hand"
                ToolTip="Create a pair with the selected supervisor, mentor, and mentee"/>
    </Grid>
</UserControl>