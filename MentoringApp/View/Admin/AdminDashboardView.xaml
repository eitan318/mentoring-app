<UserControl
    x:Class="MentoringApp.View.Admin.AdminDashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MentoringApp.View.Admin"
    xmlns:loc="clr-namespace:MentoringApp.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Action buttons  -->
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,8"
            Orientation="Horizontal">
            <Button
                Margin="0,0,8,0"
                Padding="10,5"
                Command="{Binding ManagePairsCommand}"
                Content="{Binding [Admin_ManagePairs_Button], Source={x:Static loc:TranslationSource.Instance}}" />
            <Button
                Margin="0,0,8,0"
                Padding="10,5"
                Command="{Binding ManageUsersCommand}"
                Content="{Binding [Admin_ManageUsers_Button], Source={x:Static loc:TranslationSource.Instance}}" />
        </StackPanel>

        <!--  Status message  -->
        <TextBlock
            Grid.Row="1"
            Margin="0,0,0,12"
            FontWeight="Bold"
            Foreground="Green"
            Text="{Binding StatusMessage}" />

        <!--  Supervisors header row  -->
        <Grid Grid.Row="2" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                FontSize="12"
                FontWeight="Bold"
                Foreground="Gray"
                Text="{Binding [Admin_SupervisorHeader_Name], Source={x:Static loc:TranslationSource.Instance}}" />
            <TextBlock
                Grid.Column="1"
                FontSize="12"
                FontWeight="Bold"
                Foreground="Gray"
                Text="{Binding [Admin_SupervisorHeader_Pairs], Source={x:Static loc:TranslationSource.Instance}}" />
            <TextBlock
                Grid.Column="2"
                FontSize="12"
                FontWeight="Bold"
                Foreground="Gray"
                Text="{Binding [Admin_SupervisorHeader_Pending], Source={x:Static loc:TranslationSource.Instance}}" />
            <TextBlock
                Grid.Column="3"
                FontSize="12"
                FontWeight="Bold"
                Foreground="Gray"
                Text="{Binding [Admin_SupervisorHeader_Resolved], Source={x:Static loc:TranslationSource.Instance}}" />
        </Grid>

        <!--  Supervisors list  -->
        <ListView
            Grid.Row="3"
            BorderThickness="0,1,0,0"
            ItemsSource="{Binding SupervisorsListPreview}">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0,4" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="{Binding UserName}" />
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Text="{Binding SupervisedPairsCount}" />
                        <TextBlock
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Foreground="#CC3300"
                            Text="{Binding PendingIssues.Count}" />
                        <TextBlock
                            Grid.Column="3"
                            VerticalAlignment="Center"
                            Foreground="#227722"
                            Text="{Binding ResolvedIssues.Count}" />
                        <Button
                            Grid.Column="4"
                            Padding="8,3"
                            Command="{Binding DataContext.InspectSupervisorCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                            CommandParameter="{Binding}"
                            Content="{Binding [Admin_Inspect_Button], Source={x:Static loc:TranslationSource.Instance}}"
                            FontSize="11" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>