<UserControl
    x:Class="MentoringApp.View.Admin.AdminRegisterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MentoringApp.View.Admin"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <StackPanel>

            <Button Command="{Binding RegisterSupervisorCommand}" Content="Register Supervisor" />
            <Button Command="{Binding RegisterStudentCommand}" Content="Register Student" />
            <Button Command="{Binding RegisterFromFileCommand}" Content="Register from a File" />
        </StackPanel>
    </Grid>
</UserControl>
