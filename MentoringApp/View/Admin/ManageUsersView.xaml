<UserControl x:Class="MentoringApp.View.Admin.ManageUsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:model="clr-namespace:MentoringApp.Model.User;assembly=MentoringApp.Model"
             xmlns:components="clr-namespace:MentoringApp.View.Components"
             xmlns:loc="clr-namespace:MentoringApp.Localization"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="700"
             FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <!-- Root grid for layout and popups -->
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <!-- Add / Import Section -->
            <RowDefinition Height="Auto"/>
            <!-- Main Content: Search/List and Sidebar -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── SECTION 1: ADD & IMPORT USERS ─────────────────────────────── -->
        <GroupBox Header="{Binding [Admin_ManageUsers_AddImportHeader], Source={x:Static loc:TranslationSource.Instance}}" Grid.Row="0" Margin="0,0,0,15" Padding="10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Command="{Binding RegisterSupervisorCommand}" Content="{Binding [Admin_ManageUsers_AddSupervisor], Source={x:Static loc:TranslationSource.Instance}}" Margin="0,0,5,0" Padding="5,2"/>
                    <Button Command="{Binding RegisterStudentCommand}" Content="{Binding [Admin_ManageUsers_AddStudent], Source={x:Static loc:TranslationSource.Instance}}" Margin="0,0,5,0" Padding="5,2"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding [Admin_ManageUsers_BulkImport], Source={x:Static loc:TranslationSource.Instance}}" VerticalAlignment="Center" Margin="0,0,10,0"/>

                    <Button Command="{Binding ImportStudentsCommand}" Content="{Binding [Admin_ManageUsers_ImportStudents], Source={x:Static loc:TranslationSource.Instance}}" Margin="0,0,5,0" Padding="5,2"/>
                    <Button Command="{Binding ToggleStudentInfoCommand}" Content="{Binding [Admin_ManageUsers_Help], Source={x:Static loc:TranslationSource.Instance}}" Margin="0,0,15,0" Padding="5,2" ToolTip="{Binding [Admin_ManageUsers_ImportStudentsHelp], Source={x:Static loc:TranslationSource.Instance}}"/>

                    <Button Command="{Binding ImportSupervisorsCommand}" Content="{Binding [Admin_ManageUsers_ImportSupervisors], Source={x:Static loc:TranslationSource.Instance}}" Margin="0,0,5,0" Padding="5,2"/>
                    <Button Command="{Binding ToggleSupervisorInfoCommand}" Content="{Binding [Admin_ManageUsers_Help], Source={x:Static loc:TranslationSource.Instance}}" Margin="0,0,5,0" Padding="5,2" ToolTip="{Binding [Admin_ManageUsers_ImportSupervisorsHelp], Source={x:Static loc:TranslationSource.Instance}}"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- ── SECTION 2 & 3: MAIN SPLIT CONTENT ─────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/> <!-- List Box Area -->
                <ColumnDefinition Width="2*"/> <!-- Sidebar Area -->
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDE: Filter Bar + ListBox -->
            <Grid Grid.Column="0" Margin="0,0,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Filter Bar Row 1 -->
                    <RowDefinition Height="Auto"/>  <!-- Filter Bar Row 2 (student-specific) -->
                    <RowDefinition Height="*"/>     <!-- ListBox -->
                </Grid.RowDefinitions>

                <!-- Row 1: Search + Role Dropdown -->
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="4,3" Margin="0,0,8,0"
                             Tag="{Binding [Admin_ManageUsers_SearchHint], Source={x:Static loc:TranslationSource.Instance}}"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding RoleOptions}"
                              SelectedItem="{Binding SelectedRole}"
                              Width="110" Padding="4,2">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <!-- Map role options to static keys if you wish, or keep as is if RoleOptions are correctly localized strings -->
                                <TextBlock Text="{Binding}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <!-- Row 2: Student-specific filters — visibility driven by SelectedRole -->
                <Border Grid.Row="1" Margin="0,0,0,6" Padding="6,4"
                        BorderBrush="#CCC" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStudentFilterVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <StackPanel>
                        <!-- Profile checkboxes -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="{Binding [Admin_ManageUsers_Profile], Source={x:Static loc:TranslationSource.Instance}}" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,0"/>
                            <CheckBox Content="{Binding [Admin_ManageUsers_Mentor], Source={x:Static loc:TranslationSource.Instance}}"  IsChecked="{Binding FilterIsMentor}"  VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <CheckBox Content="{Binding [Admin_ManageUsers_Mentee], Source={x:Static loc:TranslationSource.Instance}}"  IsChecked="{Binding FilterIsMentee}"  VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <CheckBox Content="{Binding [Admin_ManageUsers_UnpairedOnly], Source={x:Static loc:TranslationSource.Instance}}" IsChecked="{Binding FilterUnpairedOnly}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Grade range -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding [Admin_ManageUsers_Grade], Source={x:Static loc:TranslationSource.Instance}}" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,0"/>
                            <ComboBox ItemsSource="{Binding AvailableGrades}"
                                      SelectedItem="{Binding FilterMinGrade}"
                                      Width="70" Padding="4,2" Margin="0,0,4,0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Grade_">
                                                    <Binding Path="." />
                                                    <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Text="{Binding [Admin_ManageUsers_To], Source={x:Static loc:TranslationSource.Instance}}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <ComboBox ItemsSource="{Binding AvailableGrades}"
                                      SelectedItem="{Binding FilterMaxGrade}"
                                      Width="70" Padding="4,2">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Grade_">
                                                    <Binding Path="." />
                                                    <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding FilteredUsers}"
                         SelectedItem="{Binding SelectedUser}"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type model:UserModel}">
                            <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <components:ProfilePictureControl Grid.Column="0"
                                        Width="40" Height="40" Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        ImagePath="{Binding ProfilePicturePath}"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding UserName}" FontWeight="Bold" FontSize="15"/>
                                        <TextBlock Text="{Binding Email}" Foreground="Gray" FontSize="12"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- RIGHT SIDE: Details Sidebar -->
            <GroupBox Header="{Binding [Admin_ManageUsers_DetailsHeader], Source={x:Static loc:TranslationSource.Instance}}" Grid.Column="1" Padding="10">
                <Grid>
                    <!-- Null State Placeholder -->
                    <TextBlock Text="{Binding [Admin_ManageUsers_SelectHint], Source={x:Static loc:TranslationSource.Instance}}"
                               Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedUser}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- User Detail Pane -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedUser}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>

                        <StackPanel DataContext="{Binding SelectedUser}">
                            <components:ProfilePictureControl Width="80" Height="80" Margin="0,0,0,10" 
                                                              ImagePath="{Binding ProfilePicturePath}" HorizontalAlignment="Center"/>
                            
                            <TextBlock Text="{Binding UserName}" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding Email}" FontSize="14" Foreground="DarkGray" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                            
                            <TextBlock Text="{Binding [Admin_ManageUsers_AccountInfo], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#333"/>
                            <Border BorderBrush="#DDD" BorderThickness="1" Padding="10" Background="#FAFAFA" Margin="0,0,0,15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Text="{Binding [Admin_ManageUsers_NationalId], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="Bold" Grid.Row="0" Grid.Column="0" Margin="0,0,10,5"/>
                                    <TextBlock Text="{Binding NationalId}" Grid.Row="0" Grid.Column="1" Margin="0,0,0,5"/>

                                </Grid>
                            </Border>

                            <Separator Margin="0,10"/>

                            <TextBlock Text="{Binding [Admin_ManageUsers_Actions], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <!-- Commands are in ManageUsersViewModel, so we need RelativeSource bonding -->
                            <Button Content="{Binding [Admin_ManageUsers_FullProfile], Source={x:Static loc:TranslationSource.Instance}}" 
                                    Command="{Binding DataContext.ViewUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                    Margin="0,0,0,10" Padding="5,8"/>
                                    
                            <Button Content="{Binding [Admin_ManageUsers_DeleteUser], Source={x:Static loc:TranslationSource.Instance}}" 
                                    Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                    Background="#FFEDD4D4" Foreground="#8A1515" BorderBrush="#8A1515" 
                                    Margin="0,0,0,5" Padding="5,8"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- ══ STUDENT IMPORT INFO POPUP (Remains absolute over everything) ════ -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="White" BorderBrush="Black" BorderThickness="1"
                Visibility="{Binding IsStudentInfoVisible, Converter={StaticResource BoolToVis}}"
                HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20">
            <StackPanel>
                <TextBlock Text="{Binding [Admin_ManageUsers_StudentInstructions], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding [Admin_ManageUsers_ExcelFormat], Source={x:Static loc:TranslationSource.Instance}}" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding [Admin_ManageUsers_ColANationalId], Source={x:Static loc:TranslationSource.Instance}}" />
                <TextBlock Text="{Binding [Admin_ManageUsers_ColBEmail], Source={x:Static loc:TranslationSource.Instance}}" />
                <TextBlock Text="{Binding [Admin_ManageUsers_ColCUserName], Source={x:Static loc:TranslationSource.Instance}}" Margin="0,0,0,15"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding DownloadStudentTemplateCommand}" Content="{Binding [Admin_ManageUsers_DownloadTemplate], Source={x:Static loc:TranslationSource.Instance}}" Margin="0,0,5,0" Padding="5,2"/>
                    <Button Command="{Binding CloseStudentInfoCommand}" Content="{Binding [Admin_ManageUsers_Close], Source={x:Static loc:TranslationSource.Instance}}" Padding="5,2"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══ SUPERVISOR IMPORT INFO POPUP (Remains absolute over everything) ════ -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="White" BorderBrush="Black" BorderThickness="1"
                Visibility="{Binding IsSupervisorInfoVisible, Converter={StaticResource BoolToVis}}"
                HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20">
            <StackPanel>
                <TextBlock Text="{Binding [Admin_ManageUsers_SupervisorInstructions], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding [Admin_ManageUsers_ExcelFormat], Source={x:Static loc:TranslationSource.Instance}}" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding [Admin_ManageUsers_ColANationalId], Source={x:Static loc:TranslationSource.Instance}}" />
                <TextBlock Text="{Binding [Admin_ManageUsers_ColBEmail], Source={x:Static loc:TranslationSource.Instance}}" />
                <TextBlock Text="{Binding [Admin_ManageUsers_ColCUserName], Source={x:Static loc:TranslationSource.Instance}}" Margin="0,0,0,15"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding DownloadSupervisorTemplateCommand}" Content="{Binding [Admin_ManageUsers_DownloadTemplate], Source={x:Static loc:TranslationSource.Instance}}" Margin="0,0,5,0" Padding="5,2"/>
                    <Button Command="{Binding CloseSupervisorInfoCommand}" Content="{Binding [Admin_ManageUsers_Close], Source={x:Static loc:TranslationSource.Instance}}" Padding="5,2"/>
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>