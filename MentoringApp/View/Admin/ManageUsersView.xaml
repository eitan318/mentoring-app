<UserControl x:Class="MentoringApp.View.Admin.ManageUsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:model="clr-namespace:MentoringApp.Model.User;assembly=MentoringApp.Model"
             xmlns:components="clr-namespace:MentoringApp.View.Components"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="700">

    <!-- Root grid for layout and popups -->
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <!-- Add / Import Section -->
            <RowDefinition Height="Auto"/>
            <!-- Main Content: Search/List and Sidebar -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── SECTION 1: ADD & IMPORT USERS ─────────────────────────────── -->
        <GroupBox Header="Add &amp; Import Users" Grid.Row="0" Margin="0,0,0,15" Padding="10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Command="{Binding RegisterSupervisorCommand}" Content="Add Supervisor" Margin="0,0,5,0" Padding="5,2"/>
                    <Button Command="{Binding RegisterStudentCommand}" Content="Add Student" Margin="0,0,5,0" Padding="5,2"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Bulk Import:" VerticalAlignment="Center" Margin="0,0,10,0"/>

                    <Button Command="{Binding ImportStudentsCommand}" Content="Import Students Excel" Margin="0,0,5,0" Padding="5,2"/>
                    <Button Command="{Binding ToggleStudentInfoCommand}" Content="?" Margin="0,0,15,0" Padding="5,2" ToolTip="Import instructions for students"/>

                    <Button Command="{Binding ImportSupervisorsCommand}" Content="Import Supervisors Excel" Margin="0,0,5,0" Padding="5,2"/>
                    <Button Command="{Binding ToggleSupervisorInfoCommand}" Content="?" Margin="0,0,5,0" Padding="5,2" ToolTip="Import instructions for supervisors"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- ── SECTION 2 & 3: MAIN SPLIT CONTENT ─────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/> <!-- List Box Area -->
                <ColumnDefinition Width="2*"/> <!-- Sidebar Area -->
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDE: Filter Bar + ListBox -->
            <Grid Grid.Column="0" Margin="0,0,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Filter Bar Row 1 -->
                    <RowDefinition Height="Auto"/>  <!-- Filter Bar Row 2 (student-specific) -->
                    <RowDefinition Height="*"/>     <!-- ListBox -->
                </Grid.RowDefinitions>

                <!-- Row 1: Search + Role Dropdown -->
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="4,3" Margin="0,0,8,0"
                             Tag="Search by Name / Email"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding RoleOptions}"
                              SelectedItem="{Binding SelectedRole}"
                              Width="110" Padding="4,2"/>
                </Grid>

                <!-- Row 2: Student-specific filters — visibility driven by SelectedRole -->
                <Border Grid.Row="1" Margin="0,0,0,6" Padding="6,4"
                        BorderBrush="#CCC" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStudentFilterVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <StackPanel>
                        <!-- Profile checkboxes -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="Profile:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,0"/>
                            <CheckBox Content="Mentor"  IsChecked="{Binding FilterIsMentor}"  VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <CheckBox Content="Mentee"  IsChecked="{Binding FilterIsMentee}"  VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <CheckBox Content="Unpaired Only" IsChecked="{Binding FilterUnpairedOnly}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Grade range -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Grade:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,0"/>
                            <ComboBox ItemsSource="{Binding AvailableGrades}"
                                      SelectedItem="{Binding FilterMinGrade}"
                                      Width="70" Padding="4,2" Margin="0,0,4,0"/>
                            <TextBlock Text="to" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <ComboBox ItemsSource="{Binding AvailableGrades}"
                                      SelectedItem="{Binding FilterMaxGrade}"
                                      Width="70" Padding="4,2"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding FilteredUsers}"
                         SelectedItem="{Binding SelectedUser}"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type model:UserModel}">
                            <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <components:ProfilePictureControl Grid.Column="0"
                                        Width="40" Height="40" Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        ImagePath="{Binding ProfilePicturePath}"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding UserName}" FontWeight="Bold" FontSize="15"/>
                                        <TextBlock Text="{Binding Email}" Foreground="Gray" FontSize="12"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- RIGHT SIDE: Details Sidebar -->
            <GroupBox Header="Selected User Details" Grid.Column="1" Padding="10">
                <Grid>
                    <!-- Null State Placeholder -->
                    <TextBlock Text="Select a user from the list to view details."
                               Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedUser}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- User Detail Pane -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedUser}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>

                        <StackPanel DataContext="{Binding SelectedUser}">
                            <components:ProfilePictureControl Width="80" Height="80" Margin="0,0,0,10" 
                                                              ImagePath="{Binding ProfilePicturePath}" HorizontalAlignment="Center"/>
                            
                            <TextBlock Text="{Binding UserName}" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding Email}" FontSize="14" Foreground="DarkGray" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                            
                            <TextBlock Text="Account Information" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#333"/>
                            <Border BorderBrush="#DDD" BorderThickness="1" Padding="10" Background="#FAFAFA" Margin="0,0,0,15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Text="National ID:" FontWeight="Bold" Grid.Row="0" Grid.Column="0" Margin="0,0,10,5"/>
                                    <TextBlock Text="{Binding NationalId}" Grid.Row="0" Grid.Column="1" Margin="0,0,0,5"/>

                                </Grid>
                            </Border>

                            <Separator Margin="0,10"/>

                            <TextBlock Text="Actions" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <!-- Commands are in ManageUsersViewModel, so we need RelativeSource bonding -->
                            <Button Content="Go to Full Profile" 
                                    Command="{Binding DataContext.ViewUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                    Margin="0,0,0,10" Padding="5,8"/>
                                    
                            <Button Content="Delete User" 
                                    Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                    Background="#FFEDD4D4" Foreground="#8A1515" BorderBrush="#8A1515" 
                                    Margin="0,0,0,5" Padding="5,8"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- ══ STUDENT IMPORT INFO POPUP (Remains absolute over everything) ════ -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="White" BorderBrush="Black" BorderThickness="1"
                Visibility="{Binding IsStudentInfoVisible, Converter={StaticResource BoolToVis}}"
                HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20">
            <StackPanel>
                <TextBlock Text="Import Students Instructions" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="Excel Format: Row 1 is header (skipped)." Margin="0,0,0,5"/>
                <TextBlock Text="Column A: NationalId" />
                <TextBlock Text="Column B: Email" />
                <TextBlock Text="Column C: UserName" Margin="0,0,0,15"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding DownloadStudentTemplateCommand}" Content="Download Template" Margin="0,0,5,0" Padding="5,2"/>
                    <Button Command="{Binding CloseStudentInfoCommand}" Content="Close" Padding="5,2"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══ SUPERVISOR IMPORT INFO POPUP (Remains absolute over everything) ════ -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="White" BorderBrush="Black" BorderThickness="1"
                Visibility="{Binding IsSupervisorInfoVisible, Converter={StaticResource BoolToVis}}"
                HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20">
            <StackPanel>
                <TextBlock Text="Import Supervisors Instructions" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="Excel Format: Row 1 is header (skipped)." Margin="0,0,0,5"/>
                <TextBlock Text="Column A: NationalId" />
                <TextBlock Text="Column B: Email" />
                <TextBlock Text="Column C: UserName" Margin="0,0,0,15"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding DownloadSupervisorTemplateCommand}" Content="Download Template" Margin="0,0,5,0" Padding="5,2"/>
                    <Button Command="{Binding CloseSupervisorInfoCommand}" Content="Close" Padding="5,2"/>
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>