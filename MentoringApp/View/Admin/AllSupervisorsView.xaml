<UserControl
    x:Class="MentoringApp.View.Admin.AllSupervisorsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MentoringApp.View.Admin"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <StackPanel>
            <ListView ItemsSource="{Binding SupervisorsList}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5" Orientation="Horizontal">
                            <TextBlock FontWeight="Bold" Text="Name: " />
                            <TextBlock Margin="0,0,10,0" Text="{Binding Supervisor.UserName}" />

                            <TextBlock Text="Pairs supervised: " />
                            <TextBlock Margin="0,0,10,0" Text="{Binding PairsCount}" />

                            <TextBlock Foreground="Red" Text="Pending: " />
                            <TextBlock Margin="0,0,10,0" Text="{Binding PendingIssuesCount}" />

                            <Button
                                Margin="10,0,0,0"
                                Command="{Binding DataContext.InspectSupervisorCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                CommandParameter="{Binding}"
                                Content="Inspect More" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
    </Grid>
</UserControl>
