<UserControl x:Class="MentoringApp.View.Student.StudentHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:studentvm="clr-namespace:MentoringApp.ViewModel.ViewModelPage.Student;assembly=MentoringApp.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="400">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <Button Content="Logout" Command="{Binding LogoutCommand}"/>
            <ListBox Grid.Row="0" 
                 ItemsSource="{Binding Pairs}" 
                 SelectedItem="{Binding SelectedPair}"
                 Background="Transparent" 
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"> 
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5" Width="80">
                            <Ellipse Width="40" Height="40" Fill="#DDD"/>
                            <TextBlock Text="{Binding Counterpart.Name}" 
                           TextAlignment="Center" 
                           FontSize="10" 
                           TextWrapping="NoWrap" 
                           TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </StackPanel>
        

        <Border Grid.Row="1" 
                CornerRadius="8" 
                BorderBrush="#CCC" 
                BorderThickness="1" 
                Margin="0,15,0,0" 
                Padding="15">

            <ContentControl Content="{Binding SelectedPair}">
                <ContentControl.Resources>

                    <DataTemplate DataType="{x:Type studentvm:MentorDashboardViewModel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Counterpart.UserName}" FontSize="18" FontWeight="Bold"/>
                                <Border Background="#E1F5FE" CornerRadius="4" Margin="10,0" Padding="6,2">
                                    <TextBlock Text="{Binding CounterpartRole}" FontSize="9" Foreground="#0288D1" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>

                            <ProgressBar Grid.Row="1" Value="{Binding MenteeProgress}" Height="8" Margin="0,15"/>

                            <ListView Grid.Row="2" ItemsSource="{Binding MyIssues}" BorderThickness="0" Background="Transparent">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Description}" Padding="4"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <Button Grid.Row="3" Content="+ Add Issue" 
                                    Command="{Binding AddIssueCommand}" 
                                    HorizontalAlignment="Right" Padding="10,5" Margin="0,10,0,0"/>
                        </Grid>
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type studentvm:MenteeDashboardViewModel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding Counterpart.UserName}" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="{Binding CounterpartRole}" Foreground="Gray" FontSize="12"/>

                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Border>
    </Grid>
</UserControl>