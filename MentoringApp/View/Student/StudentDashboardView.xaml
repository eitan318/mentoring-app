<UserControl
    x:Class="MentoringApp.View.Student.StudentHomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:MentoringApp.View.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:loc="clr-namespace:MentoringApp.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:studentvm="clr-namespace:MentoringApp.ViewModel.ViewModelPage.Student;assembly=MentoringApp.ViewModel"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Tab strip — visible whenever there is at least one tab -->
        <ListBox
            Grid.Row="0"
            ItemsSource="{Binding Pairs}"
            SelectedItem="{Binding SelectedPair}"
            Visibility="{Binding HasNoPairs, Converter={StaticResource InverseBoolToVis}}">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <ContentControl Content="{Binding}">
                        <ContentControl.Resources>
                            <!-- Real pair tabs: show avatar + counterpart name -->
                            <DataTemplate DataType="{x:Type studentvm:MentorDashboardViewModel}">
                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <components:ProfilePictureControl
                                        Width="28" Height="28" Margin="0,0,6,0"
                                        ImagePath="{Binding Counterpart.ProfilePicturePath}" />
                                    <TextBlock VerticalAlignment="Center" FontSize="13"
                                               Text="{Binding Counterpart.Name}" />
                                </StackPanel>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type studentvm:MenteeDashboardViewModel}">
                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <components:ProfilePictureControl
                                        Width="28" Height="28" Margin="0,0,6,0"
                                        ImagePath="{Binding Counterpart.ProfilePicturePath}" />
                                    <TextBlock VerticalAlignment="Center" FontSize="13"
                                               Text="{Binding Counterpart.Name}" />
                                </StackPanel>
                            </DataTemplate>
                            <!-- Phase tabs: plain label -->
                            <DataTemplate DataType="{x:Type studentvm:BrowseMentorsViewModel}">
                                <TextBlock Margin="8,6" FontSize="13" Text="{Binding TabLabel}" />
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type studentvm:SelectionGalleryViewModel}">
                                <TextBlock Margin="8,6" FontSize="13" Text="{Binding TabLabel}" />
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type studentvm:MentorRequestsViewModel}">
                                <TextBlock Margin="8,6" FontSize="13" Text="{Binding TabLabel}" />
                            </DataTemplate>
                        </ContentControl.Resources>
                    </ContentControl>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Content area — dispatches by concrete VM type -->
        <ContentControl
            Grid.Row="1"
            Margin="10"
            Content="{Binding SelectedPair}"
            Visibility="{Binding HasNoPairs, Converter={StaticResource InverseBoolToVis}}">
            <ContentControl.Resources>

                <!-- ── Mentor dashboard (you are mentoring a mentee) ── -->
                <DataTemplate DataType="{x:Type studentvm:MentorDashboardViewModel}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock FontSize="18" FontWeight="Bold">
                                <Hyperlink Command="{Binding NavigateToProfileCommand}"
                                           Foreground="#0066CC" TextDecorations="Underline">
                                    <Run Text="{Binding Counterpart.UserName}" />
                                </Hyperlink>
                            </TextBlock>
                            <TextBlock Foreground="Gray"
                                       Text="{Binding [Student_YourMentee_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                            <DockPanel Margin="0,8,0,2">
                                <TextBlock DockPanel.Dock="Left" FontSize="12" Foreground="#555"
                                           Text="{Binding [Student_MeetingHours_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                                <TextBlock DockPanel.Dock="Right" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right">
                                    <Run Text="{Binding TotalMeetingHours, StringFormat='{}{0:0.#}'}" />
                                    <Run Text=" / " />
                                    <Run Text="{Binding RequiredMeetingHours, StringFormat='{}{0:0} hrs'}" />
                                </TextBlock>
                            </DockPanel>
                            <ProgressBar Height="10" Margin="0,0,0,4" Minimum="0" Maximum="100"
                                         Value="{Binding HoursProgress}" />
                        </StackPanel>

                        <UniformGrid DockPanel.Dock="Bottom" Columns="2" Margin="0,8,0,0">
                            <Button Margin="0,0,4,0" Command="{Binding CreateReviewCommand}"
                                    Content="{Binding [Student_WriteReview_Button], Source={x:Static loc:TranslationSource.Instance}}" />
                            <Button Margin="4,0,0,0" Command="{Binding IssueToSupervisorCommand}"
                                    Content="{Binding [Student_ReportIssue_Button], Source={x:Static loc:TranslationSource.Instance}}" />
                        </UniformGrid>

                        <ScrollViewer>
                            <StackPanel>
                                <TextBlock Margin="0,10,0,4" FontWeight="Bold" Foreground="#333"
                                           Text="{Binding [Student_RecentReviews_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                                <ItemsControl ItemsSource="{Binding RecentReviews}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="4,6" BorderBrush="#DDD" BorderThickness="0,0,0,1">
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock DockPanel.Dock="Left" Text="{Binding Content}" TextWrapping="Wrap" />
                                                        <TextBlock DockPanel.Dock="Right" FontSize="11" Foreground="#2E7D32" HorizontalAlignment="Right"
                                                                   Text="{Binding AmountOfHours, StringFormat='{}{0:0.#} hrs'}" />
                                                    </DockPanel>
                                                    <TextBlock Margin="0,2,0,0" FontSize="11" Foreground="#999"
                                                               Text="{Binding Date, StringFormat='{}{0:MMM d, yyyy}'}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </DataTemplate>

                <!-- ── Mentee dashboard (you are being mentored) ── -->
                <DataTemplate DataType="{x:Type studentvm:MenteeDashboardViewModel}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock FontSize="18" FontWeight="Bold">
                                <Hyperlink Command="{Binding NavigateToProfileCommand}"
                                           Foreground="#0066CC" TextDecorations="Underline">
                                    <Run Text="{Binding Counterpart.UserName}" />
                                </Hyperlink>
                            </TextBlock>
                            <TextBlock Foreground="#2E7D32" FontWeight="SemiBold"
                                       Text="{Binding MentorSubject, StringFormat='Expert in: {0}'}" />
                            <DockPanel Margin="0,8,0,2">
                                <TextBlock DockPanel.Dock="Left" FontSize="12" Foreground="#555"
                                           Text="{Binding [Student_MeetingHours_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                                <TextBlock DockPanel.Dock="Right" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right">
                                    <Run Text="{Binding TotalMeetingHours, StringFormat='{}{0:0.#}'}" />
                                    <Run Text=" / " />
                                    <Run Text="{Binding RequiredMeetingHours, StringFormat='{}{0:0} hrs'}" />
                                </TextBlock>
                            </DockPanel>
                            <ProgressBar Height="10" Margin="0,0,0,4" Minimum="0" Maximum="100"
                                         Value="{Binding HoursProgress}" />
                        </StackPanel>

                        <Button DockPanel.Dock="Bottom" Margin="0,8,0,0"
                                Command="{Binding IssueToSupervisorCommand}"
                                Content="{Binding [Student_RaiseIssue_Button], Source={x:Static loc:TranslationSource.Instance}}" />

                        <ScrollViewer>
                            <StackPanel>
                                <TextBlock Margin="0,10,0,4" FontWeight="Bold" Foreground="#333"
                                           Text="{Binding [Student_MentorFeedback_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                                <ItemsControl ItemsSource="{Binding RecentReviews}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="4,6" BorderBrush="#DDD" BorderThickness="0,0,0,1">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,2,0,0" FontSize="11" Foreground="#999"
                                                               Text="{Binding Date, StringFormat='{}{0:MMM d, yyyy}'}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Margin="0,14,0,4" FontWeight="Bold" Foreground="#333"
                                           Text="{Binding [Student_MyIssues_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                                <ItemsControl ItemsSource="{Binding MyIssues}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="4,5" BorderBrush="#DDD" BorderThickness="0,0,0,1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Width="8" Height="8" Margin="0,3,8,0"
                                                               VerticalAlignment="Top" Foreground="#E53935" Text="●" />
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" />
                                                        <TextBlock FontSize="11" Foreground="#999">
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Category_">
                                                                    <Binding Path="Category.Name" />
                                                                    <Binding Path="CurrentCulture" Source="{x:Static loc:TranslationSource.Instance}" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </DataTemplate>

                <!-- ── Phase 1 mentee tab: browse mentors ── -->
                <DataTemplate DataType="{x:Type studentvm:BrowseMentorsViewModel}">
                    <DockPanel Margin="4">
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock FontSize="13" FontWeight="Bold" Text="Available mentors" />
                            <TextBlock FontSize="11" Foreground="Gray" Margin="0,2,0,0"
                                       Text="Send a request to a mentor you would like to be paired with." />
                        </StackPanel>

                        <Border DockPanel.Dock="Top" Margin="0,0,0,8"
                                Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding StatusMessage}" FontSize="12" TextWrapping="Wrap" />
                        </Border>

                        <TextBlock DockPanel.Dock="Top" FontSize="12" Foreground="Gray" Margin="0,0,0,8"
                                   Text="Loading…"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding Mentors}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,6" BorderBrush="#DDD" BorderThickness="0,0,0,1">
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right"
                                                        Content="Send Request"
                                                        Command="{Binding DataContext.SendRequestCommand,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" />
                                                <StackPanel Margin="0,0,8,0">
                                                    <TextBlock FontSize="13" Text="{Binding MentorName}" />
                                                    <TextBlock FontSize="11" Foreground="Gray">
                                                        <Run Text="{Binding SubjectName}" />
                                                        <Run Text="·" />
                                                        <Run Text="{Binding GradeName}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </DataTemplate>

                <!-- ── Phase 2 mentee tab: top ranked recommendations ── -->
                <DataTemplate DataType="{x:Type studentvm:SelectionGalleryViewModel}">
                    <DockPanel Margin="4">
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock FontSize="13" FontWeight="Bold" Text="Recommended mentors" />
                            <TextBlock FontSize="11" Foreground="Gray" Margin="0,2,0,0"
                                       Text="Your top matches ranked by compatibility. Choose one to confirm pairing." />
                        </StackPanel>

                        <Border DockPanel.Dock="Top" Margin="0,0,0,6"
                                Visibility="{Binding AlreadyMatched, Converter={StaticResource BoolToVis}}">
                            <TextBlock FontSize="12" Text="You are already matched. Check your dashboard." />
                        </Border>

                        <Border DockPanel.Dock="Top" Margin="0,0,0,8"
                                Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding StatusMessage}" FontSize="12" TextWrapping="Wrap" />
                        </Border>

                        <TextBlock DockPanel.Dock="Top" FontSize="12" Foreground="Gray" Margin="0,0,0,8"
                                   Text="Loading…"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

                        <TextBlock DockPanel.Dock="Bottom" FontSize="11" Foreground="Gray" Margin="0,8,0,0"
                                   Text="If accepted by the mentor, pairing is confirmed automatically."
                                   TextWrapping="Wrap" />

                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding Recommendations}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,6" BorderBrush="#DDD" BorderThickness="0,0,0,1">
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right"
                                                        Content="Choose"
                                                        IsEnabled="{Binding DataContext.AlreadyMatched,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl},
                                                            Converter={StaticResource InverseBoolToVis}}"
                                                        Command="{Binding DataContext.ChooseMentorCommand,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" />
                                                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center"
                                                           Margin="0,0,10,0" FontSize="12" Foreground="Gray"
                                                           Text="{Binding ScorePercent, StringFormat='{}{0:0}%'}" />
                                                <StackPanel Margin="0,0,8,0">
                                                    <TextBlock FontSize="13" Text="{Binding MentorName}" />
                                                    <TextBlock FontSize="11" Foreground="Gray"
                                                               Text="{Binding MentorSubjectName}" />
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </DataTemplate>

                <!-- ── Phase 2 mentor tab: accept / decline incoming requests ── -->
                <DataTemplate DataType="{x:Type studentvm:MentorRequestsViewModel}">
                    <DockPanel Margin="4">
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock FontSize="13" FontWeight="Bold" Text="Incoming mentee requests" />
                            <TextBlock FontSize="11" Foreground="Gray" Margin="0,2,0,0"
                                       Text="Students who have requested you as their mentor." />
                            <TextBlock FontSize="11" Foreground="Gray" Margin="0,2,0,0"
                                       Text="{Binding RequestWindowTimerDisplay}" />
                        </StackPanel>

                        <Border DockPanel.Dock="Top" Margin="0,0,0,8"
                                Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding StatusMessage}" FontSize="12" TextWrapping="Wrap" />
                        </Border>

                        <TextBlock DockPanel.Dock="Top" FontSize="12" Foreground="Gray" Margin="0,0,0,8"
                                   Text="Loading…"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

                        <TextBlock DockPanel.Dock="Bottom" FontSize="11" Foreground="Gray" Margin="0,8,0,0"
                                   Text="Accepting a request will create an active pair."
                                   TextWrapping="Wrap" />

                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding PendingRequests}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,6" BorderBrush="#DDD" BorderThickness="0,0,0,1">
                                            <DockPanel>
                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                    <Button Margin="0,0,6,0" Content="Accept"
                                                            Command="{Binding DataContext.AcceptRequestCommand,
                                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Content="Decline"
                                                            Command="{Binding DataContext.RejectRequestCommand,
                                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                                <StackPanel Margin="0,0,8,0">
                                                    <TextBlock FontSize="13" Text="{Binding MenteeName}" />
                                                    <TextBlock FontSize="11" Foreground="Gray"
                                                               Text="{Binding MenteeSubjectName}" />
                                                    <TextBlock FontSize="11" Foreground="Gray"
                                                               Text="{Binding CreatedAt, StringFormat='Requested: {0:d}'}" />
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </DataTemplate>

            </ContentControl.Resources>
        </ContentControl>

        <!-- Empty state: only shown when Pairs is empty AND no tabs were added
             (i.e. matched student with no active pair yet — edge case) -->
        <StackPanel
            Grid.Row="1"
            MaxWidth="380"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="{Binding HasNoPairs, Converter={StaticResource BoolToVis}}">
            <TextBlock HorizontalAlignment="Center" FontSize="48" Foreground="#CCCCCC" Text="👤" />
            <TextBlock Margin="0,12,0,6" HorizontalAlignment="Center"
                       FontSize="20" FontWeight="SemiBold" Foreground="#888"
                       Text="{Binding [Student_NoAssignment_Title], Source={x:Static loc:TranslationSource.Instance}}" />
            <TextBlock Margin="0,0,0,20" HorizontalAlignment="Center"
                       FontSize="14" Foreground="#AAA" TextWrapping="Wrap" TextAlignment="Center"
                       Text="{Binding [Student_NoAssignment_Hint], Source={x:Static loc:TranslationSource.Instance}}" />

            <!-- Phase banner still shown in empty state -->
            <Border Margin="0,0,0,0" Padding="16,12"
                    Background="{Binding BannerColor}" BorderThickness="0" CornerRadius="8"
                    Visibility="{Binding IsPhaseBannerVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock FontSize="15" FontWeight="Bold"
                                   Foreground="{Binding BannerTextColor}" Text="{Binding BannerTitle}" />
                        <Button Margin="6,0,0,0" Background="Transparent" BorderThickness="0"
                                Command="{Binding ShowPhaseInfoCommand}" Content="🛈"
                                Cursor="Hand" FontSize="14" Foreground="{Binding BannerTextColor}"
                                ToolTip="Show Phase Information" />
                    </StackPanel>
                    <TextBlock Margin="0,0,0,4" FontSize="12" Opacity="0.9"
                               Foreground="{Binding BannerTextColor}" Text="{Binding BannerSubtitle}"
                               TextWrapping="Wrap" />
                    <TextBlock FontSize="13" FontWeight="SemiBold"
                               Foreground="{Binding BannerTextColor}" Text="{Binding BannerTimer}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>