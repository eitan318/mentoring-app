<UserControl
    x:Class="MentoringApp.View.Student.StudentHomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:studentvm="clr-namespace:MentoringApp.ViewModel.ViewModelPage.Student;assembly=MentoringApp.ViewModel"
    xmlns:components="clr-namespace:MentoringApp.View.Components"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Pair selector tabs (hidden when no pairs) -->
        <ListBox Grid.Row="0" ItemsSource="{Binding Pairs}" SelectedItem="{Binding SelectedPair}"
                 Visibility="{Binding HasNoPairs, Converter={StaticResource InverseBoolToVis}}">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="5" Orientation="Horizontal">
                        <components:ProfilePictureControl Width="36" Height="36" Margin="0,0,8,0" ImagePath="{Binding Counterpart.ProfilePicturePath}" />
                        <TextBlock VerticalAlignment="Center" FontSize="13" Text="{Binding Counterpart.Name}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Dashboard panel (hidden when no pairs) -->
        <ContentControl Grid.Row="1" Content="{Binding SelectedPair}" Margin="10"
                        Visibility="{Binding HasNoPairs, Converter={StaticResource InverseBoolToVis}}">
            <ContentControl.Resources>

                <!-- Mentor view: you are mentoring a mentee -->
                <DataTemplate DataType="{x:Type studentvm:MentorDashboardViewModel}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock FontSize="18" FontWeight="Bold">
                                <Hyperlink Command="{Binding NavigateToProfileCommand}" Foreground="#0066CC" TextDecorations="Underline">
                                    <Run Text="{Binding Counterpart.UserName}" />
                                </Hyperlink>
                            </TextBlock>
                            <TextBlock Foreground="Gray" Text="Your Mentee" />
                            <TextBlock
                                Margin="0,8,0,2"
                                Foreground="#555"
                                Text="{Binding MenteeProgress, StringFormat='Progress: {0:0}%'}" />
                            <ProgressBar Height="12" Maximum="100" Value="{Binding MenteeProgress}" />
                        </StackPanel>

                        <UniformGrid DockPanel.Dock="Bottom" Columns="2" Margin="0,8,0,0">
                            <Button Command="{Binding CreateReviewCommand}" Content="Write Meeting Review" Margin="0,0,4,0" Background="LightBlue" />
                            <Button Command="{Binding IssueToSupervisorCommand}" Content="Report Issue" Margin="4,0,0,0" />
                        </UniformGrid>

                        <ScrollViewer>
                            <StackPanel>
                                <TextBlock Margin="0,10,0,4" FontWeight="Bold" Foreground="#333" Text="Recent Meeting Reviews" />
                                <ItemsControl ItemsSource="{Binding RecentReviews}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="4,6">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" />
                                                    <TextBlock
                                                        Margin="0,2,0,0"
                                                        FontSize="11"
                                                        Foreground="#999"
                                                        Text="{Binding Date, StringFormat='{}{0:MMM d, yyyy}'}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </DataTemplate>

                <!-- Mentee view: you are being mentored -->
                <DataTemplate DataType="{x:Type studentvm:MenteeDashboardViewModel}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock FontSize="18" FontWeight="Bold">
                                <Hyperlink Command="{Binding NavigateToProfileCommand}" Foreground="#0066CC" TextDecorations="Underline">
                                    <Run Text="{Binding Counterpart.UserName}" />
                                </Hyperlink>
                            </TextBlock>
                            <TextBlock Foreground="#2E7D32" FontWeight="SemiBold"
                                       Text="{Binding MentorSubject, StringFormat='Expert in: {0}'}" />
                        </StackPanel>

                        <Button DockPanel.Dock="Bottom" Margin="0,8,0,0"
                                Command="{Binding IssueToSupervisorCommand}"
                                Content="Raise Issue to Supervisor" />

                        <ScrollViewer>
                            <StackPanel>
                                <TextBlock Margin="0,10,0,4" FontWeight="Bold" Foreground="#333" Text="Mentor's Meeting Feedback" />
                                <ItemsControl ItemsSource="{Binding RecentReviews}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="4,6">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" />
                                                    <TextBlock
                                                        Margin="0,2,0,0"
                                                        FontSize="11"
                                                        Foreground="#999"
                                                        Text="{Binding Date, StringFormat='{}{0:MMM d, yyyy}'}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Margin="0,14,0,4" FontWeight="Bold" Foreground="#333" Text="My Active Issues" />
                                <ItemsControl ItemsSource="{Binding MyIssues}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="4,5">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock
                                                        Width="8" Height="8"
                                                        Margin="0,3,8,0"
                                                        VerticalAlignment="Top"
                                                        Foreground="#E53935"
                                                        Text="●" />
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" />
                                                        <TextBlock
                                                            FontSize="11" Foreground="#999"
                                                            Text="{Binding Category.Name}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </DataTemplate>

            </ContentControl.Resources>
        </ContentControl>

        <!-- Empty state: shown when the student has no mentor or mentee -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding HasNoPairs, Converter={StaticResource BoolToVis}}">
            <TextBlock
                FontSize="48"
                HorizontalAlignment="Center"
                Foreground="#CCCCCC"
                Text="👤" />
            <TextBlock
                FontSize="20"
                FontWeight="SemiBold"
                Foreground="#888"
                HorizontalAlignment="Center"
                Margin="0,12,0,6"
                Text="No mentor or mentee assigned" />
            <TextBlock
                FontSize="14"
                Foreground="#AAA"
                HorizontalAlignment="Center"
                Text="Contact your supervisor or administrator to get paired." />
        </StackPanel>
    </Grid>
</UserControl>