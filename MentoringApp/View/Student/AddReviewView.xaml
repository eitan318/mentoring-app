<UserControl
    x:Class="MentoringApp.View.Student.AddReviewView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MentoringApp.View.Student"
    xmlns:loc="clr-namespace:MentoringApp.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">
    <Grid Margin="30">
        <StackPanel>
            <TextBlock
                Margin="0,0,0,10"
                FontSize="22"
                FontWeight="Bold"
                Text="{Binding [Review_Content_Label], Source={x:Static loc:TranslationSource.Instance}}" />

            <TextBox
                Height="150"
                Margin="0,0,0,15"
                AcceptsReturn="True"
                Tag="{Binding [Review_Content_Label], Source={x:Static loc:TranslationSource.Instance}}"
                Text="{Binding ReviewContent, UpdateSourceTrigger=PropertyChanged}"
                TextWrapping="Wrap" />

            <TextBlock
                Margin="0,0,0,5"
                FontSize="14"
                Foreground="Gray"
                Text="{Binding [Review_Hours_Label], Source={x:Static loc:TranslationSource.Instance}}" />

            <TextBox
                Width="100"
                Margin="0,0,0,20"
                HorizontalAlignment="Left"
                Text="{Binding AmountOfHours, UpdateSourceTrigger=PropertyChanged}"
                ToolTip="Enter the number of meeting hours (e.g. 1.5)" />

            <Button
                Width="120"
                HorizontalAlignment="Right"
                Background="Teal"
                Command="{Binding AddReviewCommand}"
                Content="{Binding [Review_Submit_Button], Source={x:Static loc:TranslationSource.Instance}}"
                Foreground="White"
                IsDefault="True"
                Cursor="Hand" />
        </StackPanel>
    </Grid>
</UserControl>
