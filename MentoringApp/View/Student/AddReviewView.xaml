<UserControl
    x:Class="MentoringApp.View.Student.AddReviewView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MentoringApp.View.Student"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="30">
        <StackPanel>
            <TextBlock
                Margin="0,0,0,10"
                FontSize="22"
                FontWeight="Bold"
                Text="Write Meeting Review" />

            <TextBlock
                Margin="0,0,0,5"
                FontSize="14"
                Foreground="Gray"
                Text="Enter your meeting review below:" />

            <TextBox
                Height="150"
                Margin="0,0,0,15"
                AcceptsReturn="True"
                Tag="Review content"
                Text="{Binding ReviewContent, UpdateSourceTrigger=PropertyChanged}"
                TextWrapping="Wrap" />

            <TextBlock
                Margin="0,0,0,5"
                FontSize="14"
                Foreground="Gray"
                Text="Meeting duration (hours):" />

            <TextBox
                Width="100"
                Margin="0,0,0,20"
                HorizontalAlignment="Left"
                Text="{Binding AmountOfHours, UpdateSourceTrigger=PropertyChanged}" />

            <Button
                Width="120"
                HorizontalAlignment="Right"
                Background="Teal"
                Command="{Binding AddReviewCommand}"
                Content="Submit Review"
                Foreground="White" />
        </StackPanel>
    </Grid>
</UserControl>
