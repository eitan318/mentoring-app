<UserControl
    x:Class="MentoringApp.View.Student.AddIssueView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MentoringApp.View.Student"
    xmlns:loc="clr-namespace:MentoringApp.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">
    <Grid>
        <StackPanel>
            <TextBox Tag="{Binding [Issue_Description_Label], Source={x:Static loc:TranslationSource.Instance}}"
                 Text="{Binding IssueDescription, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="Describe the issue you are experiencing" />

            <ComboBox ItemsSource="{Binding IssueCategoryList}"
                  SelectedItem="{Binding SelectedIssueCategory, ValidatesOnDataErrors=True}"
                  Tag="{Binding [Issue_Category_Label], Source={x:Static loc:TranslationSource.Instance}}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Category_">
                                    <Binding Path="Name" />
                                    <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <Button Command="{Binding AddIssueCommand}"
                Content="{Binding [Issue_Submit_Button], Source={x:Static loc:TranslationSource.Instance}}"
                IsDefault="True"
                Cursor="Hand" />
        </StackPanel>
    </Grid>
</UserControl>
