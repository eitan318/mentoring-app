<UserControl
    x:Class="MentoringApp.View.Student.AddIssueView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MentoringApp.View.Student"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <StackPanel>
            <TextBox Tag="Issue description" Text="{Binding IssueDescription}" />
            <ComboBox
                ItemsSource="{Binding IssueCategoryList}"
                SelectedItem="{Binding SelectedIssueCategory, ValidatesOnDataErrors=True}"
                Tag="Issue category" />
            <Button Command="{Binding AddIssueCommand}" Content="Add" />
        </StackPanel>
    </Grid>
</UserControl>
