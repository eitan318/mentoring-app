<Window x:Class="MentoringApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:components="clr-namespace:MentoringApp.View.Components"
        xmlns:loc="clr-namespace:MentoringApp.ViewModel.Localization;assembly=MentoringApp.ViewModel"
        mc:Ignorable="d"
        MinWidth="800" MinHeight="550" Width="1050" Height="650"
        Title="Mentoring App" WindowStartupLocation="CenterScreen"
        FlowDirection="{Binding FlowDirection, Source={x:Static loc:TranslationSource.Instance}}">

    <Grid>
        <!-- Main navigable content -->
        <ContentControl Content="{Binding CurrentViewModel}"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch" />

        <!-- In-app toast notifications and modal dialogs overlay -->
        <components:ToastHostView Panel.ZIndex="100" />
    </Grid>
</Window>
