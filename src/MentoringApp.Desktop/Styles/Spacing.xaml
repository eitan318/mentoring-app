<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    Centralized spacing tokens. Adjust values here to retune the whole app.
    PageMargin   : outer padding around the full page content (was 30,24)
    CardSpacing  : vertical gap between stacked cards (was commonly 0,0,0,24)
    ColumnGap    : horizontal gap between side-by-side cards (was 0,0,24,0)
    -->

    <Thickness x:Key="PageMargin" Left="16" Top="12" Right="16" Bottom="12"/>
    <Thickness x:Key="CardSpacing" Left="0" Top="0" Right="0" Bottom="16"/>
    <Thickness x:Key="ColumnGap" Left="0" Top="0" Right="16" Bottom="0"/>

</ResourceDictionary>
