<UserControl
    x:Class="MentoringApp.View.Supervisor.Dashboard.ManagedPairsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:MentoringApp.View.Components"
    xmlns:loc="clr-namespace:MentoringApp.ViewModel.Localization;assembly=MentoringApp.ViewModel"
    xmlns:b="clr-namespace:MentoringApp.Behaviors"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <UserControl.Resources>
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <Grid>
                                <TextBlock Text="{TemplateBinding Tag}" Foreground="#9CA3AF" Margin="14,0,0,0" VerticalAlignment="Center" Visibility="Collapsed" x:Name="Placeholder"/>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PairListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="12,16" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="#F3F4F6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#F9FAFB"/></Trigger>
                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource CardStyleLg}" Margin="0,0,0,24" Padding="20,20,20,0"
            Visibility="{Binding ArePairsAndIssuesVisible, Converter={StaticResource BoolToVis}}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title + clear-selection button -->
            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="{Binding [Supervisor_ManagedPairs_Label], Source={x:Static loc:TranslationSource.Instance}}" FontSize="18" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Content="{Binding [Supervisor_ClearSelection_Button], Source={x:Static loc:TranslationSource.Instance}}" HorizontalAlignment="Right" Background="Transparent" Foreground="#A855F7" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Command="{Binding SelectPairCommand}" CommandParameter="{x:Null}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers><DataTrigger Binding="{Binding IssueFilterPair}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </DockPanel>

            <!-- Search box -->
            <TextBox Grid.Row="1"
                     Text="{Binding PairSearchText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ModernInput}"
                     Tag="{Binding [Supervisor_PairSearch_Placeholder], Source={x:Static loc:TranslationSource.Instance}}"
                     Margin="0,0,0,12"/>

            <!-- Empty-state label -->
            <TextBlock Grid.Row="2" Text="{Binding [Supervisor_NoPairs], Source={x:Static loc:TranslationSource.Instance}}" FontSize="14" Foreground="#9CA3AF" FontStyle="Italic" Margin="0,0,0,16" HorizontalAlignment="Center"
                       Visibility="{Binding FilteredPairsIsEmpty, Converter={StaticResource BoolToVis}}"/>

            <!-- Column headers -->
            <Grid Grid.Row="3" Margin="10,0,10,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Common_Pair], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="SemiBold" FontSize="12" Foreground="#6B7280"/>
                <TextBlock Grid.Column="1" Text="{Binding [Common_Progress], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="SemiBold" FontSize="12" Foreground="#6B7280"/>
            </Grid>
            <Rectangle Grid.Row="3" Height="1" Fill="#F3F4F6" VerticalAlignment="Bottom" Margin="-20,0,-20,0"/>

            <ListView Grid.Row="4" ItemsSource="{Binding FilteredPairsSupervised}" ItemContainerStyle="{StaticResource PairListViewItemStyle}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      b:ListItemSelector.Command="{Binding SelectPairCommand}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Pair Names -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <components:ProfilePictureControl Width="32" Height="32" Margin="0,0,8,0" ImagePath="{Binding Pair.Mentor.ProfilePicturePath}" Gender="{Binding Pair.Mentor.Gender}"/>
                                <TextBlock Text="{Binding Pair.Mentor.UserName}" FontWeight="Medium" Foreground="#111827" VerticalAlignment="Center"/>

                                <TextBlock Text="↔" Foreground="#9CA3AF" FontWeight="Bold" Margin="12,0" VerticalAlignment="Center"/>

                                <components:ProfilePictureControl Width="32" Height="32" Margin="0,0,8,0" ImagePath="{Binding Pair.Mentee.ProfilePicturePath}" Gender="{Binding Pair.Mentee.Gender}"/>
                                <TextBlock Text="{Binding Pair.Mentee.UserName}" FontWeight="Medium" Foreground="#111827" VerticalAlignment="Center"/>

                                <Border Margin="12,0,0,0" Background="#F3F4F6" CornerRadius="8" Padding="8,4" VerticalAlignment="Center">
                                    <TextBlock FontSize="10" FontWeight="Bold" Foreground="#4B5563">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="MatchTier_">
                                                <Binding Path="MatchTier"/>
                                                <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Border>
                            </StackPanel>

                            <!-- Progress -->
                            <Grid Grid.Column="1" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Height="6" Background="#F3F4F6" CornerRadius="3" ClipToBounds="True">
                                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding HoursProgress, Mode=OneWay}" Foreground="#A855F7" Background="Transparent" BorderThickness="0"/>
                                </Border>
                                <TextBlock Grid.Column="1" Margin="12,0,0,0" FontSize="12" FontWeight="SemiBold" Foreground="#6B7280" Text="{Binding ProgressText}" VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Border>
</UserControl>
