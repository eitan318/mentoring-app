<UserControl
    x:Class="MentoringApp.View.Supervisor.SupervisorDashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:loc="clr-namespace:MentoringApp.ViewModel.Localization;assembly=MentoringApp.ViewModel"
    xmlns:dashboard="clr-namespace:MentoringApp.View.Supervisor.Dashboard"
    d:DesignHeight="800" d:DesignWidth="1000"
    mc:Ignorable="d"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <UserControl.Resources>
        <!-- Detail-pane card style (also used for the right-side detail border) -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.03" ShadowDepth="2" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30,24,30,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- ── MASTER PANE (LEFT) ── -->
        <Grid Grid.Column="0" Margin="0,0,24,0">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ArePairsAndIssuesVisible}" Value="False">
                            <Setter Property="Grid.ColumnSpan" Value="2"/>
                            <Setter Property="Margin" Value="0"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Phase/Header/Stats -->
                <RowDefinition Height="1.5*"/> <!-- Pairs List -->
                <RowDefinition Height="*"/>    <!-- Issues List -->
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <!-- Admin viewing header -->
                <StackPanel Visibility="{Binding IsAdminViewing, Converter={StaticResource BoolToVis}}" Margin="0,0,0,24">
                    <TextBlock FontSize="28" FontWeight="Bold" Foreground="#111827" Text="{Binding SelectedSupervisor.UserName}"/>
                    <TextBlock Foreground="#6B7280" FontSize="14" Margin="0,4,0,0">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{1} {0}">
                                <Binding Path="PairsSupervised.Count"/>
                                <Binding Path="[Supervisor_TotalPairs_Label]" Source="{x:Static loc:TranslationSource.Instance}"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>

                <dashboard:PhaseBannerView/>
                <dashboard:IncompleteWarningView/>
                <dashboard:ClassProgressView/>
            </StackPanel>

            <dashboard:ManagedPairsView Grid.Row="1"/>

            <dashboard:IssuesListView Grid.Row="2"/>
        </Grid>

        <!-- ── DETAIL PANE (RIGHT) ── -->
        <Border Grid.Column="1" Style="{StaticResource CardStyle}"
                Visibility="{Binding ArePairsAndIssuesVisible, Converter={StaticResource BoolToVis}}">
            <Grid>
                <TextBlock Text="{Binding [Supervisor_SelectHint], Source={x:Static loc:TranslationSource.Instance}}" Foreground="#9CA3AF" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Medium">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers><DataTrigger Binding="{Binding SelectedPaneContent}" Value="{x:Null}"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <ContentControl Content="{Binding SelectedPaneContent}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
