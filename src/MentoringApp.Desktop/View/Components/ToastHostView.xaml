<UserControl
    x:Class="MentoringApp.View.Components.ToastHostView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="clr-namespace:MentoringApp.ViewModel.Localization;assembly=MentoringApp.ViewModel"
    xmlns:svc="clr-namespace:MentoringApp.Service">

    <Grid>

        <!-- ── Modal overlay (blocks all UI interaction when active) ── -->
        <Grid Visibility="{Binding HasModal, Converter={StaticResource BoolToVis}}"
              IsHitTestVisible="{Binding HasModal}">

            <!-- Dark backdrop -->
            <Rectangle Fill="#80000000"/>

            <!-- Centered dialog card -->
            <Border MaxWidth="460" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="White" CornerRadius="10" Padding="28,24"
                    Margin="24">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" Opacity="0.25" ShadowDepth="6"/>
                </Border.Effect>
                <StackPanel DataContext="{Binding ActiveModal}">
                    <TextBlock Text="{Binding Title}"
                               FontSize="17" FontWeight="SemiBold"
                               Foreground="#1A1A2E" Margin="0,0,0,12"/>
                    <TextBlock Text="{Binding Message}"
                               TextWrapping="Wrap" FontSize="13"
                               Foreground="#555" LineHeight="20"
                               Margin="0,0,0,24"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                        <!-- Cancel button — only for confirmation dialogs -->
                        <Button Content="{Binding [Confirm_No], Source={x:Static loc:TranslationSource.Instance}}"
                                Command="{Binding CancelCommand}"
                                Visibility="{Binding IsConfirm, Converter={StaticResource BoolToVis}}"
                                Padding="18,8" Margin="0,0,10,0"
                                Background="Transparent" BorderBrush="#CCC" BorderThickness="1"
                                Foreground="#333" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="5" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- OK button (info dialog) -->
                        <Button Content="{Binding [Toast_OK_Button], Source={x:Static loc:TranslationSource.Instance}}"
                                Command="{Binding OkCommand}"
                                Visibility="{Binding IsConfirm, Converter={StaticResource InverseBoolToVis}}"
                                Padding="18,8"
                                Background="#1976D2" Foreground="White" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Yes button (confirm dialog) -->
                        <Button Content="{Binding [Confirm_Yes], Source={x:Static loc:TranslationSource.Instance}}"
                                Command="{Binding OkCommand}"
                                Visibility="{Binding IsConfirm, Converter={StaticResource BoolToVis}}"
                                Padding="18,8"
                                Background="#1976D2" Foreground="White" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Toast stack (bottom-right, non-blocking) ── -->
        <ItemsControl ItemsSource="{Binding Toasts}"
                      VerticalAlignment="Bottom" HorizontalAlignment="Right"
                      Margin="16" IsHitTestVisible="True">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type svc:ToastItem}">
                    <Border CornerRadius="8" Margin="0,0,0,8"
                            MaxWidth="380" MinWidth="260"
                            Background="White">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14" Opacity="0.18" ShadowDepth="4"/>
                        </Border.Effect>
                        <Grid>
                            <!-- Color-coded left strip -->
                            <Border Width="5" HorizontalAlignment="Left" CornerRadius="8,0,0,8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1976D2"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="Success">
                                                <Setter Property="Background" Value="#2E7D32"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="Warning">
                                                <Setter Property="Background" Value="#F57C00"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="Error">
                                                <Setter Property="Background" Value="#C62828"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <!-- Message + close -->
                            <DockPanel Margin="14,10,8,10">
                                <Button DockPanel.Dock="Right" Content="✕"
                                        Command="{Binding CloseCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="#AAAAAA" FontSize="11"
                                        Padding="6,0" VerticalAlignment="Top"
                                        Cursor="Hand"/>
                                <TextBlock Text="{Binding Message}"
                                           TextWrapping="Wrap" FontSize="13"
                                           Foreground="#222" VerticalAlignment="Center"
                                           Margin="0,0,4,0"/>
                            </DockPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </Grid>
</UserControl>
