<UserControl x:Class="MentoringApp.View.Components.ProfilePictureControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="root">
    <Grid>
        <!-- Tinted background circle (always present as a safe backdrop) -->
        <Ellipse Fill="{Binding DefaultFill, ElementName=root}" />

        <!-- Gender default avatar (shown when no user photo) -->
        <Ellipse Visibility="{Binding ShowDefaultAvatar, ElementName=root, Converter={StaticResource BoolToVis}}">
            <Ellipse.Fill>
                <ImageBrush ImageSource="{Binding DefaultImageSource, ElementName=root}"
                            Stretch="UniformToFill" />
            </Ellipse.Fill>
        </Ellipse>

        <!-- User's actual profile picture (overlaid when set) -->
        <Ellipse>
            <Ellipse.Fill>
                <ImageBrush
                    ImageSource="{Binding ImagePath, ElementName=root, Converter={StaticResource StringToImage}, TargetNullValue={x:Null}}"
                    Stretch="UniformToFill" />
            </Ellipse.Fill>
        </Ellipse>
    </Grid>
</UserControl>
