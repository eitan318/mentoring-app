<UserControl
    x:Class="MentoringApp.View.Admin.SystemSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="clr-namespace:MentoringApp.Localization"
    xmlns:model="clr-namespace:MentoringApp.Model;assembly=MentoringApp.Model"
    xmlns:apiModel="clr-namespace:MentoringApp.ApiClient.Models;assembly=MentoringApp.ApiClient"
    xmlns:adminVm="clr-namespace:MentoringApp.ViewModel.ViewModel.Admin;assembly=MentoringApp.ViewModel"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="{Binding [SysSettings_Title], Source={x:Static loc:TranslationSource.Instance}}" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="{Binding [SysSettings_Description], Source={x:Static loc:TranslationSource.Instance}}"
                       Foreground="#666" Margin="0,8,0,0" FontSize="13"/>
        </StackPanel>

        <!-- Tab Navigation -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="{Binding [SysSettings_SchoolConfig_Tab], Source={x:Static loc:TranslationSource.Instance}}"
                    Command="{Binding SelectTabCommand}"
                    CommandParameter="0"
                    Padding="12,8" Margin="0,0,4,0"
                    Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontWeight="SemiBold">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#CCCCCC"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSchoolConfigTabSelected}" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="1"
                    Content="{Binding [SysSettings_SupervisorConfig_Tab], Source={x:Static loc:TranslationSource.Instance}}"
                    Command="{Binding SelectTabCommand}"
                    CommandParameter="1"
                    Padding="12,8" Margin="0,0,0,0"
                    Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontWeight="SemiBold">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#CCCCCC"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSchoolConfigTabSelected}" Value="False">
                                <Setter Property="Background" Value="#1976D2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- First-time setup banner -->
        <Border Grid.Row="2"
                Visibility="{Binding IsFirstTimeSetup, Converter={StaticResource BoolToVis}}"
                Background="#FFF8E1" BorderBrush="#FFD54F" BorderThickness="2"
                CornerRadius="6" Padding="16,14" Margin="0,0,0,20">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="{Binding [SysSettings_Continue_Button], Source={x:Static loc:TranslationSource.Instance}}"
                        Command="{Binding GoToDashboardCommand}"
                        IsEnabled="{Binding CanContinueToDashboard}"
                        Padding="14,6" Background="#388E3C" Foreground="White" BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="{Binding [SysSettings_Continue_Tooltip], Source={x:Static loc:TranslationSource.Instance}}"
                        VerticalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Opacity" Value="1"/>
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                    Padding="{TemplateBinding Padding}"
                                    Opacity="{TemplateBinding Opacity}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding [SysSettings_Welcome_Title], Source={x:Static loc:TranslationSource.Instance}}"
                               FontWeight="SemiBold" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding [SysSettings_Welcome_Subtitle], Source={x:Static loc:TranslationSource.Instance}}"
                               Foreground="#555" FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="3"
              Visibility="{Binding IsSchoolConfigTabSelected, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Add new class -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding [SysSettings_AddClass_Header], Source={x:Static loc:TranslationSource.Instance}}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <Border BorderBrush="#E0E0E0" BorderThickness="1" Padding="18" CornerRadius="8" Background="#F5F5F5">
                    <StackPanel>
                        <TextBlock Text="{Binding [SysSettings_Grade_Label], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="Bold" Margin="0,0,0,6"/>
                        <ComboBox ItemsSource="{Binding AvailableGrades}"
                                  SelectedItem="{Binding SelectedGrade}"
                                  Margin="0,0,0,16">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Grade_">
                                                <Binding Path="Name"/>
                                                <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="{Binding [SysSettings_ClassNumber_Label], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding ClassNumInput, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,16"
                                 Tag="{Binding [SysSettings_ClassNumber_Tag], Source={x:Static loc:TranslationSource.Instance}}"/>

                        <Button Content="{Binding [SysSettings_AddClass_Button], Source={x:Static loc:TranslationSource.Instance}}"
                                Command="{Binding AddClassCommand}"
                                Padding="14,10" HorizontalAlignment="Left"
                                Background="#1976D2" Foreground="White" BorderThickness="0"
                                Cursor="Hand" FontWeight="SemiBold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- RIGHT: Current classes list -->
            <StackPanel Grid.Column="2">
                <DockPanel Margin="0,0,0,12">
                    <TextBlock Text="{Binding [SysSettings_ParticipatingClasses_Header], Source={x:Static loc:TranslationSource.Instance}}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="{Binding [SysSettings_RemoveSelected_Button], Source={x:Static loc:TranslationSource.Instance}}"
                            Command="{Binding DeleteClassCommand}"
                            HorizontalAlignment="Right"
                            Padding="10,6" Background="#EF9A9A" Foreground="White" BorderThickness="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DockPanel>

                <ListBox ItemsSource="{Binding AllClasses}"
                         SelectedItem="{Binding SelectedClass}"
                         BorderBrush="#E0E0E0" BorderThickness="1"
                         Background="#F5F5F5"
                         MinHeight="220" MaxHeight="370">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type model:SchoolClassModel}">
                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Margin="0,12,0,0" Foreground="#999" FontSize="12"
                           Text="{Binding [SysSettings_Tip], Source={x:Static loc:TranslationSource.Instance}}"/>
            </StackPanel>
        </Grid>

        <!-- Assign Classes to Supervisors -->
        <Border Grid.Row="4"
                Visibility="{Binding IsSchoolConfigTabSelected, Converter={StaticResource InverseBoolToVis}}"
                Margin="0,0,0,0" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding [SysSettings_AssignClasses_Header], Source={x:Static loc:TranslationSource.Instance}}"
                           FontSize="18" FontWeight="SemiBold"/>
                <TextBlock Grid.Row="1" Margin="0,8,0,14" Foreground="#666" FontSize="13"
                           Text="{Binding [SysSettings_AssignClasses_Description], Source={x:Static loc:TranslationSource.Instance}}"/>

                <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Top">

                    <!-- Unassigned classes pool -->
                    <Border x:Name="PoolDropZone"
                            AllowDrop="True"
                            Drop="PoolDropZone_Drop"
                            DragEnter="DropZone_DragEnter"
                            DragLeave="DropZone_DragLeave"
                            DragOver="DropZone_DragOver"
                            Width="180" MinHeight="140" VerticalAlignment="Top"
                            Margin="0,0,12,0"
                            BorderBrush="#E0E0E0" BorderThickness="1"
                            Background="#F5F5F5" Padding="12" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="{Binding [SysSettings_UnassignedPool_Header], Source={x:Static loc:TranslationSource.Instance}}"
                                       FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,8" FontSize="12"/>
                            <ItemsControl ItemsSource="{Binding UnassignedClasses}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#E3F2FD" BorderBrush="#64B5F6" BorderThickness="1"
                                                CornerRadius="4" Padding="8,5" Margin="0,0,0,5" Cursor="Hand"
                                                PreviewMouseLeftButtonDown="ClassChip_MouseDown"
                                                PreviewMouseMove="ClassChip_MouseMove">
                                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#1565C0" Text="{Binding DisplayName}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- One card per supervisor -->
                    <ItemsControl ItemsSource="{Binding SupervisorSlots}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type adminVm:SupervisorSlot}">
                                <Border AllowDrop="True"
                                        Drop="SupervisorCard_Drop"
                                        DragEnter="DropZone_DragEnter"
                                        DragLeave="DropZone_DragLeave"
                                        DragOver="DropZone_DragOver"
                                        Width="180" MinHeight="140" VerticalAlignment="Top"
                                        Margin="0,0,12,0"
                                        BorderBrush="#E0E0E0" BorderThickness="1"
                                        Background="#F5F5F5" Padding="12" CornerRadius="6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="Bold" FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,0,8"
                                                   ToolTip="{Binding DisplayName}"/>
                                        <ItemsControl ItemsSource="{Binding AssignedClasses}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#E8F5E9" BorderBrush="#81C784" BorderThickness="1"
                                                            CornerRadius="4" Padding="8,5" Margin="0,0,0,5" Cursor="Hand"
                                                            PreviewMouseLeftButtonDown="ClassChip_MouseDown"
                                                            PreviewMouseMove="ClassChip_MouseMove">
                                                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#2E7D32" Text="{Binding DisplayName}"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

    </Grid>
</UserControl>
