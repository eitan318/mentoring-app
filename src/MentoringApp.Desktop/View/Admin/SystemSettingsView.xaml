<UserControl
    x:Class="MentoringApp.View.Admin.SystemSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="clr-namespace:MentoringApp.ViewModel.Localization;assembly=MentoringApp.ViewModel"
    xmlns:model="clr-namespace:MentoringApp.Model;assembly=MentoringApp.Model"
    xmlns:apiModel="clr-namespace:MentoringApp.ApiClient.Models;assembly=MentoringApp.ApiClient"
    xmlns:adminVm="clr-namespace:MentoringApp.ViewModel.ViewModel.Admin;assembly=MentoringApp.ViewModel"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Inverse Boolean To Visibility -->
        <Style x:Key="InverseVisibilityStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSchoolConfigTabSelected}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Base Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.03" ShadowDepth="2" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Button Style -->
        <Style x:Key="ModernBtn" TargetType="Button">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5E7EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource ModernBtn}">
            <Setter Property="Background" Value="#A855F7"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#9333EA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource ModernBtn}">
            <Setter Property="Background" Value="#FEE2E2"/>
            <Setter Property="Foreground" Value="#DC2626"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FECACA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Input Style -->
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <Grid>
                                <TextBlock Text="{TemplateBinding Tag}" Foreground="#9CA3AF" Margin="14,0,0,0" VerticalAlignment="Center" Visibility="Collapsed" x:Name="Placeholder"/>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Margin="30,24,30,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── HEADER ── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="{Binding [SysSettings_Title], Source={x:Static loc:TranslationSource.Instance}}" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
            <TextBlock Text="{Binding [SysSettings_Description], Source={x:Static loc:TranslationSource.Instance}}" Foreground="#6B7280" Margin="0,8,0,0" FontSize="14"/>
        </StackPanel>

        <!-- ── FIRST TIME SETUP BANNER ── -->
        <Border Grid.Row="1" Visibility="{Binding IsFirstTimeSetup, Converter={StaticResource BoolToVis}}"
                Background="#FEF3C7" BorderBrush="#FCD34D" BorderThickness="1" CornerRadius="12" Padding="20,16" Margin="0,0,0,24">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="{Binding [SysSettings_Continue_Button], Source={x:Static loc:TranslationSource.Instance}}"
                        Command="{Binding GoToDashboardCommand}" IsEnabled="{Binding CanContinueToDashboard}"
                        Style="{StaticResource PrimaryBtn}" VerticalAlignment="Center" ToolTip="{Binding [SysSettings_Continue_Tooltip], Source={x:Static loc:TranslationSource.Instance}}"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding [SysSettings_Welcome_Title], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="Bold" FontSize="16" Foreground="#92400E" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding [SysSettings_Welcome_Subtitle], Source={x:Static loc:TranslationSource.Instance}}" Foreground="#B45309" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── TABS ── -->
        <Border Grid.Row="2" Background="#F3F4F6" CornerRadius="12" Padding="4" HorizontalAlignment="Left" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal">
                <Button Content="{Binding [SysSettings_SchoolConfig_Tab], Source={x:Static loc:TranslationSource.Instance}}" Command="{Binding SelectTabCommand}" CommandParameter="0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ModernBtn}">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#6B7280"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSchoolConfigTabSelected}" Value="True">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="#111827"/>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="4" Color="#000000" Opacity="0.05" ShadowDepth="1" Direction="270"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="{Binding [SysSettings_SupervisorConfig_Tab], Source={x:Static loc:TranslationSource.Instance}}" Command="{Binding SelectTabCommand}" CommandParameter="1">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ModernBtn}">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#6B7280"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSchoolConfigTabSelected}" Value="False">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="#111827"/>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="4" Color="#000000" Opacity="0.05" ShadowDepth="1" Direction="270"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <!-- ── TAB CONTENT ── -->
        <Grid Grid.Row="3">
            
            <!-- ── TAB 1: SCHOOL CONFIG ── -->
            <Grid Visibility="{Binding IsSchoolConfigTabSelected, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Add Class -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,24,0" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="{Binding [SysSettings_AddClass_Header], Source={x:Static loc:TranslationSource.Instance}}" FontSize="18" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,24"/>
                        
                        <TextBlock Text="{Binding [SysSettings_Grade_Label], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
                        <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="12,4" Margin="0,0,0,16">
                            <ComboBox ItemsSource="{Binding AvailableGrades}" SelectedItem="{Binding SelectedGrade}" BorderThickness="0" Background="Transparent">
                                <ComboBox.ItemTemplate><DataTemplate><TextBlock><TextBlock.Text><MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Grade_"><Binding Path="Name"/><Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture"/></MultiBinding></TextBlock.Text></TextBlock></DataTemplate></ComboBox.ItemTemplate>
                            </ComboBox>
                        </Border>

                        <TextBlock Text="{Binding [SysSettings_ClassNumber_Label], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource ModernInput}" Text="{Binding ClassNumInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,24" Tag="{Binding [SysSettings_ClassNumber_Tag], Source={x:Static loc:TranslationSource.Instance}}"/>

                        <Button Content="{Binding [SysSettings_AddClass_Button], Source={x:Static loc:TranslationSource.Instance}}" Command="{Binding AddClassCommand}" Style="{StaticResource PrimaryBtn}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Current Classes List -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <DockPanel Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="{Binding [SysSettings_ParticipatingClasses_Header], Source={x:Static loc:TranslationSource.Instance}}" FontSize="18" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right" Content="{Binding [SysSettings_RemoveSelected_Button], Source={x:Static loc:TranslationSource.Instance}}" Command="{Binding DeleteClassCommand}" Style="{StaticResource DangerBtn}" HorizontalAlignment="Right" Padding="12,6"/>
                        </DockPanel>

                        <Border Grid.Row="1" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="8">
                            <ListBox ItemsSource="{Binding AllClasses}" SelectedItem="{Binding SelectedClass}" BorderThickness="0" Background="Transparent" MinHeight="200">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="16,12"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush" Value="#F3F4F6"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" CornerRadius="8" Margin="0,2">
                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#E5E7EB"/></Trigger>
                                                        <Trigger Property="IsSelected" Value="True"><Setter TargetName="Bd" Property="Background" Value="#D1D5DB"/></Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type model:SchoolClassModel}">
                                        <TextBlock FontWeight="Medium" Foreground="#111827">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource GradeClassDisplay}">
                                                    <Binding Path="Grade.Name"/>
                                                    <Binding Path="ClassNum"/>
                                                    <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── TAB 2: SUPERVISOR ASSIGNMENT ── -->
            <Grid Style="{StaticResource InverseVisibilityStyle}">
                <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,24">
                        <TextBlock Text="{Binding [SysSettings_AssignClasses_Header], Source={x:Static loc:TranslationSource.Instance}}" FontSize="18" FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Text="{Binding [SysSettings_AssignClasses_Description], Source={x:Static loc:TranslationSource.Instance}}" Foreground="#6B7280" FontSize="14" Margin="0,4,0,0"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top">

                            <!-- Unassigned Classes DropZone -->
                            <Border x:Name="PoolDropZone" AllowDrop="True" Drop="PoolDropZone_Drop" DragEnter="DropZone_DragEnter" DragLeave="DropZone_DragLeave" DragOver="DropZone_DragOver"
                                    Width="220" MinHeight="200" VerticalAlignment="Top" Margin="0,0,16,0"
                                    Background="#F9FAFB" BorderBrush="#D1D5DB" BorderThickness="2" CornerRadius="12" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="{Binding [SysSettings_UnassignedPool_Header], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="Bold" Foreground="#4B5563" Margin="0,0,0,16" FontSize="14"/>
                                    <ItemsControl ItemsSource="{Binding UnassignedClasses}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#E0F2FE" BorderBrush="#BAE6FD" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,8" Cursor="Hand"
                                                        PreviewMouseLeftButtonDown="ClassChip_MouseDown" PreviewMouseMove="ClassChip_MouseMove">
                                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#0369A1" HorizontalAlignment="Center">
                                                        <TextBlock.Text>
                                                            <MultiBinding Converter="{StaticResource GradeClassDisplay}">
                                                                <Binding Path="Grade.Name"/>
                                                                <Binding Path="ClassNum"/>
                                                                <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Supervisor DropZones -->
                            <ItemsControl ItemsSource="{Binding SupervisorSlots}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type adminVm:SupervisorSlot}">
                                        <Border AllowDrop="True" Drop="SupervisorCard_Drop" DragEnter="DropZone_DragEnter" DragLeave="DropZone_DragLeave" DragOver="DropZone_DragOver"
                                                Width="220" MinHeight="200" VerticalAlignment="Top" Margin="0,0,16,0"
                                                Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="16">
                                            <Border.Effect><DropShadowEffect BlurRadius="10" Color="#000000" Opacity="0.02" ShadowDepth="1" Direction="270"/></Border.Effect>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                                    <TextBlock Text="👤" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="14" Foreground="#111827" TextTrimming="CharacterEllipsis" ToolTip="{Binding DisplayName}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <ItemsControl ItemsSource="{Binding AssignedClasses}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,8" Cursor="Hand"
                                                                    PreviewMouseLeftButtonDown="ClassChip_MouseDown" PreviewMouseMove="ClassChip_MouseMove">
                                                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#047857" HorizontalAlignment="Center">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding Converter="{StaticResource GradeClassDisplay}">
                                                                            <Binding Path="Grade.Name"/>
                                                                            <Binding Path="ClassNum"/>
                                                                            <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture"/>
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                </TextBlock>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
