<UserControl
    x:Class="MentoringApp.View.Admin.SystemSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="clr-namespace:MentoringApp.Localization"
    xmlns:apiModel="clr-namespace:MentoringApp.ApiClient.Models;assembly=MentoringApp.ApiClient"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="{Binding [SysSettings_Title], Source={x:Static loc:TranslationSource.Instance}}" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="{Binding [SysSettings_Description], Source={x:Static loc:TranslationSource.Instance}}"
                       Foreground="Gray" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- First-time setup banner -->
        <Border Grid.Row="1"
                Visibility="{Binding IsFirstTimeSetup, Converter={StaticResource BoolToVis}}"
                Background="#FFF8E1" BorderBrush="#FFD54F" BorderThickness="1"
                CornerRadius="4" Padding="14,10" Margin="0,0,0,16">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="{Binding [SysSettings_Continue_Button], Source={x:Static loc:TranslationSource.Instance}}"
                        Command="{Binding GoToDashboardCommand}"
                        IsEnabled="{Binding CanContinueToDashboard}"
                        Padding="14,6" Background="#388E3C" Foreground="White" BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="{Binding [SysSettings_Continue_Tooltip], Source={x:Static loc:TranslationSource.Instance}}"
                        VerticalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Opacity" Value="1"/>
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                    Padding="{TemplateBinding Padding}"
                                    Opacity="{TemplateBinding Opacity}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding [SysSettings_Welcome_Title], Source={x:Static loc:TranslationSource.Instance}}"
                               FontWeight="SemiBold" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding [SysSettings_Welcome_Subtitle], Source={x:Static loc:TranslationSource.Instance}}"
                               Foreground="#555" FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Add new class -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding [SysSettings_AddClass_Header], Source={x:Static loc:TranslationSource.Instance}}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Border BorderBrush="#DDD" BorderThickness="1" Padding="16" CornerRadius="6" Background="#FAFAFA">
                    <StackPanel>
                        <TextBlock Text="{Binding [SysSettings_Grade_Label], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="Bold" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding AvailableGrades}"
                                  SelectedItem="{Binding SelectedGrade}"
                                  Margin="0,0,0,12">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Grade_">
                                                <Binding Path="Name"/>
                                                <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="{Binding [SysSettings_ClassNumber_Label], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding ClassNumInput, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"
                                 Tag="{Binding [SysSettings_ClassNumber_Tag], Source={x:Static loc:TranslationSource.Instance}}"/>

                        <Button Content="{Binding [SysSettings_AddClass_Button], Source={x:Static loc:TranslationSource.Instance}}"
                                Command="{Binding AddClassCommand}"
                                Padding="12,8" HorizontalAlignment="Left"
                                Background="#1976D2" Foreground="White" BorderThickness="0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- RIGHT: Current classes list -->
            <StackPanel Grid.Column="2">
                <DockPanel Margin="0,0,0,12">
                    <TextBlock Text="{Binding [SysSettings_ParticipatingClasses_Header], Source={x:Static loc:TranslationSource.Instance}}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="{Binding [SysSettings_RemoveSelected_Button], Source={x:Static loc:TranslationSource.Instance}}"
                            Command="{Binding DeleteClassCommand}"
                            HorizontalAlignment="Right"
                            Padding="8,4" Background="#D32F2F" Foreground="White" BorderThickness="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DockPanel>

                <ListBox ItemsSource="{Binding AllClasses}"
                         SelectedItem="{Binding SelectedClass}"
                         BorderBrush="#DDD" BorderThickness="1"
                         MinHeight="200" MaxHeight="350">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type apiModel:SchoolClassResponse}">
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <TextBlock FontWeight="SemiBold" Margin="0,0,8,0" Text="{Binding GradeId, StringFormat='Grade {0}'}"/>
                                <TextBlock Text="{Binding [SysSettings_ClassSeparator], Source={x:Static loc:TranslationSource.Instance}}" Foreground="Gray"/>
                                <TextBlock Text="{Binding ClassNum}" FontWeight="Bold"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Margin="0,8,0,0" Foreground="#AAA" FontSize="11"
                           Text="{Binding [SysSettings_Tip], Source={x:Static loc:TranslationSource.Instance}}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
