<UserControl
    x:Class="MentoringApp.View.Admin.AdminOverviewView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:loc="clr-namespace:MentoringApp.ViewModel.Localization;assembly=MentoringApp.ViewModel"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:MentoringApp.View.Admin"
    xmlns:overview="clr-namespace:MentoringApp.View.Admin.Overview"
    mc:Ignorable="d"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <UserControl.Resources>
        <!-- Base Card Style (used by inline import-instruction and supervisor-assignment cards) -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.03" ShadowDepth="2" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30,24,30,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="270"/>
        </Grid.ColumnDefinitions>

        <!-- ── Left Column (Main Content) ── -->
        <Grid Grid.Column="0" Margin="0,0,30,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Stat Cards -->
                <RowDefinition Height="Auto"/> <!-- Phase Stepper -->
                <RowDefinition Height="*"/>    <!-- Step content -->
            </Grid.RowDefinitions>

            <!-- Phase Stepper -->
            <overview:PhaseStepperView Grid.Row="2"/>

            <!-- Bottom Row: Step-specific content -->
            <Grid Grid.Row="3">
                <!-- Step 1: School configuration (inline) -->
                <local:SchoolConfigView DataContext="{Binding SchoolConfig}"
                                        Visibility="{Binding DataContext.Progress.IsSchoolConfigStepActive, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>

                <!-- Step 2: Import users instruction -->
                <Border Style="{StaticResource CardStyle}"
                        Visibility="{Binding Progress.IsImportStepActive, Converter={StaticResource BoolToVis}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
                        <TextBlock Text="&#x1F393;" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="{Binding [Admin_ImportUsers_Instruction_Title], Source={x:Static loc:TranslationSource.Instance}}"
                                   FontSize="20" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding [Admin_ImportUsers_Instruction_Body], Source={x:Static loc:TranslationSource.Instance}}"
                                   FontSize="14" Foreground="#6B7280" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="500"/>
                    </StackPanel>
                </Border>

                <!-- Step 3: Assign Supervisors -->
                <Border Style="{StaticResource CardStyle}"
                        Visibility="{Binding Progress.IsSupervisorAssignmentStepActive, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <local:SupervisorAssignmentView Grid.Row="0" DataContext="{Binding SupervisorAssignment}"/>
                        <Button Grid.Row="1" Content="{Binding [Admin_Continue_Button], Source={x:Static loc:TranslationSource.Instance}}" Padding="0,10" Margin="0,20,0,0"
                                Background="#A855F7" Foreground="White" FontWeight="SemiBold" BorderThickness="0"
                                IsEnabled="{Binding SupervisorAssignment.AllClassesAssigned}"
                                Command="{Binding CompleteSupervisorAssignmentCommand}">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                        </Button>
                    </Grid>
                </Border>

                <!-- Step 4: Supervisors list (Registration, Mentor Selection, and Completed phases) -->
                <overview:SupervisorsListView Loaded="SupervisorsListView_Loaded"/>
            </Grid>
        </Grid>

        <!-- ── Right Column (Sidebar) ── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Calendar / Deadlines / Phase Actions -->
            <overview:PhaseActionsView Grid.Row="0"/>

            <!-- Notice Board (Forwarded Issues) -->
            <overview:NoticeBoardView Grid.Row="1" Visibility="{Binding Progress.IsSupervisorsAssigned, Converter={StaticResource BoolToVis}}"/>
        </Grid>
    </Grid>
</UserControl>
