<UserControl
    x:Class="MentoringApp.View.Admin.AdminDashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:loc="clr-namespace:MentoringApp.ViewModel.Localization;assembly=MentoringApp.ViewModel"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="700" d:DesignWidth="1100"
    mc:Ignorable="d"
    SizeChanged="OnSizeChanged"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <UserControl.Resources>

        <!-- Sidebar nav item template -->
        <Style x:Key="SideNavStyle" TargetType="Button">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="Padding"                  Value="14,12"/>
            <Setter Property="Margin"                   Value="0,4"/>
            <Setter Property="Foreground"               Value="#6B7280"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="FontWeight"               Value="Medium"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"                   Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Background="#F4F7FE">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SideNavColumn" Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Left Sidebar ── -->
        <Border x:Name="SideNavBorder" Grid.Column="0" Background="#FFFFFF" CornerRadius="0,20,20,0"
                MouseEnter="OnSideNavMouseEnter" MouseLeave="OnSideNavMouseLeave">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Color="#000000" Opacity="0.03"
                                  ShadowDepth="0" Direction="0"/>
            </Border.Effect>

            <DockPanel LastChildFill="False">

                <!-- Navigation -->
                <StackPanel DockPanel.Dock="Top" Margin="8,10,8,0">

                    <!-- Dashboard -->
                    <Button Command="{Binding GoToDashboardCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SideNavStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnDashboard}" Value="True">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#C084FC" Offset="0.0" />
                                                    <GradientStop Color="#A855F7" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x25A6;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding [Admin_Menu_Dashboard], Source={x:Static loc:TranslationSource.Instance}}" VerticalAlignment="Center"
                                       Visibility="{Binding IsRailMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVis}}"/>
                        </StackPanel>
                    </Button>

                    <!-- Manage Pairs (visible from mentor selection step onward) -->
                    <Button Command="{Binding ManagePairsCommand}"
                            Visibility="{Binding Progress.ShowManagePairs, Converter={StaticResource BoolToVis}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SideNavStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnManagePairs}" Value="True">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#C084FC" Offset="0.0" />
                                                    <GradientStop Color="#A855F7" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4DA;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding [Admin_Menu_ManagePairs], Source={x:Static loc:TranslationSource.Instance}}" VerticalAlignment="Center"
                                       Visibility="{Binding IsRailMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVis}}"/>
                        </StackPanel>
                    </Button>

                    <!-- Manage Users (visible once school is configured) -->
                    <Button Command="{Binding ManageUsersCommand}"
                            Visibility="{Binding Progress.ShowManageUsers, Converter={StaticResource BoolToVis}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SideNavStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnManageUsers}" Value="True">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#C084FC" Offset="0.0" />
                                                    <GradientStop Color="#A855F7" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F393;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding [Admin_Menu_ManageUsers], Source={x:Static loc:TranslationSource.Instance}}" VerticalAlignment="Center"
                                       Visibility="{Binding IsRailMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVis}}"/>
                        </StackPanel>
                    </Button>

                    <!-- System Settings (visible once school is configured) -->
                    <Button Command="{Binding SystemSettingsCommand}"
                            Visibility="{Binding Progress.ShowSystemSettings, Converter={StaticResource BoolToVis}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SideNavStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnSystemSettings}" Value="True">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#C084FC" Offset="0.0" />
                                                    <GradientStop Color="#A855F7" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2699;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding [Admin_Menu_SystemSettings], Source={x:Static loc:TranslationSource.Instance}}" VerticalAlignment="Center"
                                       Visibility="{Binding IsRailMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVis}}"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
                
               
            </DockPanel>
        </Border>

        <!-- ── Main content area ── -->
        <Border Grid.Column="1" Padding="0">
            <ContentControl Content="{Binding ActiveSubPage}"/>
        </Border>

    </Grid>
</UserControl>
