<UserControl
    x:Class="MentoringApp.View.Admin.AdminDashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:loc="clr-namespace:MentoringApp.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="700" d:DesignWidth="1100"
    mc:Ignorable="d"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <UserControl.Resources>

        <!-- Sidebar nav item template -->
        <Style x:Key="SideNavStyle" TargetType="Button">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="Padding"                  Value="14,12"/>
            <Setter Property="Margin"                   Value="0,4"/>
            <Setter Property="Foreground"               Value="#6B7280"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="FontWeight"               Value="Medium"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"                   Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Background="#F4F7FE">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Left Sidebar ── -->
        <Border Grid.Column="0" Background="#FFFFFF" CornerRadius="0,20,20,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Color="#000000" Opacity="0.03"
                                  ShadowDepth="0" Direction="0"/>
            </Border.Effect>

            <DockPanel LastChildFill="False">

                <!-- Logo block -->
                <Border DockPanel.Dock="Top" Padding="24,30,24,20">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32" CornerRadius="8"
                                Background="#A855F7" Margin="0,0,12,0" VerticalAlignment="Center">
                            <TextBlock Text="E" Foreground="White" FontWeight="Bold" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="EDUCATION" FontWeight="Bold" FontSize="14" Foreground="#111827"/>
                            <TextBlock Text="ONLINE LEARNING" FontSize="8" Foreground="#9CA3AF"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Navigation -->
                <StackPanel DockPanel.Dock="Top" Margin="16,10,16,0">

                    <!-- Dashboard -->
                    <Button Command="{Binding GoToDashboardCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SideNavStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnDashboard}" Value="True">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#C084FC" Offset="0.0" />
                                                    <GradientStop Color="#A855F7" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x25A6;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Manage Pairs -->
                    <Button Command="{Binding ManagePairsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SideNavStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnManagePairs}" Value="True">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#C084FC" Offset="0.0" />
                                                    <GradientStop Color="#A855F7" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4DA;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Manage Pairs" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Manage Users -->
                    <Button Command="{Binding ManageUsersCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SideNavStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnManageUsers}" Value="True">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#C084FC" Offset="0.0" />
                                                    <GradientStop Color="#A855F7" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F393;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Manage Users" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- System Settings -->
                    <Button Command="{Binding SystemSettingsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SideNavStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnSystemSettings}" Value="True">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#C084FC" Offset="0.0" />
                                                    <GradientStop Color="#A855F7" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2699;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="System Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
                
               
            </DockPanel>
        </Border>

        <!-- ── Main content area ── -->
        <Border Grid.Column="1" Padding="0">
            <ContentControl Content="{Binding ActiveSubPage}"/>
        </Border>

    </Grid>
</UserControl>
