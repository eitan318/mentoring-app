<UserControl
    x:Class="MentoringApp.View.Admin.AdminDashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:loc="clr-namespace:MentoringApp.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600" d:DesignWidth="800"
    mc:Ignorable="d"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <UserControl.Resources>
        <!-- Navbar button base style -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="Margin"          Value="0,0,4,0"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Foreground"      Value="#555555"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EBEBEB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- ── Top Navigation Bar ── -->
        <Border Height="50" Background="#F8F8F8" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" DockPanel.Dock="Top">
            <StackPanel Orientation="Horizontal" Margin="12,0" VerticalAlignment="Stretch">

                <Button Content="&#x1F4CA; Dashboard"
                        Command="{Binding GoToDashboardCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOnDashboard}" Value="True">
                                    <Setter Property="BorderBrush" Value="#3B82F6"/>
                                    <Setter Property="Foreground"  Value="#1D4ED8"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="&#x1F517; Manage Pairs"
                        Command="{Binding ManagePairsCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOnManagePairs}" Value="True">
                                    <Setter Property="BorderBrush" Value="#3B82F6"/>
                                    <Setter Property="Foreground"  Value="#1D4ED8"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="&#x1F465; Manage Users"
                        Command="{Binding ManageUsersCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOnManageUsers}" Value="True">
                                    <Setter Property="BorderBrush" Value="#3B82F6"/>
                                    <Setter Property="Foreground"  Value="#1D4ED8"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="&#x2699; System Settings"
                        Command="{Binding SystemSettingsCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOnSystemSettings}" Value="True">
                                    <Setter Property="BorderBrush" Value="#3B82F6"/>
                                    <Setter Property="Foreground"  Value="#1D4ED8"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>
        </Border>

        <!-- ── Active sub-page content (resolved via DataTemplate in ViewModelViewMap.xaml) ── -->
        <ContentControl Content="{Binding ActiveSubPage}"/>
    </DockPanel>
</UserControl>
