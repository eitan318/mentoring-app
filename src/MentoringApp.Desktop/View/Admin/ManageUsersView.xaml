<UserControl x:Class="MentoringApp.View.Admin.ManageUsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:apiModel="clr-namespace:MentoringApp.ApiClient.Models;assembly=MentoringApp.ApiClient"
             xmlns:components="clr-namespace:MentoringApp.View.Components"
             xmlns:loc="clr-namespace:MentoringApp.Localization"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="700"
             FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#9EB4CB" Opacity="0.10" BlurRadius="6" ShadowDepth="1" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CardHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="MetaLbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextHintBrush}"/>
        </Style>
    </UserControl.Resources>

    <!-- Root grid -->
    <Grid Background="#F0F4F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── CARD: ADD & IMPORT ──────────────────────────────────────────── -->
        <Border Grid.Row="0" Margin="16,16,16,0" Style="{StaticResource CardBorder}">
            <StackPanel Margin="20,16">
                <!-- Card header -->
                <DockPanel Margin="0,0,0,14">
                    <Border Width="4" Height="18" Background="{StaticResource PrimaryBrush}" CornerRadius="2"
                            VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Style="{StaticResource CardHeader}"
                               Text="{Binding [Admin_ManageUsers_AddImportHeader], Source={x:Static loc:TranslationSource.Instance}}"/>
                </DockPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Command="{Binding RegisterSupervisorCommand}"
                            Content="{Binding [Admin_ManageUsers_AddSupervisor], Source={x:Static loc:TranslationSource.Instance}}"
                            Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                    <Button Command="{Binding RegisterStudentCommand}"
                            Content="{Binding [Admin_ManageUsers_AddStudent], Source={x:Static loc:TranslationSource.Instance}}"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding [Admin_ManageUsers_BulkImport], Source={x:Static loc:TranslationSource.Instance}}"
                               VerticalAlignment="Center" Margin="0,0,10,0"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                    <Button Command="{Binding ImportStudentsCommand}"
                            Content="{Binding [Admin_ManageUsers_ImportStudents], Source={x:Static loc:TranslationSource.Instance}}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,4,0"/>
                    <Button Command="{Binding ToggleStudentInfoCommand}"
                            Content="{Binding [Admin_ManageUsers_Help], Source={x:Static loc:TranslationSource.Instance}}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,16,0"
                            ToolTip="{Binding [Admin_ManageUsers_ImportStudentsHelp], Source={x:Static loc:TranslationSource.Instance}}"/>
                    <Button Command="{Binding ImportSupervisorsCommand}"
                            Content="{Binding [Admin_ManageUsers_ImportSupervisors], Source={x:Static loc:TranslationSource.Instance}}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,4,0"/>
                    <Button Command="{Binding ToggleSupervisorInfoCommand}"
                            Content="{Binding [Admin_ManageUsers_Help], Source={x:Static loc:TranslationSource.Instance}}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            ToolTip="{Binding [Admin_ManageUsers_ImportSupervisorsHelp], Source={x:Static loc:TranslationSource.Instance}}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── MAIN SPLIT: LIST + DETAILS ─────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="16,12,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Search/Filter + User List -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                <DockPanel>
                    <!-- Card header -->
                    <Border DockPanel.Dock="Top" Padding="20,14" Background="#EBF5FF"
                            BorderThickness="0,0,0,1" BorderBrush="#BBDEFB" CornerRadius="12,12,0,0">
                        <DockPanel>
                            <Border Width="4" Height="18" Background="{StaticResource PrimaryBrush}" CornerRadius="2"
                                    VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Style="{StaticResource CardHeader}" Text="Users"/>
                        </DockPanel>
                    </Border>

                    <!-- Search + role filter -->
                    <Grid DockPanel.Dock="Top" Margin="16,12,16,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="4,3" Margin="0,0,8,0"
                                 Tag="{Binding [Admin_ManageUsers_SearchHint], Source={x:Static loc:TranslationSource.Instance}}"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding RoleOptions}"
                                  SelectedItem="{Binding SelectedRole}"
                                  Width="110" Padding="4,2">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <!-- Student-specific filters -->
                    <Border DockPanel.Dock="Top" Margin="16,0,16,8" Padding="8,6"
                            BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStudentFilterVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="{Binding [Admin_ManageUsers_Profile], Source={x:Static loc:TranslationSource.Instance}}"
                                           VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <CheckBox Content="{Binding [Admin_ManageUsers_Mentor], Source={x:Static loc:TranslationSource.Instance}}"
                                          IsChecked="{Binding FilterIsMentor}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <CheckBox Content="{Binding [Admin_ManageUsers_Mentee], Source={x:Static loc:TranslationSource.Instance}}"
                                          IsChecked="{Binding FilterIsMentee}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <CheckBox Content="{Binding [Admin_ManageUsers_UnpairedOnly], Source={x:Static loc:TranslationSource.Instance}}"
                                          IsChecked="{Binding FilterUnpairedOnly}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding [Admin_ManageUsers_Grade], Source={x:Static loc:TranslationSource.Instance}}"
                                           VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <ComboBox ItemsSource="{Binding AvailableGrades}" SelectedItem="{Binding FilterMinGrade}"
                                          Width="70" Padding="4,2" Margin="0,0,4,0">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Grade_">
                                                        <Binding Path="."/>
                                                        <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text="{Binding [Admin_ManageUsers_To], Source={x:Static loc:TranslationSource.Instance}}"
                                           VerticalAlignment="Center" Margin="0,0,4,0"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <ComboBox ItemsSource="{Binding AvailableGrades}" SelectedItem="{Binding FilterMaxGrade}"
                                          Width="70" Padding="4,2">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Grade_">
                                                        <Binding Path="."/>
                                                        <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- User list -->
                    <ListView DockPanel.Dock="Top" BorderThickness="0" Padding="8,0,8,8"
                              ItemsSource="{Binding FilteredUsers}"
                              SelectedItem="{Binding SelectedUser}"
                              HorizontalContentAlignment="Stretch">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="row" CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="row" Property="Background" Value="#F8FAFF"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="row" Property="Background" Value="{StaticResource HoverLightBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type apiModel:UserResponse}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <components:ProfilePictureControl Grid.Column="0"
                                        Width="40" Height="40" Margin="0,0,12,0"
                                        VerticalAlignment="Center"
                                        ImagePath="{Binding ProfilePicturePath}"
                                        Gender="{Binding Gender}"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding UserName}" FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Email}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                        <TextBlock Text="{Binding Role}" Foreground="{StaticResource TextHintBrush}" FontSize="11"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>
            </Border>

            <!-- RIGHT: Details Sidebar -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                <DockPanel>
                    <!-- Card header -->
                    <Border DockPanel.Dock="Top" Padding="20,14" Background="#EBF5FF"
                            BorderThickness="0,0,0,1" BorderBrush="#BBDEFB" CornerRadius="12,12,0,0">
                        <DockPanel>
                            <Border Width="4" Height="18" Background="{StaticResource PrimaryBrush}" CornerRadius="2"
                                    VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Style="{StaticResource CardHeader}"
                                       Text="{Binding [Admin_ManageUsers_DetailsHeader], Source={x:Static loc:TranslationSource.Instance}}"/>
                        </DockPanel>
                    </Border>

                    <Grid DockPanel.Dock="Top" Margin="16,12,16,16">
                        <!-- Null state -->
                        <TextBlock Text="{Binding [Admin_ManageUsers_SelectHint], Source={x:Static loc:TranslationSource.Instance}}"
                                   Foreground="{StaticResource TextHintBrush}" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                                   FontStyle="Italic">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedUser}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- User detail pane -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedUser}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>

                            <StackPanel DataContext="{Binding SelectedUser}">
                                <components:ProfilePictureControl Width="80" Height="80" Margin="0,0,0,10"
                                                                  ImagePath="{Binding ProfilePicturePath}"
                                                                  Gender="{Binding Gender}"
                                                                  HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding UserName}" FontWeight="Bold" FontSize="18"
                                           HorizontalAlignment="Center" Margin="0,0,0,4"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding Email}" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,0,0,16"/>

                                <!-- Account info card -->
                                <TextBlock Text="{Binding [Admin_ManageUsers_AccountInfo], Source={x:Static loc:TranslationSource.Instance}}"
                                           FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <Border BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                                        Padding="12,10" Background="#FAFCFF" CornerRadius="8" Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding [Admin_ManageUsers_NationalId], Source={x:Static loc:TranslationSource.Instance}}"
                                                   FontWeight="SemiBold" FontSize="12" Grid.Column="0" Margin="0,0,10,0"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding NationalId}" Grid.Column="1" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </Grid>
                                </Border>

                                <!-- Supervisor class assignment -->
                                <StackPanel Margin="0,0,0,14"
                                            Visibility="{Binding DataContext.IsSupervisorSelected,
                                                RelativeSource={RelativeSource AncestorType=UserControl},
                                                Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Assigned Classes" FontWeight="SemiBold" FontSize="12"
                                               Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <Border BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                                            Padding="10" Background="#FAFCFF" CornerRadius="8" MaxHeight="200">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <ScrollViewer Grid.Row="0" Margin="0,0,0,8" VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding DataContext.SelectableClasses,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsSelected}" Margin="0,3"
                                                                      Content="{Binding Class.DisplayName}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                            <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="Save Classes"
                                                        Command="{Binding DataContext.SaveSupervisorClassCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        Style="{StaticResource PrimaryButtonStyle}" Padding="8,4"/>
                                                <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                                                           Text="{Binding DataContext.SupervisorClassSaveStatus,
                                                               RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.SupervisorClassSaveIsError,
                                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    Value="True">
                                                                    <Setter Property="Foreground" Value="#C62828"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <Separator Background="{StaticResource BorderLightBrush}" Margin="0,4,0,12"/>

                                <TextBlock Text="{Binding [Admin_ManageUsers_Actions], Source={x:Static loc:TranslationSource.Instance}}"
                                           FontWeight="SemiBold" FontSize="12" Margin="0,0,0,10"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <Button Content="{Binding [Admin_ManageUsers_FullProfile], Source={x:Static loc:TranslationSource.Instance}}"
                                        Command="{Binding DataContext.ViewUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,0,8" Padding="5,8" HorizontalAlignment="Stretch"/>
                                <Button Content="{Binding [Admin_ManageUsers_DeleteUser], Source={x:Static loc:TranslationSource.Instance}}"
                                        Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Background="#FFEDD4D4" Foreground="#8A1515" BorderBrush="#8A1515"
                                        Cursor="Hand"
                                        ToolTip="{Binding [ManageUsers_DeleteUser_Tooltip], Source={x:Static loc:TranslationSource.Instance}}"
                                        Padding="5,8" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ══ STUDENT IMPORT INFO POPUP ════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="White" CornerRadius="12"
                BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                Visibility="{Binding IsStudentInfoVisible, Converter={StaticResource BoolToVis}}"
                HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24">
            <Border.Effect>
                <DropShadowEffect Color="#9EB4CB" Opacity="0.25" BlurRadius="16" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="{Binding [Admin_ManageUsers_StudentInstructions], Source={x:Static loc:TranslationSource.Instance}}"
                           FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding [Admin_ManageUsers_ExcelFormat], Source={x:Static loc:TranslationSource.Instance}}"
                           Margin="0,0,0,5" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding [Admin_ManageUsers_ColANationalId], Source={x:Static loc:TranslationSource.Instance}}"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding [Admin_ManageUsers_ColBEmail], Source={x:Static loc:TranslationSource.Instance}}"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding [Admin_ManageUsers_ColCUserName], Source={x:Static loc:TranslationSource.Instance}}"
                           Margin="0,0,0,16" Foreground="{StaticResource TextSecondaryBrush}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding DownloadStudentTemplateCommand}"
                            Content="{Binding [Admin_ManageUsers_DownloadTemplate], Source={x:Static loc:TranslationSource.Instance}}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                    <Button Command="{Binding CloseStudentInfoCommand}"
                            Content="{Binding [Admin_ManageUsers_Close], Source={x:Static loc:TranslationSource.Instance}}"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══ SUPERVISOR IMPORT INFO POPUP ══════════════════════════════════ -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="White" CornerRadius="12"
                BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                Visibility="{Binding IsSupervisorInfoVisible, Converter={StaticResource BoolToVis}}"
                HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24">
            <Border.Effect>
                <DropShadowEffect Color="#9EB4CB" Opacity="0.25" BlurRadius="16" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="{Binding [Admin_ManageUsers_SupervisorInstructions], Source={x:Static loc:TranslationSource.Instance}}"
                           FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding [Admin_ManageUsers_ExcelFormat], Source={x:Static loc:TranslationSource.Instance}}"
                           Margin="0,0,0,5" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding [Admin_ManageUsers_ColANationalId], Source={x:Static loc:TranslationSource.Instance}}"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding [Admin_ManageUsers_ColBEmail], Source={x:Static loc:TranslationSource.Instance}}"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding [Admin_ManageUsers_ColCUserName], Source={x:Static loc:TranslationSource.Instance}}"
                           Margin="0,0,0,16" Foreground="{StaticResource TextSecondaryBrush}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding DownloadSupervisorTemplateCommand}"
                            Content="{Binding [Admin_ManageUsers_DownloadTemplate], Source={x:Static loc:TranslationSource.Instance}}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                    <Button Command="{Binding CloseSupervisorInfoCommand}"
                            Content="{Binding [Admin_ManageUsers_Close], Source={x:Static loc:TranslationSource.Instance}}"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
