<UserControl
    x:Class="MentoringApp.View.Admin.Overview.PhaseActionsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="clr-namespace:MentoringApp.ViewModel.Localization;assembly=MentoringApp.ViewModel"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <UserControl.Resources>
        <Style x:Key="ActionsCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.03" ShadowDepth="2" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="DeadlineTemplate">
            <StackPanel>
                <!-- No deadline -->
                <StackPanel Visibility="{Binding IsDeadlineNotScheduled, Converter={StaticResource BoolToVis}}" Margin="0,0,0,6">
                    <TextBlock Text="{Binding [Admin_Phase_Deadline_Label], Source={x:Static loc:TranslationSource.Instance}}"
                               Foreground="#6B7280" FontSize="12" Margin="0,0,0,8"/>
                    <DatePicker SelectedDate="{Binding DeadlineInput, Mode=TwoWay}" Margin="0,0,0,12"/>
                    <Button Content="{Binding [Admin_Phase_SetDeadline_Button], Source={x:Static loc:TranslationSource.Instance}}"
                            Background="#7C3AED" Foreground="White" FontWeight="SemiBold" Padding="0,8" BorderThickness="0"
                            Command="{Binding SaveDeadlineCommand}">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <!-- Deadline active -->
                <StackPanel Visibility="{Binding IsDeadlineScheduled, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding [Admin_Phase_TimeRemaining_Label], Source={x:Static loc:TranslationSource.Instance}}"
                               Foreground="#6B7280" FontSize="12" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding DeadlineTimeRemaining}"
                               FontSize="22" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,12"/>
                    <Button Content="{Binding [Admin_Phase_CancelDeadline_Button], Source={x:Static loc:TranslationSource.Instance}}"
                            Background="#F3F4F6" Foreground="#4B5563" FontWeight="Medium" Padding="0,8" BorderThickness="0"
                            Command="{Binding CancelDeadlineCommand}">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Border>
        <Border.Style>
            <Style TargetType="Border" BasedOn="{StaticResource ActionsCardStyle}">
                <Setter Property="Visibility" Value="Visible"/>
                <Setter Property="Margin" Value="0,0,0,24"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Progress.IsProcessComplete}" Value="True">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <StackPanel>
            <TextBlock Text="{Binding [Admin_PhaseDeadlines_Label], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="Bold" FontSize="18" Foreground="#111827" Margin="0,0,0,20"/>

            <!-- Deadline section: only meaningful once registration starts -->
            <ContentControl Content="{Binding}" ContentTemplate="{StaticResource DeadlineTemplate}">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Progress.IsRegistrationStepActive}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Progress.IsMentorSelectionStepActive}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>

            <TextBlock Text="{Binding [Admin_ProcessComplete_NoDeadlines_Label], Source={x:Static loc:TranslationSource.Instance}}" Foreground="#6B7280" FontStyle="Italic" TextWrapping="Wrap"
                       Visibility="{Binding Progress.IsProcessComplete, Converter={StaticResource BoolToVis}}"/>

            <TextBlock Text="{Binding [Admin_NoDeadlinesYet_Label], Source={x:Static loc:TranslationSource.Instance}}" Foreground="#6B7280" FontStyle="Italic" TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Progress.IsSchoolConfigStepActive}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Progress.IsImportStepActive}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Rectangle Height="1" Fill="#E5E7EB" Margin="0,20">
                <Rectangle.Style>
                    <Style TargetType="Rectangle">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Progress.IsProcessComplete}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Rectangle.Style>
            </Rectangle>
            <TextBlock Text="{Binding [Admin_PhaseActions_Label], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="Bold" FontSize="16" Foreground="#111827" Margin="0,0,0,16">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Progress.IsProcessComplete}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Progress.IsProcessComplete}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <!-- School config: hint while user is adding classes -->
                <TextBlock Text="{Binding [Admin_SchoolConfig_InProgress_Hint], Source={x:Static loc:TranslationSource.Instance}}"
                           Foreground="#6B7280" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"
                           Visibility="{Binding Progress.IsSchoolConfigStepActive, Converter={StaticResource BoolToVis}}"/>

                <Button Content="{Binding [Admin_CompleteSchoolConfig_Button], Source={x:Static loc:TranslationSource.Instance}}" Padding="0,10"
                        Background="#A855F7" Foreground="White" FontWeight="SemiBold" BorderThickness="0"
                        Visibility="{Binding Progress.IsSchoolConfigStepActive, Converter={StaticResource BoolToVis}}"
                        IsEnabled="{Binding CanCompleteSchoolConfig}"
                        Command="{Binding CompleteSchoolConfigCommand}">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                </Button>

                <Button Content="{Binding [Admin_CompleteSupervisorAssignment_Button], Source={x:Static loc:TranslationSource.Instance}}" Padding="0,10"
                        Background="#A855F7" Foreground="White" FontWeight="SemiBold" BorderThickness="0"
                        Visibility="{Binding Progress.IsSupervisorAssignmentStepActive, Converter={StaticResource BoolToVis}}"
                        IsEnabled="{Binding SupervisorAssignment.AllClassesAssigned}"
                        Command="{Binding CompleteSupervisorAssignmentCommand}">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                </Button>

                <Button Content="{Binding [Admin_BeginRegistration_Button], Source={x:Static loc:TranslationSource.Instance}}" Padding="0,10"
                        Background="#10B981" Foreground="White" FontWeight="SemiBold" BorderThickness="0"
                        Visibility="{Binding Progress.IsImportStepActive, Converter={StaticResource BoolToVis}}"
                        Command="{Binding MarkUsersImportedCommand}">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                </Button>

                <Button Content="{Binding [Admin_StartSelectionStage_Button], Source={x:Static loc:TranslationSource.Instance}}" Padding="0,10"
                        Background="#3B82F6" Foreground="White" FontWeight="SemiBold" BorderThickness="0"
                        Visibility="{Binding Progress.IsRegistrationStepActive, Converter={StaticResource BoolToVis}}"
                        Command="{Binding StartSelectionPhaseCommand}">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                </Button>

                <Button Content="{Binding [Admin_StartActiveMentoring_Button], Source={x:Static loc:TranslationSource.Instance}}" Padding="0,10"
                        Background="#8B5CF6" Foreground="White" FontWeight="SemiBold" BorderThickness="0"
                        Visibility="{Binding Progress.IsMentorSelectionStepActive, Converter={StaticResource BoolToVis}}"
                        Command="{Binding RunAutoMatchCommand}">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                </Button>
            </StackPanel>

            <TextBlock Text="{Binding [Admin_ProcessComplete_Label], Source={x:Static loc:TranslationSource.Instance}}" Foreground="#10B981" FontWeight="Bold" HorizontalAlignment="Center"
                        Visibility="{Binding Progress.IsProcessComplete, Converter={StaticResource BoolToVis}}"/>

        </StackPanel>
    </Border>
</UserControl>
