<UserControl
    x:Class="MentoringApp.View.Admin.Overview.PhaseStepperView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="clr-namespace:MentoringApp.ViewModel.Localization;assembly=MentoringApp.ViewModel"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <Border Margin="0,0,0,24">
        <Border.Style>
            <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                <Setter Property="Visibility" Value="Visible"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Progress.IsProcessComplete}" Value="True">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <StackPanel>
            <!-- Simplified Horizontal Stepper -->
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Connecting Lines (background) -->
                <Rectangle Grid.Column="1" Height="3" Fill="#F3F4F6"/>
                <Rectangle Grid.Column="3" Height="3" Fill="#F3F4F6"/>
                <Rectangle Grid.Column="5" Height="3" Fill="#F3F4F6"/>
                <Rectangle Grid.Column="7" Height="3" Fill="#F3F4F6"/>
                <Rectangle Grid.Column="9" Height="3" Fill="#F3F4F6"/>

                <!-- Connecting Lines (filled when step complete) -->
                <Rectangle Grid.Column="1" Height="3" Fill="#A855F7" Visibility="{Binding Progress.IsSchoolConfigured, Converter={StaticResource BoolToVis}}"/>
                <Rectangle Grid.Column="3" Height="3" Fill="#A855F7" Visibility="{Binding Progress.IsUsersImported, Converter={StaticResource BoolToVis}}"/>
                <Rectangle Grid.Column="5" Height="3" Fill="#A855F7" Visibility="{Binding Progress.IsSupervisorsAssigned, Converter={StaticResource BoolToVis}}"/>
                <Rectangle Grid.Column="7" Height="3" Fill="#A855F7" Visibility="{Binding Progress.IsSelectionPhaseActive, Converter={StaticResource BoolToVis}}"/>
                <Rectangle Grid.Column="9" Height="3" Fill="#A855F7" Visibility="{Binding Progress.IsProcessComplete, Converter={StaticResource BoolToVis}}"/>

                <!-- Step 0: School Config -->
                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" HorizontalAlignment="Center" Background="#A855F7">
                    <TextBlock Text="✓" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"
                               Visibility="{Binding Progress.IsSchoolConfigured, Converter={StaticResource BoolToVis}}"/>
                </Border>

                <!-- Step 1: Import Users -->
                <Border Grid.Column="2" Width="36" Height="36" CornerRadius="18" HorizontalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#F3F4F6"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Progress.IsImportStepActive}" Value="True">
                                    <Setter Property="Background" Value="#A855F7"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Progress.IsUsersImported}" Value="True">
                                    <Setter Property="Background" Value="#A855F7"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="✓" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"
                               Visibility="{Binding Progress.IsUsersImported, Converter={StaticResource BoolToVis}}"/>
                </Border>

                <!-- Step 2: Assign Supervisors -->
                <Border Grid.Column="4" Width="36" Height="36" CornerRadius="18" HorizontalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#F3F4F6"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Progress.IsSupervisorAssignmentStepActive}" Value="True">
                                    <Setter Property="Background" Value="#A855F7"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Progress.IsSupervisorsAssigned}" Value="True">
                                    <Setter Property="Background" Value="#A855F7"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="✓" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"
                               Visibility="{Binding Progress.IsSupervisorsAssigned, Converter={StaticResource BoolToVis}}"/>
                </Border>

                <!-- Step 3: Registration -->
                <Border Grid.Column="6" Width="36" Height="36" CornerRadius="18" HorizontalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#F3F4F6"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Progress.IsRegistrationStepActive}" Value="True">
                                    <Setter Property="Background" Value="#A855F7"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Progress.IsSelectionPhaseActive}" Value="True">
                                    <Setter Property="Background" Value="#A855F7"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="✓" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"
                               Visibility="{Binding Progress.IsSelectionPhaseActive, Converter={StaticResource BoolToVis}}"/>
                </Border>

                <!-- Step 4: Selection -->
                <Border Grid.Column="8" Width="36" Height="36" CornerRadius="18" HorizontalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#F3F4F6"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Progress.IsMentorSelectionStepActive}" Value="True">
                                    <Setter Property="Background" Value="#A855F7"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Progress.IsProcessComplete}" Value="True">
                                    <Setter Property="Background" Value="#A855F7"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="✓" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"
                               Visibility="{Binding Progress.IsProcessComplete, Converter={StaticResource BoolToVis}}"/>
                </Border>

                <!-- Step 5: Complete -->
                <Border Grid.Column="10" Width="36" Height="36" CornerRadius="18" HorizontalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#F3F4F6"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Progress.IsProcessComplete}" Value="True">
                                    <Setter Property="Background" Value="#A855F7"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="✓" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"
                               Visibility="{Binding Progress.IsProcessComplete, Converter={StaticResource BoolToVis}}"/>
                </Border>
            </Grid>

            <Grid Margin="12,12,12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding [Admin_Step_SchoolConfig], Source={x:Static loc:TranslationSource.Instance}}" FontSize="11" TextWrapping="Wrap" Foreground="#6B7280" VerticalAlignment="Center"/>
                    <Button Content="?" Width="16" Height="16" FontSize="10" Margin="4,0,0,0" Padding="0" Background="#E5E7EB" Foreground="#4B5563" BorderThickness="0" FontWeight="Bold" Cursor="Hand" Command="{Binding ShowPhaseInfoCommand}" CommandParameter="SchoolConfig">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding [Admin_Step_ImportUsers], Source={x:Static loc:TranslationSource.Instance}}" FontSize="11" TextWrapping="Wrap" Foreground="#6B7280" VerticalAlignment="Center"/>
                    <Button Content="?" Width="16" Height="16" FontSize="10" Margin="4,0,0,0" Padding="0" Background="#E5E7EB" Foreground="#4B5563" BorderThickness="0" FontWeight="Bold" Cursor="Hand" Command="{Binding ShowPhaseInfoCommand}" CommandParameter="Import" ToolTip="{Binding [Admin_ImportUsersInfo_Tooltip], Source={x:Static loc:TranslationSource.Instance}}">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding [Admin_Step_AssignSupervisors], Source={x:Static loc:TranslationSource.Instance}}" FontSize="11" TextWrapping="Wrap" Foreground="#6B7280" VerticalAlignment="Center"/>
                    <Button Content="?" Width="16" Height="16" FontSize="10" Margin="4,0,0,0" Padding="0" Background="#E5E7EB" Foreground="#4B5563" BorderThickness="0" FontWeight="Bold" Cursor="Hand" Command="{Binding ShowPhaseInfoCommand}" CommandParameter="SupervisorAssignment">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
                <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding [Admin_Step_Registration], Source={x:Static loc:TranslationSource.Instance}}" FontSize="11" TextWrapping="Wrap" Foreground="#6B7280" VerticalAlignment="Center"/>
                    <Button Content="?" Width="16" Height="16" FontSize="10" Margin="4,0,0,0" Padding="0" Background="#E5E7EB" Foreground="#4B5563" BorderThickness="0" FontWeight="Bold" Cursor="Hand" Command="{Binding ShowPhaseInfoCommand}" CommandParameter="Phase1" ToolTip="{Binding [Admin_Phase1Info_Tooltip], Source={x:Static loc:TranslationSource.Instance}}">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
                <StackPanel Grid.Column="8" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding [Admin_Step_Selection], Source={x:Static loc:TranslationSource.Instance}}" FontSize="11" TextWrapping="Wrap" Foreground="#6B7280" VerticalAlignment="Center"/>
                    <Button Content="?" Width="16" Height="16" FontSize="10" Margin="4,0,0,0" Padding="0" Background="#E5E7EB" Foreground="#4B5563" BorderThickness="0" FontWeight="Bold" Cursor="Hand" Command="{Binding ShowPhaseInfoCommand}" CommandParameter="Phase2" ToolTip="{Binding [Admin_Phase2Info_Tooltip], Source={x:Static loc:TranslationSource.Instance}}">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
                <StackPanel Grid.Column="10" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding [Admin_Step_Complete], Source={x:Static loc:TranslationSource.Instance}}" FontSize="11" TextWrapping="Wrap" Foreground="#6B7280" VerticalAlignment="Center"/>
                    <Button Content="?" Width="16" Height="16" FontSize="10" Margin="4,0,0,0" Padding="0" Background="#E5E7EB" Foreground="#4B5563" BorderThickness="0" FontWeight="Bold" Cursor="Hand" Command="{Binding ShowPhaseInfoCommand}" CommandParameter="Phase3" ToolTip="{Binding [Admin_Phase3Info_Tooltip], Source={x:Static loc:TranslationSource.Instance}}">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
