<UserControl
    x:Class="MentoringApp.View.Admin.Overview.NoticeBoardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="clr-namespace:MentoringApp.ViewModel.Localization;assembly=MentoringApp.ViewModel"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <UserControl.Resources>
        <Style x:Key="NoticeCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.03" ShadowDepth="2" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource NoticeCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="{Binding [Admin_NoticeBoard_Label], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="Bold" FontSize="18" Foreground="#111827" VerticalAlignment="Center"/>
                <Border Background="#EF4444" CornerRadius="10" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Visibility="{Binding HasForwardedIssues, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ForwardedIssues.Count}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                </Border>
            </DockPanel>

            <ListView Grid.Row="1" ItemsSource="{Binding ForwardedIssues}" BorderThickness="0" Background="Transparent"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,16"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnForwardedIssueClick"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#F9FAFB" CornerRadius="12" Padding="16">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,8">
                                    <Border Background="#FEF3C7" CornerRadius="4" Padding="6,2" DockPanel.Dock="Left">
                                        <TextBlock Text="{Binding Category.Name}" Foreground="#D97706" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                    <TextBlock Text="{Binding [Admin_NewIssue_Label], Source={x:Static loc:TranslationSource.Instance}}" Foreground="#9CA3AF" FontSize="11" HorizontalAlignment="Right"/>
                                </DockPanel>
                                <TextBlock Text="{Binding Description}" FontSize="13" Foreground="#374151" TextWrapping="Wrap" MaxHeight="40" TextTrimming="CharacterEllipsis" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding AuthorName, StringFormat='By - {0}'}" FontSize="12" Foreground="#6B7280"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock Grid.Row="1" Text="{Binding [Admin_NoNotices_Label], Source={x:Static loc:TranslationSource.Instance}}" Foreground="#9CA3AF" FontStyle="Italic" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding HasForwardedIssues, Converter={StaticResource InverseBoolToVis}}"/>
        </Grid>
    </Border>
</UserControl>
