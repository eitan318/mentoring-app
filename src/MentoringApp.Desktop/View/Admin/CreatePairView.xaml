<UserControl x:Class="MentoringApp.View.Admin.CreatePairView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:MentoringApp.Localization"
             mc:Ignorable="d" d:DesignHeight="400" d:DesignWidth="800"
             FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding [Admin_CreatePair_SearchSupervisor], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="Bold" Margin="0,0,0,8"/>
                <TextBox Grid.Row="1" Text="{Binding SupervisorSearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <ListBox Grid.Row="2" MinHeight="120" DisplayMemberPath="UserName"
                         ItemsSource="{Binding FilteredSupervisors}"
                         SelectedItem="{Binding SelectedSupervisor}" />
            </Grid>

            <Grid Grid.Column="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding [Admin_CreatePair_SearchMentor], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="Bold" Margin="0,0,0,8"/>
                <TextBox Grid.Row="1" Text="{Binding MentorSearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <ListBox Grid.Row="2" MinHeight="120" DisplayMemberPath="UserName"
                         ItemsSource="{Binding FilteredMentors}"
                         SelectedItem="{Binding SelectedMentor}" />
            </Grid>

            <Grid Grid.Column="2" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding [Admin_CreatePair_SearchMentee], Source={x:Static loc:TranslationSource.Instance}}" FontWeight="Bold" Margin="0,0,0,8"/>
                <TextBox Grid.Row="1" Text="{Binding MenteeSearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <ListBox Grid.Row="2" MinHeight="120" DisplayMemberPath="UserName"
                         ItemsSource="{Binding FilteredMentees}"
                         SelectedItem="{Binding SelectedMentee}" />
            </Grid>
        </Grid>

        <Button Grid.Row="1"
                Content="{Binding [Admin_CreatePair_Button], Source={x:Static loc:TranslationSource.Instance}}"
                Command="{Binding CreatePairCommand}"
                Padding="12,8"
                Margin="0,20,0,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                FontWeight="Bold"
                IsDefault="True"
                Cursor="Hand"
                ToolTip="Create a pair with the selected supervisor, mentor, and mentee"/>
    </Grid>
</UserControl>