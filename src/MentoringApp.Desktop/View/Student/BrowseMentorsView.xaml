<UserControl
    x:Class="MentoringApp.View.Student.BrowseMentorsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:components="clr-namespace:MentoringApp.View.Components"
    xmlns:loc="clr-namespace:MentoringApp.ViewModel.Localization;assembly=MentoringApp.ViewModel"
    xmlns:conv="clr-namespace:MentoringApp.Converter"
    mc:Ignorable="d"
    d:DesignHeight="600" d:DesignWidth="700"    
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, 
                   Path=FlowDirection, 
                   Converter={StaticResource FlowConverter}}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock FontSize="26" FontWeight="Bold" Text="{Binding [Browse_Header], Source={x:Static loc:TranslationSource.Instance}}"/>
            <TextBlock Foreground="#666" FontSize="13" TextWrapping="Wrap"
                       Text="{Binding [Browse_Description], Source={x:Static loc:TranslationSource.Instance}}"/>
        </StackPanel>

        <!-- Status message -->
        <Border Grid.Row="1" Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}}"
                Background="#E8F5E9" BorderBrush="#4CAF50" BorderThickness="1"
                CornerRadius="4" Padding="12,8" Margin="0,0,0,12">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#1B5E20" FontWeight="SemiBold" TextWrapping="Wrap"/>
        </Border>

        <!-- Loading indicator -->
        <TextBlock Grid.Row="2" Text="{Binding [Browse_Loading], Source={x:Static loc:TranslationSource.Instance}}" Foreground="#999"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" Margin="0,0,0,8"/>

        <!-- Empty state -->
        <TextBlock x:Name="emptyMentors" Grid.Row="3" Text="{Binding [Browse_NoMentors], Source={x:Static loc:TranslationSource.Instance}}"
                   FontSize="12" Foreground="Gray" Margin="0,8,0,0">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Mentors.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Mentor cards list -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Mentors}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10" Padding="16" CornerRadius="8"
                                Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="6" Opacity="0.08"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Avatar -->
                                <components:ProfilePictureControl Grid.Column="0"
                                    Width="56" Height="56" Margin="0,0,14,0" VerticalAlignment="Center"
                                    ImagePath="{Binding ProfilePicturePath}"
                                    Gender="{Binding Gender}"/>

                                <!-- Info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding MentorName}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0"
                                                Visibility="{Binding SubjectName, Converter={StaticResource NullToVis}}">
                                        <TextBlock Text="{Binding [Browse_Teaches_Label], Source={x:Static loc:TranslationSource.Instance}}"
                                                   Foreground="#555" FontSize="12" Margin="0,0,4,0"/>
                                        <TextBlock FontWeight="Medium" Foreground="#555" FontSize="12">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Subject_">
                                                    <Binding Path="SubjectName"/>
                                                    <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Foreground="#777" FontSize="12" Margin="0,2,0,0">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource GradeClassDisplay}">
                                                <Binding Path="GradeName"/>
                                                <Binding Path="ClassNum"/>
                                                <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Send Request button (shown when no pending request) -->
                                <Button Grid.Column="2" VerticalAlignment="Center"
                                        Padding="14,8" FontWeight="SemiBold"
                                        Background="#1976D2" Foreground="White"
                                        BorderThickness="0"
                                        Visibility="{Binding HasPendingRequest, Converter={StaticResource InverseBoolToVis}}"
                                        Command="{Binding DataContext.SendRequestCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="{Binding [Browse_SendRequest_Button], Source={x:Static loc:TranslationSource.Instance}}"/>
                                </Button>

                                <!-- Cancel Request button (shown when a pending request exists) -->
                                <Button Grid.Column="2" VerticalAlignment="Center"
                                        Padding="14,8" FontWeight="SemiBold"
                                        Background="#D32F2F" Foreground="White"
                                        BorderThickness="0"
                                        Visibility="{Binding HasPendingRequest, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding DataContext.CancelRequestCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="{Binding [Browse_CancelRequest_Button], Source={x:Static loc:TranslationSource.Instance}}"/>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
