<UserControl
    x:Class="MentoringApp.View.Student.AddIssueView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MentoringApp.View.Student"
    xmlns:loc="clr-namespace:MentoringApp.ViewModel.Localization;assembly=MentoringApp.ViewModel"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <UserControl.Resources>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#A855F7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#9333EA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F4F7FE" FocusManager.FocusedElement="{Binding ElementName=descriptionInput}">
        <Border
            Background="White"
            CornerRadius="16"
            Padding="28"
            MaxWidth="480"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.06" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="#111827"
                    Margin="0,0,0,20"
                    Text="{Binding [Issue_Title], Source={x:Static loc:TranslationSource.Instance}}" />

                <TextBlock
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="#374151"
                    Margin="0,0,0,6"
                    Text="{Binding [Issue_Description_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                <TextBox
                    x:Name="descriptionInput"
                    Padding="10,8"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    FontSize="14"
                    Margin="0,0,0,16"
                    Tag="{Binding [Issue_Description_Label], Source={x:Static loc:TranslationSource.Instance}}"
                    Text="{Binding IssueDescription, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip="Describe the issue you are experiencing" />

                <TextBlock
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="#374151"
                    Margin="0,0,0,6"
                    Text="{Binding [Issue_Category_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                <ComboBox
                    Margin="0,0,0,24"
                    ItemsSource="{Binding IssueCategoryList}"
                    SelectedItem="{Binding SelectedIssueCategory, ValidatesOnDataErrors=True}"
                    Tag="{Binding [Issue_Category_Label], Source={x:Static loc:TranslationSource.Instance}}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Category_">
                                        <Binding Path="Name" />
                                        <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Button
                    HorizontalAlignment="Right"
                    Style="{StaticResource PrimaryBtn}"
                    Command="{Binding AddIssueCommand}"
                    Content="{Binding [Issue_Submit_Button], Source={x:Static loc:TranslationSource.Instance}}"
                    IsDefault="True" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
