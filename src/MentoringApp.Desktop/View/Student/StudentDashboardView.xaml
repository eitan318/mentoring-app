<UserControl
    x:Class="MentoringApp.View.Student.StudentHomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:MentoringApp.View.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:loc="clr-namespace:MentoringApp.ViewModel.Localization;assembly=MentoringApp.ViewModel"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:studentvm="clr-namespace:MentoringApp.ViewModel.ViewModel.Student;assembly=MentoringApp.ViewModel"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, 
                   Path=FlowDirection, 
                   Converter={StaticResource FlowConverter}}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#A855F7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#9333EA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Background" Value="#FEF2F2"/>
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FECACA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabItemStyle" TargetType="ListBoxItem">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="12,14"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#A855F7"/>
                                <Setter Property="Foreground" Value="#A855F7"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F9FAFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F4F7FE">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
        </Grid.RowDefinitions>

        <!-- ══ ROW 0: Phase banner ══ -->
        <Border Grid.Row="0" Margin="24,16,24,0" Padding="16,14" CornerRadius="12"
                Background="{Binding BannerColor}"
                Visibility="{Binding IsPhaseBannerVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock FontSize="15" FontWeight="Bold"
                               Foreground="{Binding BannerTextColor}" Text="{Binding BannerTitle}" />
                    <Button Margin="6,0,0,0" Background="Transparent" BorderThickness="0"
                            Command="{Binding ShowPhaseInfoCommand}" Content="🛈"
                            Cursor="Hand" FontSize="14" Foreground="{Binding BannerTextColor}"
                            ToolTip="Click for details about the current phase" />
                </StackPanel>
                <TextBlock Margin="0,0,0,4" FontSize="12" Opacity="0.9"
                           Foreground="{Binding BannerTextColor}" Text="{Binding BannerSubtitle}"
                           TextWrapping="Wrap" />
                <TextBlock FontSize="13" FontWeight="SemiBold"
                           Foreground="{Binding BannerTextColor}" Text="{Binding BannerTimer}" />
            </StackPanel>
        </Border>

        <!-- ══ ROW 1: Tab bar ══ -->
        <Border Grid.Row="1" Background="White" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
            <ListBox
                BorderThickness="0"
                Background="Transparent"
                Padding="16,0,16,0"
                ItemsSource="{Binding Pairs}"
                SelectedItem="{Binding SelectedPair}"
                ItemContainerStyle="{StaticResource TabItemStyle}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <ContentControl Content="{Binding}">
                            <ContentControl.Resources>
                                <DataTemplate DataType="{x:Type studentvm:MentorDashboardViewModel}">
                                    <StackPanel Orientation="Horizontal">
                                        <components:ProfilePictureControl
                                            Width="28" Height="28" Margin="0,0,6,0"
                                            ImagePath="{Binding Counterpart.ProfilePicturePath}"
                                            Gender="{Binding Counterpart.Gender}" />
                                        <TextBlock VerticalAlignment="Center" FontSize="13" FontWeight="Medium"
                                                   Text="{Binding Counterpart.UserName}" />
                                    </StackPanel>
                                </DataTemplate>
                                <DataTemplate DataType="{x:Type studentvm:MenteeDashboardViewModel}">
                                    <StackPanel Orientation="Horizontal">
                                        <components:ProfilePictureControl
                                            Width="28" Height="28" Margin="0,0,6,0"
                                            ImagePath="{Binding Counterpart.ProfilePicturePath}"
                                            Gender="{Binding Counterpart.Gender}" />
                                        <TextBlock VerticalAlignment="Center" FontSize="13" FontWeight="Medium"
                                                   Text="{Binding Counterpart.UserName}" />
                                    </StackPanel>
                                </DataTemplate>
                                <DataTemplate DataType="{x:Type studentvm:BrowseMentorsViewModel}">
                                    <TextBlock FontSize="13" FontWeight="Medium" Text="{Binding TabLabel}" />
                                </DataTemplate>
                                <DataTemplate DataType="{x:Type studentvm:SelectionGalleryViewModel}">
                                    <TextBlock FontSize="13" FontWeight="Medium" Text="{Binding TabLabel}" />
                                </DataTemplate>
                                <DataTemplate DataType="{x:Type studentvm:MentorRequestsViewModel}">
                                    <TextBlock FontSize="13" FontWeight="Medium" Text="{Binding TabLabel}" />
                                </DataTemplate>
                            </ContentControl.Resources>
                        </ContentControl>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- ══ ROW 2: Tab content ══ -->
        <ContentControl Grid.Row="2" Content="{Binding SelectedPair}">
            <ContentControl.Resources>

                <!-- ── Mentor dashboard ── -->
                <DataTemplate DataType="{x:Type studentvm:MentorDashboardViewModel}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24,16">

                            <!-- Counterpart header card -->
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                                <DockPanel>
                                    <!-- Action buttons (right) -->
                                    <StackPanel DockPanel.Dock="Right" Margin="16,0,0,0" VerticalAlignment="Top">
                                        <Button Margin="0,0,0,8" MinWidth="140"
                                                Style="{StaticResource PrimaryBtn}"
                                                Command="{Binding CreateReviewCommand}"
                                                Content="{Binding [Student_WriteReview_Button], Source={x:Static loc:TranslationSource.Instance}}" />
                                        <Button MinWidth="140"
                                                Style="{StaticResource SecondaryBtn}"
                                                Command="{Binding IssueToSupervisorCommand}"
                                                Content="{Binding [Student_ReportIssue_Button], Source={x:Static loc:TranslationSource.Instance}}" />
                                    </StackPanel>

                                    <!-- Left: name + progress -->
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock FontSize="20" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,2">
                                            <Hyperlink Command="{Binding NavigateToProfileCommand}"
                                                       Foreground="#A855F7" TextDecorations="None">
                                                <Run Text="{Binding Counterpart.UserName}" />
                                            </Hyperlink>
                                        </TextBlock>
                                        <TextBlock Foreground="#6B7280" FontSize="13" Margin="0,0,0,16"
                                                   Text="{Binding [Student_YourMentee_Label], Source={x:Static loc:TranslationSource.Instance}}" />

                                        <TextBlock FontSize="12" Foreground="#6B7280" Margin="0,0,0,6"
                                                   Text="{Binding [Student_MeetingHours_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Height="8" Background="#F3F4F6" CornerRadius="4" ClipToBounds="True">
                                                <ProgressBar Minimum="0" Maximum="100"
                                                             Value="{Binding HoursProgress, Mode=OneWay}"
                                                             Foreground="#A855F7" Background="Transparent" BorderThickness="0"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Margin="12,0,0,0" FontSize="12" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center">
                                                <Run Text="{Binding TotalMeetingHours, StringFormat='{}{0:0.#}'}" />
                                                <Run Text=" / " />
                                                <Run Text="{Binding RequiredMeetingHours, StringFormat='{}{0:0}'}" />
                                                <Run Text=" " />
                                                <Run Text="{Binding [Common_HoursUnit], Source={x:Static loc:TranslationSource.Instance}, Mode=OneWay}" />
                                            </TextBlock>
                                        </Grid>
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <!-- Recent reviews card -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,16"
                                               Text="{Binding [Student_RecentReviews_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                                    <ItemsControl ItemsSource="{Binding RecentReviews}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="0,12" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                                    <DockPanel>
                                                        <Border DockPanel.Dock="Right" Background="#ECFDF5" CornerRadius="12"
                                                                Padding="10,4" Margin="12,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock Foreground="#059669" FontSize="12" FontWeight="SemiBold">
                                                                <Run Text="{Binding AmountOfHours, StringFormat='{}{0:0.#}'}" />
                                                                <Run Text=" " />
                                                                <Run Text="{Binding [Common_HoursUnit], Source={x:Static loc:TranslationSource.Instance}, Mode=OneWay}" />
                                                            </TextBlock>
                                                        </Border>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                                                       Foreground="#374151" FontSize="14"/>
                                                            <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="#9CA3AF"
                                                                       Text="{Binding Date, StringFormat='{}{0:MMM d, yyyy}'}" />
                                                        </StackPanel>
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </DataTemplate>

                <!-- ── Mentee dashboard ── -->
                <DataTemplate DataType="{x:Type studentvm:MenteeDashboardViewModel}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24,16">

                            <!-- Counterpart header card -->
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                                <DockPanel>
                                    <!-- Action button (right) -->
                                    <StackPanel DockPanel.Dock="Right" Margin="16,0,0,0" VerticalAlignment="Top">
                                        <Button MinWidth="140"
                                                Style="{StaticResource SecondaryBtn}"
                                                Command="{Binding IssueToSupervisorCommand}"
                                                Content="{Binding [Student_RaiseIssue_Button], Source={x:Static loc:TranslationSource.Instance}}" />
                                    </StackPanel>

                                    <!-- Left: name + subject + progress -->
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock FontSize="20" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,2">
                                            <Hyperlink Command="{Binding NavigateToProfileCommand}"
                                                       Foreground="#A855F7" TextDecorations="None">
                                                <Run Text="{Binding Counterpart.UserName}" />
                                            </Hyperlink>
                                        </TextBlock>
                                        <TextBlock Foreground="#6B7280" FontSize="13" Margin="0,0,0,8"
                                                   Text="{Binding [Student_YourMentor_Label], Source={x:Static loc:TranslationSource.Instance}}" />

                                        <Border Background="#ECFDF5" CornerRadius="8" Padding="10,4" HorizontalAlignment="Left" Margin="0,0,0,16">
                                            <TextBlock Foreground="#059669" FontSize="12" FontWeight="SemiBold">
                                                <Run Text="{Binding [Student_ExpertIn_Label], Source={x:Static loc:TranslationSource.Instance}, Mode=OneWay}" />
                                                <Run Text=": " />
                                                <Run Text="{Binding MentorSubject}" />
                                            </TextBlock>
                                        </Border>

                                        <TextBlock FontSize="12" Foreground="#6B7280" Margin="0,0,0,6"
                                                   Text="{Binding [Student_MeetingHours_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Height="8" Background="#F3F4F6" CornerRadius="4" ClipToBounds="True">
                                                <ProgressBar Minimum="0" Maximum="100"
                                                             Value="{Binding HoursProgress, Mode=OneWay}"
                                                             Foreground="#A855F7" Background="Transparent" BorderThickness="0"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Margin="12,0,0,0" FontSize="12" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center">
                                                <Run Text="{Binding TotalMeetingHours, StringFormat='{}{0:0.#}'}" />
                                                <Run Text=" / " />
                                                <Run Text="{Binding RequiredMeetingHours, StringFormat='{}{0:0}'}" />
                                                <Run Text=" " />
                                                <Run Text="{Binding [Common_HoursUnit], Source={x:Static loc:TranslationSource.Instance}, Mode=OneWay}" />
                                            </TextBlock>
                                        </Grid>
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <!-- Mentor feedback card -->
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,16"
                                               Text="{Binding [Student_MentorFeedback_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                                    <ItemsControl ItemsSource="{Binding RecentReviews}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="0,12" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                                                   Foreground="#374151" FontSize="14"/>
                                                        <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="#9CA3AF"
                                                                   Text="{Binding Date, StringFormat='{}{0:MMM d, yyyy}'}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- My issues card -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,16"
                                               Text="{Binding [Student_MyIssues_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                                    <ItemsControl ItemsSource="{Binding MyIssues}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="0,10" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                                    <DockPanel>
                                                        <Border DockPanel.Dock="Right" Background="#F3F4F6" CornerRadius="8"
                                                                Padding="8,4" Margin="8,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#374151">
                                                                <TextBlock.Text>
                                                                    <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Category_">
                                                                        <Binding Path="Category.Name" />
                                                                        <Binding Path="CurrentCulture" Source="{x:Static loc:TranslationSource.Instance}" />
                                                                    </MultiBinding>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                        </Border>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Ellipse Width="8" Height="8" Fill="#DC2626" Margin="0,0,10,0"/>
                                                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                                                                       Foreground="#374151" FontSize="14"/>
                                                        </StackPanel>
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </DataTemplate>

                <!-- ── Browse mentors (Phase 1 mentee) ── -->
                <DataTemplate DataType="{x:Type studentvm:BrowseMentorsViewModel}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24,16">

                            <TextBlock FontSize="18" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,4"
                                       Text="{Binding [Student_AvailableMentors_Header], Source={x:Static loc:TranslationSource.Instance}}" />
                            <TextBlock FontSize="13" Foreground="#6B7280" Margin="0,0,0,16"
                                       Text="{Binding [Student_AvailableMentors_Desc], Source={x:Static loc:TranslationSource.Instance}}" />

                            <!-- Status message -->
                            <Border Margin="0,0,0,12" Background="#EFF6FF" CornerRadius="8" Padding="12,8"
                                    Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="#1D4ED8" TextWrapping="Wrap" />
                            </Border>

                            <!-- Loading -->
                            <TextBlock FontSize="13" Foreground="#9CA3AF" Margin="0,0,0,12"
                                       Text="{Binding [Student_Loading], Source={x:Static loc:TranslationSource.Instance}}"
                                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

                            <!-- Mentor list -->
                            <ItemsControl ItemsSource="{Binding Mentors}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F9FAFB" CornerRadius="12" Padding="16" Margin="0,0,0,8">
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right"
                                                        Style="{StaticResource PrimaryBtn}"
                                                        VerticalAlignment="Center"
                                                        Content="{Binding [Student_SendRequest_Button], Source={x:Static loc:TranslationSource.Instance}}"
                                                        Command="{Binding DataContext.SendRequestCommand,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" />
                                                <StackPanel Margin="0,0,12,0" VerticalAlignment="Center">
                                                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#111827"
                                                               Text="{Binding MentorName}" />
                                                    <TextBlock FontSize="12" Foreground="#6B7280" Margin="0,2,0,0">
                                                        <Run>
                                                            <Run.Text>
                                                                <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Subject_">
                                                                    <Binding Path="SubjectName"/>
                                                                    <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture"/>
                                                                </MultiBinding>
                                                            </Run.Text>
                                                        </Run>
                                                        <Run Text=" · " />
                                                        <Run>
                                                            <Run.Text>
                                                                <MultiBinding Converter="{StaticResource GradeClassDisplay}">
                                                                    <Binding Path="GradeName"/>
                                                                    <Binding Path="ClassNum"/>
                                                                    <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture"/>
                                                                </MultiBinding>
                                                            </Run.Text>
                                                        </Run>
                                                    </TextBlock>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                </DataTemplate>

                <!-- ── Selection gallery (Phase 2 mentee) ── -->
                <DataTemplate DataType="{x:Type studentvm:SelectionGalleryViewModel}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24,16">

                            <TextBlock FontSize="18" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,4"
                                       Text="{Binding [Student_TopMatches_Header], Source={x:Static loc:TranslationSource.Instance}}" />
                            <TextBlock FontSize="13" Foreground="#6B7280" Margin="0,0,0,16"
                                       Text="{Binding [Student_TopMatches_Desc], Source={x:Static loc:TranslationSource.Instance}}" />

                            <!-- Already matched banner -->
                            <Border Margin="0,0,0,12" Background="#ECFDF5" CornerRadius="8" Padding="12,8"
                                    Visibility="{Binding AlreadyMatched, Converter={StaticResource BoolToVis}}">
                                <TextBlock FontSize="13" Foreground="#059669" FontWeight="SemiBold"
                                           Text="{Binding [Student_AlreadyMatched_Banner], Source={x:Static loc:TranslationSource.Instance}}" />
                            </Border>

                            <!-- Status message -->
                            <Border Margin="0,0,0,12" Background="#EFF6FF" CornerRadius="8" Padding="12,8"
                                    Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="#1D4ED8" TextWrapping="Wrap" />
                            </Border>

                            <!-- Loading -->
                            <TextBlock FontSize="13" Foreground="#9CA3AF" Margin="0,0,0,12"
                                       Text="{Binding [Student_Loading], Source={x:Static loc:TranslationSource.Instance}}"
                                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

                            <!-- Recommendations -->
                            <ItemsControl ItemsSource="{Binding Recommendations}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="12" Color="#000000" Opacity="0.04" ShadowDepth="2" Direction="270"/>
                                            </Border.Effect>
                                            <DockPanel>
                                                <!-- Score badge -->
                                                <Border DockPanel.Dock="Right" Background="#EFF6FF" CornerRadius="12"
                                                        Padding="16,12" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock FontSize="22" FontWeight="Bold" Foreground="#3B82F6"
                                                                   HorizontalAlignment="Center"
                                                                   Text="{Binding ScorePercent, StringFormat='{}{0:0}%'}" />
                                                        <TextBlock FontSize="10" Foreground="#3B82F6"
                                                                   HorizontalAlignment="Center"
                                                                   Text="{Binding [Student_Match_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                                                    </StackPanel>
                                                </Border>
                                                <!-- Mentor info -->
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="#111827"
                                                               Text="{Binding MentorName}" />
                                                    <TextBlock FontSize="12" Foreground="#6B7280" Margin="0,2,0,12">
                                                        <TextBlock.Text>
                                                            <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Subject_">
                                                                <Binding Path="MentorSubjectName"/>
                                                                <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                    <Button Style="{StaticResource PrimaryBtn}"
                                                            HorizontalAlignment="Left"
                                                            Content="{Binding [Student_ChooseMentor_Button], Source={x:Static loc:TranslationSource.Instance}}"
                                                            IsEnabled="{Binding DataContext.AlreadyMatched,
                                                                RelativeSource={RelativeSource AncestorType=ItemsControl},
                                                                Converter={StaticResource InverseBoolConverter}}"
                                                            Command="{Binding DataContext.ChooseMentorCommand,
                                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                </DataTemplate>

                <!-- ── Mentor requests (Phase 1 mentor) ── -->
                <DataTemplate DataType="{x:Type studentvm:MentorRequestsViewModel}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <DockPanel Margin="24,16">

                            <!-- Footnote at bottom -->
                            <TextBlock DockPanel.Dock="Bottom" FontSize="12" Foreground="#9CA3AF" Margin="0,12,0,0"
                                       Text="{Binding [Student_AcceptCreates_Footnote], Source={x:Static loc:TranslationSource.Instance}}"
                                       Visibility="{Binding IsPhase2Active, Converter={StaticResource InverseBoolToVis}}"
                                       TextWrapping="Wrap" />

                            <StackPanel>
                                <TextBlock FontSize="18" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,4"
                                           Text="{Binding [Student_MentoringRequests_Header], Source={x:Static loc:TranslationSource.Instance}}" />

                                <TextBlock FontSize="13" Foreground="#6B7280" Margin="0,0,0,4"
                                           Text="{Binding [Student_MentoringRequests_Desc], Source={x:Static loc:TranslationSource.Instance}}"
                                           Visibility="{Binding IsPhase2Active, Converter={StaticResource InverseBoolToVis}}" />
                                <TextBlock FontSize="13" Foreground="#6B7280" Margin="0,0,0,4"
                                           Text="{Binding RequestWindowTimerDisplay}"
                                           Visibility="{Binding IsPhase2Active, Converter={StaticResource InverseBoolToVis}}" />
                                <TextBlock FontSize="13" Foreground="#6B7280" Margin="0,0,0,16"
                                           Text="{Binding [Student_Phase2_NoAction], Source={x:Static loc:TranslationSource.Instance}}"
                                           Visibility="{Binding IsPhase2Active, Converter={StaticResource BoolToVis}}" />

                                <!-- Status message -->
                                <Border Margin="0,0,0,12" Background="#EFF6FF" CornerRadius="8" Padding="12,8"
                                        Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="#1D4ED8" TextWrapping="Wrap" />
                                </Border>

                                <!-- Loading -->
                                <TextBlock FontSize="13" Foreground="#9CA3AF" Margin="0,0,0,12"
                                           Text="{Binding [Student_Loading], Source={x:Static loc:TranslationSource.Instance}}"
                                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

                                <!-- Request list -->
                                <ItemsControl ItemsSource="{Binding PendingRequests}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F9FAFB" CornerRadius="12" Padding="16" Margin="0,0,0,8">
                                                <DockPanel>
                                                    <!-- Accept / Decline only in Phase 1 -->
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"
                                                                Visibility="{Binding DataContext.IsPhase2Active,
                                                                    RelativeSource={RelativeSource AncestorType=ItemsControl},
                                                                    Converter={StaticResource InverseBoolToVis}}">
                                                        <Button Margin="0,0,8,0"
                                                                Style="{StaticResource PrimaryBtn}"
                                                                Content="{Binding [Student_Accept_Button], Source={x:Static loc:TranslationSource.Instance}}"
                                                                Command="{Binding DataContext.AcceptRequestCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}" />
                                                        <Button Style="{StaticResource DangerBtn}"
                                                                Content="{Binding [Student_Decline_Button], Source={x:Static loc:TranslationSource.Instance}}"
                                                                Command="{Binding DataContext.RejectRequestCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}" />
                                                    </StackPanel>
                                                    <!-- Mentee info -->
                                                    <StackPanel Margin="0,0,12,0" VerticalAlignment="Center">
                                                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#111827"
                                                                   Text="{Binding MenteeName}" />
                                                        <TextBlock FontSize="12" Foreground="#6B7280" Margin="0,2,0,0"
                                                                   Text="{Binding MenteeSubjectName}" />
                                                        <TextBlock FontSize="11" Foreground="#9CA3AF" Margin="0,2,0,0">
                                                            <Run Text="{Binding [Student_RequestedAt_Label], Source={x:Static loc:TranslationSource.Instance}, Mode=OneWay}" />
                                                            <Run Text=" " />
                                                            <Run Text="{Binding CreatedAt, StringFormat='{}{0:d}'}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DockPanel>
                    </ScrollViewer>
                </DataTemplate>

            </ContentControl.Resources>
        </ContentControl>

    </Grid>
</UserControl>
