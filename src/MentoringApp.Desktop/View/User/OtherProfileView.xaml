<UserControl x:Class="MentoringApp.View.User.OtherProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:components="clr-namespace:MentoringApp.View.Components"
             xmlns:loc="clr-namespace:MentoringApp.Localization"
             mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="400"
             FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}">

    <ScrollViewer Background="#F4F7FE" VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,40,24,40">
            <Border
                Background="White"
                CornerRadius="16"
                Padding="28"
                MaxWidth="420"
                HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.03" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <StackPanel>

                    <components:ProfilePictureControl
                        Width="96" Height="96"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,12"
                        ImagePath="{Binding User.ProfilePicturePath}"
                        Gender="{Binding User.Gender}" />

                    <TextBlock
                        Text="{Binding User.UserName}"
                        FontSize="24" FontWeight="Bold"
                        Foreground="#111827"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,4"/>

                    <TextBlock
                        Text="{Binding RoleName}"
                        FontSize="14" Foreground="#6B7280"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,20"/>

                    <Rectangle Height="1" Fill="#F3F4F6"/>

                    <!-- Email -->
                    <TextBlock
                        Text="{Binding [OtherProfile_Email_Label], Source={x:Static loc:TranslationSource.Instance}}"
                        FontSize="11" FontWeight="SemiBold" Foreground="#6B7280"
                        Margin="0,16,0,4"/>
                    <TextBlock
                        Text="{Binding User.Email}"
                        FontSize="15" Foreground="#374151" FontWeight="Medium"/>

                    <!-- Phone -->
                    <TextBlock
                        Text="{Binding [OtherProfile_PhoneNumber_Label], Source={x:Static loc:TranslationSource.Instance}}"
                        FontSize="11" FontWeight="SemiBold" Foreground="#6B7280"
                        Margin="0,16,0,4"/>
                    <TextBlock
                        Text="{Binding User.PhoneNumber}"
                        FontSize="15" Foreground="#374151" FontWeight="Medium"/>

                    <!-- Gender -->
                    <TextBlock
                        Text="{Binding [OtherProfile_Gender_Label], Source={x:Static loc:TranslationSource.Instance}}"
                        FontSize="11" FontWeight="SemiBold" Foreground="#6B7280"
                        Margin="0,16,0,4"/>
                    <TextBlock
                        Text="{Binding GenderDisplay}"
                        FontSize="15" Foreground="#374151" FontWeight="Medium"/>

                    <!-- Student-only section -->
                    <StackPanel Visibility="{Binding IsStudent, Converter={StaticResource BoolToVis}}">

                        <TextBlock
                            Text="{Binding [OtherProfile_Grade_Label], Source={x:Static loc:TranslationSource.Instance}}"
                            FontSize="11" FontWeight="SemiBold" Foreground="#6B7280"
                            Margin="0,16,0,4"/>
                        <TextBlock FontSize="15" Foreground="#374151" FontWeight="Medium">
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource GradeClassDisplay}">
                                    <Binding Path="GradeName"/>
                                    <Binding Path="ClassNum"/>
                                    <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <TextBlock
                            Text="{Binding [OtherProfile_PreferredMentorGender_Label], Source={x:Static loc:TranslationSource.Instance}}"
                            FontSize="11" FontWeight="SemiBold" Foreground="#6B7280"
                            Margin="0,16,0,4"/>
                        <TextBlock
                            Text="{Binding PreferredMentorGenderDisplay}"
                            FontSize="15" Foreground="#374151" FontWeight="Medium"/>

                        <TextBlock
                            Text="{Binding [OtherProfile_PreferredMenteeGender_Label], Source={x:Static loc:TranslationSource.Instance}}"
                            FontSize="11" FontWeight="SemiBold" Foreground="#6B7280"
                            Margin="0,16,0,4"/>
                        <TextBlock
                            Text="{Binding PreferredMenteeGenderDisplay}"
                            FontSize="15" Foreground="#374151" FontWeight="Medium"/>

                        <TextBlock
                            Text="{Binding [OtherProfile_MentoringDetails_Label], Source={x:Static loc:TranslationSource.Instance}}"
                            FontSize="11" FontWeight="SemiBold" Foreground="#6B7280"
                            Margin="0,16,0,4"/>
                        <Border Background="#F9FAFB" BorderBrush="#F3F4F6" BorderThickness="1" CornerRadius="8" Padding="12">
                            <StackPanel>
                                <TextBlock Text="{Binding TeachingSubject}" FontSize="14" Foreground="#374151" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding LearningSubject}" FontSize="14" Foreground="#374151"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
