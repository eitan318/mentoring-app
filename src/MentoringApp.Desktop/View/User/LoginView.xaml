<UserControl
    x:Class="MentoringApp.View.User.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MentoringApp.View.User"
    xmlns:loc="clr-namespace:MentoringApp.ViewModel.Localization;assembly=MentoringApp.ViewModel"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}"
    FocusManager.FocusedElement="{Binding ElementName=nationalIdInput}">
    <Grid Margin="20">
        <!-- Top-Right Language Picker -->
        <ComboBox
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Width="80"
            ItemsSource="{Binding AvailableLanguages}"
            SelectedItem="{Binding SelectedLanguage}"
            Margin="0,0,10,0"/>

        <!-- Centered Login Form -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Visibility="{Binding WasCodeSent, Converter={StaticResource InverseBoolToVis}}">
                <TextBlock Margin="0,0,0,6" Text="{Binding [Login_Step1], Source={x:Static loc:TranslationSource.Instance}}" />
                <TextBlock Margin="0,0,0,4"
                           Text="{Binding [Login_NationalId_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                <TextBox x:Name="nationalIdInput" Width="200" Margin="0,0,0,10" Text="{Binding NationalId, UpdateSourceTrigger=PropertyChanged}" />
                <Button
                    Padding="10,6"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Right"
                    Cursor="Hand"
                    IsDefault="True"
                    ToolTip="{Binding [Login_SendCode_Tooltip], Source={x:Static loc:TranslationSource.Instance}}"
                    Command="{Binding SendVerificationCodeCommand}"
                    Content="{Binding [Login_SendCode_Button], Source={x:Static loc:TranslationSource.Instance}}" />
                <TextBlock
                    MaxWidth="200"
                    Foreground="Red"
                    Text="{Binding ErrorMessage}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Visibility="{Binding WasCodeSent, Converter={StaticResource BoolToVis}}">
                <TextBlock Margin="0,0,0,6" Text="{Binding [Login_Step2], Source={x:Static loc:TranslationSource.Instance}}" />
                <TextBlock Margin="0,0,0,4"
                           Text="{Binding [Login_VerificationCode_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                <TextBox Width="200" Margin="0,0,0,10" Text="{Binding VerificationCode, UpdateSourceTrigger=PropertyChanged}" />
                <Button
                    Padding="10,6"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Right"
                    Cursor="Hand"
                    IsDefault="True"
                    ToolTip="{Binding [Login_VerifyCode_Tooltip], Source={x:Static loc:TranslationSource.Instance}}"
                    Command="{Binding LoginCommand}"
                    Content="{Binding [Login_Login_Button], Source={x:Static loc:TranslationSource.Instance}}" />
                <TextBlock
                    MaxWidth="200"
                    Foreground="Red"
                    Text="{Binding ErrorMessage}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>