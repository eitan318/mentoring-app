<UserControl
    x:Class="MentoringApp.View.User.MyProfileView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:MentoringApp.View.Components"
    xmlns:loc="clr-namespace:MentoringApp.Localization"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}"
    FocusManager.FocusedElement="{Binding ElementName=usernameInput}">

    <UserControl.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#A855F7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#9333EA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#059669"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer Background="#F4F7FE" VerticalScrollBarVisibility="Auto">
        <Grid Margin="40,32">
            <Border
                Background="White"
                CornerRadius="16"
                Padding="28"
                MaxWidth="520"
                HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.03" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <StackPanel>

                    <!-- Profile picture -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Grid Width="100" Height="100">
                            <components:ProfilePictureControl ImagePath="{Binding ProfilePicturePath}" Gender="{Binding Gender}" />
                            <Button
                                Width="28" Height="28"
                                VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                Background="#111827" Foreground="White"
                                BorderThickness="0"
                                Content="📷"
                                FontSize="14"
                                Cursor="Hand"
                                ToolTip="{Binding [Profile_ChangePhoto_Tooltip], Source={x:Static loc:TranslationSource.Instance}}"
                                Command="{Binding UploadProfilePictureCommand}" />
                        </Grid>
                        <TextBlock
                            Margin="0,6,0,0"
                            HorizontalAlignment="Center"
                            FontSize="12" Foreground="#6B7280"
                            Text="{Binding [Profile_ChangePhoto_Hint], Source={x:Static loc:TranslationSource.Instance}}" />
                    </StackPanel>

                    <!-- Role badge -->
                    <Border Background="#F0F4FF" BorderBrush="#C7D4F5" BorderThickness="1"
                            CornerRadius="12" Padding="14,4" Margin="0,0,0,24"
                            HorizontalAlignment="Center">
                        <TextBlock Text="{Binding RoleBadge}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#3B5BDB" />
                    </Border>

                    <!-- Username -->
                    <TextBlock Style="{StaticResource FieldLabel}"
                               Text="{Binding [Profile_Username_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                    <TextBox x:Name="usernameInput"
                             IsReadOnly="{Binding IsReadOnly}"
                             BorderBrush="#E5E7EB" BorderThickness="1" Padding="10,8" FontSize="14"
                             Margin="0,0,0,16"
                             Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

                    <!-- Email -->
                    <TextBlock Style="{StaticResource FieldLabel}"
                               Text="{Binding [Profile_Email_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                    <TextBox IsReadOnly="{Binding IsReadOnly}"
                             BorderBrush="#E5E7EB" BorderThickness="1" Padding="10,8" FontSize="14"
                             Margin="0,0,0,16"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

                    <!-- National ID (read-only) -->
                    <TextBlock Style="{StaticResource FieldLabel}"
                               Text="{Binding [Profile_NationalId_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                    <TextBox
                        Background="#F9FAFB"
                        Foreground="#6B7280"
                        IsReadOnly="True"
                        BorderBrush="#E5E7EB" BorderThickness="1" Padding="10,8" FontSize="14"
                        Margin="0,0,0,16"
                        Text="{Binding NationalId, Mode=OneWay}" />

                    <!-- Phone -->
                    <TextBlock Style="{StaticResource FieldLabel}"
                               Text="{Binding [Profile_Phone_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                    <TextBox IsReadOnly="{Binding IsReadOnly}"
                             BorderBrush="#E5E7EB" BorderThickness="1" Padding="10,8" FontSize="14"
                             Margin="0,0,0,16"
                             Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" />

                    <!-- Gender -->
                    <TextBlock Style="{StaticResource FieldLabel}"
                               Text="{Binding [Profile_Gender_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                    <ComboBox
                        IsEnabled="{Binding IsEditMode}"
                        ItemsSource="{Binding GenderOptions}"
                        SelectedValue="{Binding SelectedGenderValue, UpdateSourceTrigger=PropertyChanged}"
                        SelectedValuePath="Value"
                        DisplayMemberPath="Display"
                        Margin="0,0,0,16" />

                    <!-- Student section -->
                    <StackPanel Visibility="{Binding IsSupervisor, Converter={StaticResource InverseBoolToVis}}">

                        <Rectangle Height="1" Fill="#F3F4F6" Margin="0,8,0,16"/>
                        <TextBlock Style="{StaticResource SectionHeader}"
                                   Text="{Binding [Profile_Grade_Label], Source={x:Static loc:TranslationSource.Instance}}" />

                        <TextBlock Style="{StaticResource FieldLabel}" Margin="0,12,0,4"
                                   Text="{Binding [Profile_Grade_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                        <ComboBox
                            TextSearch.TextPath="Name"
                            IsEnabled="{Binding IsEditMode}"
                            ItemsSource="{Binding Grades}"
                            SelectedItem="{Binding SelectedGrade, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                            Margin="0,0,0,16">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Grade_">
                                                <Binding Path="Name" />
                                                <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Style="{StaticResource FieldLabel}"
                                   Text="{Binding [Profile_ClassNum_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                        <TextBox IsReadOnly="{Binding IsReadOnly}"
                                 BorderBrush="#E5E7EB" BorderThickness="1" Padding="10,8" FontSize="14"
                                 Margin="0,0,0,16"
                                 Text="{Binding ClassNum, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

                        <!-- Mentor section -->
                        <StackPanel Visibility="{Binding HasMentorProfile, Converter={StaticResource BoolToVis}}">
                            <Rectangle Height="1" Fill="#F3F4F6" Margin="0,4,0,12"/>
                            <TextBlock Style="{StaticResource SectionHeader}"
                                       Text="{Binding [Profile_SubjectToTeach_Label], Source={x:Static loc:TranslationSource.Instance}}" />

                            <TextBlock Style="{StaticResource FieldLabel}" Margin="0,12,0,4"
                                       Text="{Binding [Profile_SubjectToTeach_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                            <ComboBox
                                TextSearch.TextPath="Name"
                                IsEnabled="{Binding IsEditMode}"
                                ItemsSource="{Binding Subjects}"
                                SelectedValue="{Binding SubjectToTeach, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                SelectedValuePath="Id"
                                Margin="0,0,0,16">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Subject_">
                                                    <Binding Path="Name" />
                                                    <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Style="{StaticResource FieldLabel}"
                                       Text="{Binding [Profile_MaxMentees_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                            <TextBox IsReadOnly="{Binding IsReadOnly}"
                                     BorderBrush="#E5E7EB" BorderThickness="1" Padding="10,8" FontSize="14"
                                     Margin="0,0,0,16"
                                     Text="{Binding MaxMentees, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

                            <TextBlock Style="{StaticResource FieldLabel}"
                                       Text="{Binding [Profile_PreferredMenteeGender_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                            <ComboBox
                                IsEnabled="{Binding IsEditMode}"
                                ItemsSource="{Binding GenderPreferenceOptions}"
                                SelectedValue="{Binding SelectedPreferredMenteeGenderValue, UpdateSourceTrigger=PropertyChanged}"
                                SelectedValuePath="Value"
                                DisplayMemberPath="Display"
                                Margin="0,0,0,16" />
                        </StackPanel>

                        <!-- Mentee section -->
                        <StackPanel Visibility="{Binding HasMenteeProfile, Converter={StaticResource BoolToVis}}">
                            <Rectangle Height="1" Fill="#F3F4F6" Margin="0,4,0,12"/>
                            <TextBlock Style="{StaticResource SectionHeader}"
                                       Text="{Binding [Profile_SubjectToLearn_Label], Source={x:Static loc:TranslationSource.Instance}}" />

                            <TextBlock Style="{StaticResource FieldLabel}" Margin="0,12,0,4"
                                       Text="{Binding [Profile_SubjectToLearn_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                            <ComboBox
                                TextSearch.TextPath="Name"
                                IsEnabled="{Binding IsEditMode}"
                                ItemsSource="{Binding Subjects}"
                                SelectedValue="{Binding SubjectToLearn, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                SelectedValuePath="Id"
                                Margin="0,0,0,16">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Subject_">
                                                    <Binding Path="Name" />
                                                    <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Style="{StaticResource FieldLabel}"
                                       Text="{Binding [Profile_PreferredMentorGender_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                            <ComboBox
                                IsEnabled="{Binding IsEditMode}"
                                ItemsSource="{Binding GenderPreferenceOptions}"
                                SelectedValue="{Binding SelectedPreferredMentorGenderValue, UpdateSourceTrigger=PropertyChanged}"
                                SelectedValuePath="Value"
                                DisplayMemberPath="Display"
                                Margin="0,0,0,16" />
                        </StackPanel>

                    </StackPanel>

                    <!-- Action buttons -->
                    <Rectangle Height="1" Fill="#F3F4F6" Margin="0,8,0,16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button
                            Style="{StaticResource PrimaryBtn}"
                            ToolTip="{Binding [Profile_EditProfile_Tooltip], Source={x:Static loc:TranslationSource.Instance}}"
                            Command="{Binding ToggleEditCommand}"
                            Content="{Binding [Profile_EditProfile_Button], Source={x:Static loc:TranslationSource.Instance}}"
                            Visibility="{Binding IsReadOnly, Converter={StaticResource BoolToVis}}" />

                        <Button
                            Style="{StaticResource SaveBtn}"
                            ToolTip="{Binding [Profile_SaveChanges_Tooltip], Source={x:Static loc:TranslationSource.Instance}}"
                            Command="{Binding SaveCommand}"
                            Content="{Binding [Profile_SaveChanges_Button], Source={x:Static loc:TranslationSource.Instance}}"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>

                    <TextBlock
                        Margin="0,10,0,0"
                        HorizontalAlignment="Center"
                        Foreground="#DC2626"
                        Text="{Binding ErrorMessage}" />

                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
