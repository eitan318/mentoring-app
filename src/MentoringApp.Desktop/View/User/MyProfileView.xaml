<UserControl
    x:Class="MentoringApp.View.User.MyProfileView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:MentoringApp.View.Components"
    xmlns:loc="clr-namespace:MentoringApp.Localization"
    FlowDirection="{Binding Source={x:Static loc:TranslationSource.Instance}, Path=FlowDirection}"
    FocusManager.FocusedElement="{Binding ElementName=usernameInput}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <StackPanel>

                <!--  ── Profile Picture Section ──  -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Grid Width="100" Height="100">
                        <components:ProfilePictureControl ImagePath="{Binding ProfilePicturePath}" Gender="{Binding Gender}" />
                        <!--  Camera overlay button  -->
                        <Button
                            Width="28" Height="28"
                            VerticalAlignment="Bottom" HorizontalAlignment="Right"
                            Background="#444" Foreground="White"
                            BorderThickness="0"
                            Content="📷"
                            FontSize="14"
                            Cursor="Hand"
                            ToolTip="{Binding [Profile_ChangePhoto_Tooltip], Source={x:Static loc:TranslationSource.Instance}}"
                            Command="{Binding UploadProfilePictureCommand}" />
                    </Grid>
                    <TextBlock
                        Margin="0,6,0,0"
                        HorizontalAlignment="Center"
                        FontSize="12" Foreground="Gray"
                        Text="{Binding [Profile_ChangePhoto_Hint], Source={x:Static loc:TranslationSource.Instance}}" />
                </StackPanel>

                <!-- Role badge pill -->
                <Border Background="#F0F4FF" BorderBrush="#C7D4F5" BorderThickness="1"
                        CornerRadius="12" Padding="14,4" Margin="0,4,0,18"
                        HorizontalAlignment="Center">
                    <TextBlock Text="{Binding RoleBadge}" FontSize="13" FontWeight="SemiBold"
                               Foreground="#3B5BDB" />
                </Border>

                <Label Content="{Binding [Profile_Username_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                <TextBox x:Name="usernameInput" IsReadOnly="{Binding IsReadOnly}" Margin="0,0,0,8"
                         Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

                <Label Content="{Binding [Profile_Email_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                <TextBox IsReadOnly="{Binding IsReadOnly}" Margin="0,0,0,8"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

                <Label Content="{Binding [Profile_NationalId_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                <TextBox
                    Background="#F0F0F0"
                    IsReadOnly="True"
                    Margin="0,0,0,8"
                    Text="{Binding NationalId}" />

                <Label Content="{Binding [Profile_Phone_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                <TextBox IsReadOnly="{Binding IsReadOnly}" Margin="0,0,0,8"
                         Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" />

                <Label Content="{Binding [Profile_Gender_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                <ComboBox
                    IsEnabled="{Binding IsEditMode}"
                    ItemsSource="{Binding GenderOptions}"
                    SelectedValue="{Binding SelectedGenderValue, UpdateSourceTrigger=PropertyChanged}"
                    SelectedValuePath="Value"
                    DisplayMemberPath="Display"
                    Margin="0,0,0,8" />

                <StackPanel Visibility="{Binding IsSupervisor, Converter={StaticResource InverseBoolToVis}}">

                    <Label Content="{Binding [Profile_Grade_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                    <ComboBox
                        TextSearch.TextPath="Name"
                        IsEnabled="{Binding IsEditMode}"
                        ItemsSource="{Binding Grades}"
                        SelectedItem="{Binding SelectedGrade, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                        Margin="0,0,0,8">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Grade_">
                                            <Binding Path="Name" />
                                            <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Label Content="{Binding [Profile_ClassNum_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                    <TextBox IsReadOnly="{Binding IsReadOnly}" Margin="0,0,0,8"
                             Text="{Binding ClassNum, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

                    <!-- Mentor section: subject, max mentees, preferred mentee gender -->
                    <StackPanel Visibility="{Binding HasMentorProfile, Converter={StaticResource BoolToVis}}">
                        <Label Content="{Binding [Profile_SubjectToTeach_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                        <ComboBox
                            TextSearch.TextPath="Name"
                            IsEnabled="{Binding IsEditMode}"
                            ItemsSource="{Binding Subjects}"
                            SelectedValue="{Binding SubjectToTeach, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                            SelectedValuePath="Id"
                            Margin="0,0,0,8">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Subject_">
                                                <Binding Path="Name" />
                                                <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Label Content="{Binding [Profile_MaxMentees_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                        <TextBox IsReadOnly="{Binding IsReadOnly}" Margin="0,0,0,8"
                                 Text="{Binding MaxMentees, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

                        <Label Content="{Binding [Profile_PreferredMenteeGender_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                        <ComboBox
                            IsEnabled="{Binding IsEditMode}"
                            ItemsSource="{Binding GenderPreferenceOptions}"
                            SelectedValue="{Binding SelectedPreferredMenteeGenderValue, UpdateSourceTrigger=PropertyChanged}"
                            SelectedValuePath="Value"
                            DisplayMemberPath="Display"
                            Margin="0,0,0,8" />
                    </StackPanel>

                    <!-- Mentee section: subject to learn, preferred mentor gender -->
                    <StackPanel Visibility="{Binding HasMenteeProfile, Converter={StaticResource BoolToVis}}">
                        <Label Content="{Binding [Profile_SubjectToLearn_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                        <ComboBox
                            TextSearch.TextPath="Name"
                            IsEnabled="{Binding IsEditMode}"
                            ItemsSource="{Binding Subjects}"
                            SelectedValue="{Binding SubjectToLearn, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                            SelectedValuePath="Id"
                            Margin="0,0,0,8">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource DbTranslation}" ConverterParameter="DB_Subject_">
                                                <Binding Path="Name" />
                                                <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="CurrentCulture" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Label Content="{Binding [Profile_PreferredMentorGender_Label], Source={x:Static loc:TranslationSource.Instance}}" />
                        <ComboBox
                            IsEnabled="{Binding IsEditMode}"
                            ItemsSource="{Binding GenderPreferenceOptions}"
                            SelectedValue="{Binding SelectedPreferredMentorGenderValue, UpdateSourceTrigger=PropertyChanged}"
                            SelectedValuePath="Value"
                            DisplayMemberPath="Display"
                            Margin="0,0,0,8" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Margin="0,20,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button
                        Padding="10,6"
                        Cursor="Hand"
                        ToolTip="{Binding [Profile_EditProfile_Tooltip], Source={x:Static loc:TranslationSource.Instance}}"
                        Command="{Binding ToggleEditCommand}"
                        Content="{Binding [Profile_EditProfile_Button], Source={x:Static loc:TranslationSource.Instance}}"
                        Visibility="{Binding IsReadOnly, Converter={StaticResource BoolToVis}}" />

                    <Button
                        Padding="10,6"
                        Background="LightGreen"
                        Cursor="Hand"
                        ToolTip="{Binding [Profile_SaveChanges_Tooltip], Source={x:Static loc:TranslationSource.Instance}}"
                        Command="{Binding SaveCommand}"
                        Content="{Binding [Profile_SaveChanges_Button], Source={x:Static loc:TranslationSource.Instance}}"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}" />
                </StackPanel>

                <TextBlock
                    Margin="0,10"
                    HorizontalAlignment="Center"
                    Foreground="Red"
                    Text="{Binding ErrorMessage}" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>