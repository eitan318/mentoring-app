@using MentoringApp.ViewModel.ViewModel.Student

@*
    Mirrors the BrowseMentorsViewModel DataTemplate (Phase 1 mentee).
    Lists available mentors with a "Send Request" action per row.
*@

<div class="scroll">
    <div class="title">Available Mentors</div>
    <div class="subtitle">Send a request to a mentor you would like to be paired with.</div>

    @if (Vm.HasStatusMessage)
    {
        <div class="status-msg">@Vm.StatusMessage</div>
    }

    @if (Vm.IsLoading)
    {
        <div class="loading">Loading…</div>
    }

    @foreach (var mentor in Vm.Mentors)
    {
        <div class="mentor-row">
            <div class="mentor-info">
                <div class="mentor-name">@mentor.MentorName</div>
                <div class="mentor-meta">
                    @mentor.SubjectName · @mentor.GradeName · Class @mentor.ClassNum
                </div>
            </div>
            @if (mentor.HasPendingRequest)
            {
                <button class="btn-cancel"
                        @onclick="async () => await Vm.CancelRequestCommand.ExecuteAsync(mentor)">
                    Cancel Request
                </button>
            }
            else
            {
                <button class="btn-primary"
                        @onclick="async () => await Vm.SendRequestCommand.ExecuteAsync(mentor)">
                    Send Request
                </button>
            }
        </div>
    }
</div>

<style>
    .scroll { overflow-y: auto; }
    .title { font-size: 18px; font-weight: bold; color: #111827; margin-bottom: 4px; }
    .subtitle { font-size: 13px; color: #6B7280; margin-bottom: 16px; }
    .status-msg {
        background: #EFF6FF; color: #1D4ED8;
        padding: 8px 12px; border-radius: 8px;
        font-size: 13px; margin-bottom: 12px;
    }
    .loading { font-size: 13px; color: #9CA3AF; margin-bottom: 12px; }
    .mentor-row {
        background: #F9FAFB; border-radius: 12px;
        padding: 16px; margin-bottom: 8px;
        display: flex; justify-content: space-between; align-items: center;
    }
    .mentor-info { flex: 1; }
    .mentor-name { font-size: 14px; font-weight: 600; color: #111827; }
    .mentor-meta { font-size: 12px; color: #6B7280; margin-top: 2px; }
    .btn-primary {
        background: #A855F7; color: white; border: 0;
        padding: 8px 14px; border-radius: 8px; font-weight: 600;
        font-size: 13px; cursor: pointer;
    }
    .btn-primary:hover { background: #9333EA; }
    .btn-cancel {
        background: #DC2626; color: white; border: 0;
        padding: 8px 14px; border-radius: 8px; font-weight: 600;
        font-size: 13px; cursor: pointer;
    }
    .btn-cancel:hover { background: #B91C1C; }
</style>

@code {
    [Parameter, EditorRequired] public BrowseMentorsViewModel Vm { get; set; } = default!;
}
