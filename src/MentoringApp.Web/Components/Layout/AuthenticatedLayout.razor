@inherits LayoutComponentBase
@implements IDisposable
@using System.ComponentModel
@using MentoringApp.ViewModel.ViewModel.User
@using MentoringApp.ViewModel.IService
@using MentoringApp.ViewModel.Localization
@inject AuthenticatedDashboardViewModel Vm
@inject ILocalizationService Loc

@*
    Mirrors AuthenticatedDashboardView.xaml shell:
    - DockPanel with top-row Grid (Back / App title / Language + Profile + Logout)
    - ContentControl Content="{Binding ActiveSubPage}"  →  @Body
*@

<div class="auth-shell" dir="@Dir">

    @* ─── Top bar ─────────────────────────────────────────────────────────── *@
    <div class="topbar">
        <div class="topbar-left">
            @if (Vm.IsBackVisible)
            {
                <button class="btn-link"
                        @onclick="async () => await Vm.BackCommand.ExecuteAsync(null)">
                    @Loc.Get("Nav_Back")
                </button>
            }
        </div>

        <div class="topbar-center">
            <span class="app-title">@Loc.Get("App_Title")</span>
        </div>

        <div class="topbar-right">
            <span class="lang-label">Language:</span>
            <select class="lang-picker"
                    value="@Vm.SelectedLanguage"
                    @onchange="e => Vm.SelectedLanguage = e.Value?.ToString() ?? Vm.SelectedLanguage">
                @foreach (var lang in Vm.AvailableLanguages)
                {
                    <option value="@lang" selected="@(lang == Vm.SelectedLanguage)">@lang</option>
                }
            </select>

            @if (Vm.IsProfileButtonVisible && Vm.CurrentUser != null)
            {
                <button class="btn-profile"
                        @onclick="() => Vm.NavigateProfileCommand.Execute(null)">
                    <span class="profile-pic"
                          style="background:@(Vm.CurrentUser.Gender.ToString() == "Female" ? "#FBCFE8" : "#BFDBFE")">
                        @(string.IsNullOrEmpty(Vm.CurrentUser.UserName) ? "?" : Vm.CurrentUser.UserName![0].ToString().ToUpper())
                    </span>
                    <span class="profile-name">@Vm.CurrentUser.UserName</span>
                </button>
            }

            <button class="btn-logout"
                    @onclick="ExecuteLogout">
                @Loc.Get("Nav_Logout")
            </button>
        </div>
    </div>

    @* ─── Sub-page (was ContentControl Content="{Binding ActiveSubPage}") ─── *@
    <div class="auth-body">
        @Body
    </div>
</div>

<style>
    .auth-shell {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        font-family: 'Segoe UI', system-ui, sans-serif;
        background: #F4F7FE;
    }

    .topbar {
        height: 48px;
        background: #F5F5F5;
        border-bottom: 1px solid #E5E7EB;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        padding: 0 12px;
        flex-shrink: 0;
    }

    .topbar-left  { justify-self: start; }
    .topbar-center { justify-self: center; }
    .topbar-right {
        justify-self: end;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .app-title { font-weight: bold; font-size: 14px; color: #111827; }
    .lang-label { font-size: 13px; color: #4B5563; }

    .lang-picker {
        padding: 4px 8px;
        border: 1px solid #D0D5DD;
        border-radius: 6px;
        font-size: 13px;
        cursor: pointer;
        background: white;
    }

    .btn-link {
        background: transparent; border: 0;
        color: #4E6EF2; cursor: pointer;
        font-size: 13px; padding: 6px 10px;
    }
    .btn-link:hover { text-decoration: underline; }

    .btn-profile {
        display: inline-flex; align-items: center; gap: 8px;
        background: white; border: 1px solid #E5E7EB;
        border-radius: 8px; padding: 4px 10px 4px 4px;
        cursor: pointer; font-size: 13px; color: #111827;
    }
    .btn-profile:hover { background: #F9FAFB; }

    .profile-pic {
        width: 28px; height: 28px;
        border-radius: 50%;
        display: inline-flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 12px; color: #1F2937;
    }
    .profile-name { font-weight: 500; }

    .btn-logout {
        background: white; color: #DC2626;
        border: 1px solid #FECACA;
        padding: 6px 12px; border-radius: 6px;
        font-weight: 600; font-size: 13px;
        cursor: pointer;
    }
    .btn-logout:hover { background: #FEF2F2; }

    .auth-body { flex: 1; overflow: auto; }
</style>

@code {
    private string Dir => TranslationSource.Instance.IsRtl ? "rtl" : "ltr";

    protected override async Task OnInitializedAsync()
    {
        Vm.PropertyChanged += OnVmChanged;
        TranslationSource.Instance.PropertyChanged += OnLocChanged;

        // Populate CurrentUser / SelectedLanguage from the store. Calling the VM's
        // OnNavigatedToAsync ALSO triggers role-based routing — fine on /authenticated,
        // but on a direct URL like /student we are already there, so the redundant
        // NavigateToAsync<StudentDashboardViewModel> is a harmless no-op (same URL).
        await Vm.OnNavigatedToAsync();
    }

    private void OnVmChanged(object? sender, PropertyChangedEventArgs e) =>
        InvokeAsync(StateHasChanged);

    private void OnLocChanged(object? sender, PropertyChangedEventArgs e) =>
        InvokeAsync(StateHasChanged);

        
    private async Task ExecuteLogout()
    {
        try { await Vm.LogoutCommand.ExecuteAsync(null); }
        finally { StateHasChanged(); }
    }

    public void Dispose()
    {
        Vm.PropertyChanged -= OnVmChanged;
        TranslationSource.Instance.PropertyChanged -= OnLocChanged;
    }
}
