@inject MatchingApiClient Matching

<div>
    @if (_loading)
    {
        <div class="empty-state"><div class="loading-spinner"></div></div>
    }
    else
    {
        @if (IsPhase2Active)
        {
            <div class="phase-note phase-note-purple">
                <strong>Phase 2 is now active.</strong> New requests are no longer accepted.
                Your supervisor will finalize pairings from the matching recommendations.
            </div>
        }
        else if (!string.IsNullOrEmpty(Phase1Deadline))
        {
            <div class="phase-note phase-note-blue">
                Students can request you as a mentor until <strong>@Phase1Deadline[..10]</strong>.
                Your supervisor will review and approve matches.
            </div>
        }

        @if (!_requests.Any())
        {
            <div class="empty-state">
                <h3>No incoming requests</h3>
                <p>No students have requested you yet. Your supervisor will pair you when ready.</p>
            </div>
        }
        else
        {
            <h2 style="margin-bottom:.75rem">Incoming Mentee Requests</h2>
            @foreach (var req in _requests)
            {
                <div class="request-item">
                    <div class="peer-avatar" style="width:40px;height:40px;font-size:.9rem">
                        @req.MenteeName[0].ToString().ToUpper()
                    </div>
                    <div class="req-info">
                        <h4>@req.MenteeName</h4>
                        <p>Subject: @req.MenteeSubjectName &nbsp;|&nbsp; Requested: @req.CreatedAt[..10]</p>
                    </div>
                    <span class="badge badge-pending">@req.Status</span>
                </div>
            }
        }
    }

    @if (!string.IsNullOrEmpty(_error)) { <p class="error-msg mt-4">@_error</p> }
</div>

@code {
    [Parameter] public int UserId { get; set; }
    [Parameter] public bool IsPhase2Active { get; set; }
    [Parameter] public string? Phase1Deadline { get; set; }

    private List<PairRequestResponse> _requests = new();
    private bool _loading = true;
    private string _error = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _requests = (await Matching.GetRequestsForMentorAsync(UserId))
                .Where(r => r.Status == "Pending").ToList();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }
}
