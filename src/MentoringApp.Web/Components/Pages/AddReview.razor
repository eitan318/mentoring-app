@page "/add-review"
@rendermode InteractiveServer
@layout MentoringApp.Web.Components.Layout.AuthenticatedLayout
@implements IDisposable
@using System.ComponentModel
@using System.Globalization
@using MentoringApp.ViewModel.ViewModel.Student
@using MentoringApp.ViewModel.IService
@using MentoringApp.ViewModel.Localization
@using MentoringApp.Web.Services
@inject AddReviewViewModel Vm
@inject ILocalizationService Loc
@inject NavigationParameterStore ParamStore

@*
    Mirrors AddReviewView.xaml — bound 1:1 to AddReviewViewModel.
    Receives pairId via NavigationParameterStore (parameter type: int).
*@

<div class="review-root" dir="@Dir">
    <div class="review-card">
        <div class="title">@Loc.Get("Review_Content_Label")</div>

        <div class="field-label">@Loc.Get("Review_Content_Label")</div>
        <textarea class="field-input field-textarea"
                  rows="5"
                  value="@Vm.ReviewContent"
                  @oninput="e => Vm.ReviewContent = e.Value?.ToString() ?? string.Empty"></textarea>

        <div class="field-label">@Loc.Get("Review_Hours_Label")</div>
        <input class="field-input field-hours"
               type="number" step="0.1" min="0.1" max="24"
               value="@Vm.AmountOfHours.ToString(CultureInfo.InvariantCulture)"
               @oninput="OnHoursChanged" />

        <div class="actions">
            <button class="btn-primary"
                    @onclick="async () => await Vm.AddReviewCommand.ExecuteAsync(null)">
                @Loc.Get("Review_Submit_Button")
            </button>
        </div>
    </div>
</div>

<style>
    .review-root {
        background: #F4F7FE;
        min-height: 100%;
        display: flex; align-items: center; justify-content: center;
        padding: 40px 24px;
        font-family: 'Segoe UI', system-ui, sans-serif;
    }
    .review-card {
        background: white;
        border-radius: 16px;
        padding: 28px;
        max-width: 480px; width: 100%;
        box-shadow: 0 2px 15px rgba(0,0,0,.06);
    }
    .title {
        font-size: 20px; font-weight: bold;
        color: #111827; margin-bottom: 20px;
    }
    .field-label {
        font-size: 12px; font-weight: 600;
        color: #374151; margin: 0 0 6px;
    }
    .field-input {
        width: 100%; box-sizing: border-box;
        padding: 10px 8px; font-size: 14px;
        border: 1px solid #E5E7EB; border-radius: 6px;
        outline: none; background: white;
        margin-bottom: 16px;
        font-family: inherit;
    }
    .field-input:focus { border-color: #4E6EF2; }
    .field-textarea { resize: vertical; min-height: 100px; }
    .field-hours { width: 120px; margin-bottom: 24px; }

    .actions { display: flex; justify-content: flex-end; }
    .btn-primary {
        background: #10B981; color: white;
        border: 0; padding: 10px 16px;
        border-radius: 8px; font-weight: 600;
        font-size: 14px; cursor: pointer;
    }
    .btn-primary:hover { background: #059669; }
    .btn-primary:disabled { opacity: .5; cursor: default; }
</style>

@code {
    private string Dir => TranslationSource.Instance.IsRtl ? "rtl" : "ltr";

    protected override async Task OnInitializedAsync()
    {
        Vm.PropertyChanged += OnVmChanged;
        TranslationSource.Instance.PropertyChanged += OnLocChanged;

        var pairId = ParamStore.Take<int>(typeof(AddReviewViewModel));
        await Vm.OnNavigatedToAsync(pairId);
    }

    private void OnVmChanged(object? sender, PropertyChangedEventArgs e) =>
        InvokeAsync(StateHasChanged);

    private void OnLocChanged(object? sender, PropertyChangedEventArgs e) =>
        InvokeAsync(StateHasChanged);

    private void OnHoursChanged(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var n))
            Vm.AmountOfHours = n;
    }

    public void Dispose()
    {
        Vm.PropertyChanged -= OnVmChanged;
        TranslationSource.Instance.PropertyChanged -= OnLocChanged;
    }
}
