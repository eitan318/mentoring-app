@inject UserApiClient Users
@inject ReviewApiClient Reviews
@inject IssueApiClient IssueClient
@inject ReferenceApiClient Reference
@inject SettingsApiClient SettingsClient

<div>
    @if (_loading)
    {
        <div class="empty-state"><div class="loading-spinner"></div></div>
    }
    else if (IsMentor)
    {
        <div class="card" style="margin-bottom:1rem">
            <p class="card-title" style="margin-bottom:.75rem">Your Mentee</p>
            @if (_peer is not null)
            {
                <div class="flex items-center gap-2">
                    <div class="peer-avatar">@_peer.UserName[0].ToString().ToUpper()</div>
                    <div>
                        <a class="peer-link" href="/user/@_peer.Id">@_peer.UserName</a>
                        <p class="text-sm text-muted">@_peer.Email</p>
                        @if (!string.IsNullOrEmpty(_peer.PhoneNumber))
                        {
                            <p class="text-sm text-muted">@_peer.PhoneNumber</p>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="card" style="margin-bottom:1rem">
            <div class="flex items-center justify-between" style="margin-bottom:.5rem">
                <span class="card-title" style="margin-bottom:0">Meeting Hours</span>
                <span class="text-sm text-muted">@_totalHours.ToString("F1") / @_requiredHours.ToString("F0") hrs</span>
            </div>
            <div class="hours-bar-bg">
                <div class="hours-bar-fill" style="width:@_hoursBarWidth"></div>
            </div>
        </div>

        <div class="flex gap-2" style="margin-bottom:1rem">
            <button class="btn btn-primary" @onclick="() => _showReviewModal = true">Write Review</button>
            <button class="btn btn-secondary" @onclick="() => _showIssueModal = true">Report Issue</button>
        </div>

        <div class="card" style="margin-bottom:1rem">
            <p class="card-title">Meeting Reviews</p>
            @if (!_reviews.Any())
            {
                <p class="text-muted text-sm">No reviews yet.</p>
            }
            else
            {
                @foreach (var r in _reviews)
                {
                    <div class="review-item">
                        <div class="review-header">
                            <span class="review-content-text">@r.Content</span>
                            <span class="review-hours-green">@r.AmountOfHours h</span>
                        </div>
                        <p class="text-sm text-muted" style="margin-top:.25rem">@r.Date[..10]</p>
                    </div>
                }
            }
        </div>

        <div class="card">
            <p class="card-title">Issues</p>
            @if (!_issues.Any())
            {
                <p class="text-muted text-sm">No issues reported.</p>
            }
            else
            {
                @foreach (var issue in _issues)
                {
                    <div class="issue-row">
                        <span class="issue-bullet @(issue.IsResolvedBool ? "bullet-green" : "bullet-red")">●</span>
                        <div>
                            <span class="text-sm">@issue.Description</span>
                            <p class="text-sm text-muted" style="margin-top:.1rem">@CategoryName(issue.CategoryId) · @issue.CreationDate</p>
                        </div>
                    </div>
                }
            }
        </div>
    }
    else
    {
        <div class="card" style="margin-bottom:1rem">
            <p class="card-title" style="margin-bottom:.75rem">Your Mentor</p>
            @if (_peer is not null)
            {
                <div class="flex items-center gap-2">
                    <div class="peer-avatar">@_peer.UserName[0].ToString().ToUpper()</div>
                    <div>
                        <a class="peer-link" href="/user/@_peer.Id">@_peer.UserName</a>
                        @if (!string.IsNullOrEmpty(_mentorSubject))
                        {
                            <p class="text-sm" style="color:#2E7D32;font-weight:500">Expert in: @_mentorSubject</p>
                        }
                        <p class="text-sm text-muted">@_peer.Email</p>
                    </div>
                </div>
            }
        </div>

        <div class="card" style="margin-bottom:1rem">
            <div class="flex items-center justify-between" style="margin-bottom:.5rem">
                <span class="card-title" style="margin-bottom:0">Meeting Hours</span>
                <span class="text-sm text-muted">@_totalHours.ToString("F1") / @_requiredHours.ToString("F0") hrs</span>
            </div>
            <div class="hours-bar-bg">
                <div class="hours-bar-fill" style="width:@_hoursBarWidth"></div>
            </div>
        </div>

        <div style="margin-bottom:1rem">
            <button class="btn btn-secondary" @onclick="() => _showIssueModal = true">Raise Issue</button>
        </div>

        <div class="card" style="margin-bottom:1rem">
            <p class="card-title">Mentor Feedback</p>
            @if (!_reviews.Any())
            {
                <p class="text-muted text-sm">No feedback from your mentor yet.</p>
            }
            else
            {
                @foreach (var r in _reviews)
                {
                    <div class="review-item">
                        <p class="review-content-text" style="margin-bottom:.25rem">@r.Content</p>
                        <p class="text-sm text-muted">@r.Date[..10]</p>
                    </div>
                }
            }
        </div>

        <div class="card">
            <p class="card-title">My Issues</p>
            @if (!_issues.Any())
            {
                <p class="text-muted text-sm">No issues reported.</p>
            }
            else
            {
                @foreach (var issue in _issues)
                {
                    <div class="issue-row">
                        <span class="issue-bullet @(issue.IsResolvedBool ? "bullet-green" : "bullet-red")">●</span>
                        <div>
                            <span class="text-sm">@issue.Description</span>
                            <p class="text-sm text-muted" style="margin-top:.1rem">@CategoryName(issue.CategoryId) · @issue.CreationDate</p>
                        </div>
                    </div>
                }
            }
        </div>
    }

    @if (_showReviewModal)
    {
        <AddReviewModal PairId="@Pair.Id" AuthorUserId="@CurrentUser.Id" OnClose="OnReviewClose" />
    }
    @if (_showIssueModal)
    {
        <AddIssueModal UserId="@CurrentUser.Id" OnClose="OnIssueClose" />
    }
</div>

@code {
    [Parameter] public PairResponse Pair { get; set; } = null!;
    [Parameter] public UserResponse CurrentUser { get; set; } = null!;
    [Parameter] public bool IsMentor { get; set; }

    private UserResponse? _peer;
    private List<ReviewResponse> _reviews = new();
    private List<IssueResponse> _issues = new();
    private Dictionary<int, string> _categories = new();
    private Dictionary<int, string> _subjects = new();
    private double _totalHours;
    private double _requiredHours = 10;
    private string _hoursBarWidth = "0%";
    private string _mentorSubject = "";
    private bool _loading = true;
    private bool _showReviewModal, _showIssueModal;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var peerId = IsMentor ? Pair.MenteeId : Pair.MentorId;
            var peerTask = Users.GetByIdAsync(peerId);
            var reviewsTask = Reviews.GetByPairAsync(Pair.Id);
            var issuesTask = IssueClient.GetByUserAsync(CurrentUser.Id);
            var catsTask = IssueClient.GetCategoriesAsync();
            var subjectsTask = Reference.GetSubjectsAsync();
            var settingsTask = SettingsClient.GetAllAsync();
            await Task.WhenAll(peerTask, reviewsTask, issuesTask, catsTask, subjectsTask, settingsTask);

            _peer = peerTask.Result;
            _reviews = reviewsTask.Result.ToList();
            _issues = issuesTask.Result.ToList();
            _categories = catsTask.Result.ToDictionary(c => c.Id, c => c.Name);
            _subjects = subjectsTask.Result.ToDictionary(s => s.Id, s => s.Name);

            var settings = settingsTask.Result;
            _totalHours = _reviews.Sum(r => r.AmountOfHours);
            _requiredHours = settings.MeetingHoursBarrier > 0 ? settings.MeetingHoursBarrier : 10;
            UpdateHoursBar();

            if (!IsMentor && _peer?.MentorSubjectId is int sid && _subjects.TryGetValue(sid, out var sname))
                _mentorSubject = sname;
        }
        catch { }
        finally { _loading = false; }
    }

    private void UpdateHoursBar()
    {
        var pct = (int)Math.Min(100, Math.Round(_totalHours / _requiredHours * 100));
        _hoursBarWidth = $"{pct}%";
    }

    private string CategoryName(int id) =>
        _categories.TryGetValue(id, out var name) ? name : $"Category #{id}";

    private async Task OnReviewClose(bool created)
    {
        _showReviewModal = false;
        if (!created) return;
        try
        {
            _reviews = (await Reviews.GetByPairAsync(Pair.Id)).ToList();
            _totalHours = _reviews.Sum(r => r.AmountOfHours);
            UpdateHoursBar();
        }
        catch { }
    }

    private async Task OnIssueClose(bool created)
    {
        _showIssueModal = false;
        if (!created) return;
        try { _issues = (await IssueClient.GetByUserAsync(CurrentUser.Id)).ToList(); }
        catch { }
    }
}
