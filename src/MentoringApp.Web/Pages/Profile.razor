@page "/profile"
@inject AuthStateService Auth
@inject NavigationManager Nav
@inject UserApiClient Users
@inject ReferenceApiClient Reference
@using MentoringApp.Model
@using MentoringApp.Model.User

<PageTitle>Profile – MentoringApp</PageTitle>

@if (!Auth.IsAuthenticated)
{
    <p>Redirecting…</p>
}
else if (_loading)
{
    <div class="empty-state"><div class="loading-spinner"></div></div>
}
else if (_user is null)
{
    <p class="error-msg">Failed to load profile.</p>
}
else
{
    <div class="page-header">
        <h1>My Profile</h1>
    </div>

    @* --- Basic Info --- *@
    <div class="card">
        <p class="card-title">Basic Info</p>
        <div class="form-group">
            <label>Username</label>
            <input @bind="_userName" class="form-input" />
        </div>
        <div class="form-group">
            <label>Email</label>
            <input @bind="_email" class="form-input" type="email" />
        </div>
        <div class="form-group">
            <label>National ID</label>
            <input @bind="_nationalId" class="form-input" />
        </div>
        <div class="form-group">
            <label>Phone</label>
            <input @bind="_phone" class="form-input" placeholder="Optional" />
        </div>
        <div class="form-group">
            <label>Gender</label>
            <select @bind="_gender" class="form-select">
                @foreach (var g in Enum.GetValues<Gender>())
                {
                    <option value="@g">@g.ToString()</option>
                }
            </select>
        </div>
        <button class="btn btn-primary" @onclick="SaveBaseInfo" disabled="@_saving">
            @(_saving ? "Saving…" : "Save Basic Info")
        </button>
        @if (!string.IsNullOrEmpty(_baseInfoMsg))
        {
            <p class="@(_baseInfoOk ? "success-msg" : "error-msg") mt-2">@_baseInfoMsg</p>
        }
    </div>

    @* --- Student Specific Info --- *@
    @if (_user is StudentModel student)
    {
        <div class="card">
            <p class="card-title">School</p>
            <div class="form-group">
                <label>Grade</label>
                <select @bind="_gradeId" class="form-select">
                    <option value="">Select…</option>
                    @foreach (var g in _grades)
                    {
                        <option value="@g.Id">@g.Name</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Class Number</label>
                <input @bind="_classNum" class="form-input" type="number" min="1" max="20" />
            </div>
            <button class="btn btn-primary" @onclick="SaveGradeClass" disabled="@_saving">Save School Info</button>
            @if (!string.IsNullOrEmpty(_gradeClassMsg))
            {
                <p class="@(_gradeClassOk ? "success-msg" : "error-msg") mt-2">@_gradeClassMsg</p>
            }
        </div>

        <div class="card">
            <p class="card-title">Gender Preferences</p>
            <div class="form-group">
                <label>Preferred Mentor Gender</label>
                <select @bind="_prefMentorGender" class="form-select">
                    @foreach (var gp in Enum.GetValues<GenderPreference>())
                    {
                        <option value="@gp">@gp.ToString().Replace("Preference", "")</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Preferred Mentee Gender</label>
                <select @bind="_prefMenteeGender" class="form-select">
                    @foreach (var gp in Enum.GetValues<GenderPreference>())
                    {
                        <option value="@gp">@gp.ToString().Replace("Preference", "")</option>
                    }
                </select>
            </div>
            <button class="btn btn-primary" @onclick="SaveGenderPrefs" disabled="@_saving">Save Preferences</button>
            @if (!string.IsNullOrEmpty(_genderPrefsMsg))
            {
                <p class="@(_genderPrefsOk ? "success-msg" : "error-msg") mt-2">@_genderPrefsMsg</p>
            }
        </div>

        @if (student.IsMentor)
        {
            <div class="card">
                <p class="card-title">Mentor Subject</p>
                <div class="form-group">
                    <label>Subject I Teach</label>
                    <select @bind="_mentorSubjectId" class="form-select">
                        <option value="">Select…</option>
                        @foreach (var s in _subjects)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
                <button class="btn btn-primary" @onclick="SaveMentorProfile" disabled="@_saving">Save</button>
                @if (!string.IsNullOrEmpty(_mentorProfileMsg))
                {
                    <p class="@(_mentorProfileOk ? "success-msg" : "error-msg") mt-2">@_mentorProfileMsg</p>
                }
            </div>
        }

        @if (student.IsMentee)
        {
            <div class="card">
                <p class="card-title">Mentee Subject</p>
                <div class="form-group">
                    <label>Subject I Want to Learn</label>
                    <select @bind="_menteeSubjectId" class="form-select">
                        <option value="">Select…</option>
                        @foreach (var s in _subjects)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
                <button class="btn btn-primary" @onclick="SaveMenteeProfile" disabled="@_saving">Save</button>
                @if (!string.IsNullOrEmpty(_menteeProfileMsg))
                {
                    <p class="@(_menteeProfileOk ? "success-msg" : "error-msg") mt-2">@_menteeProfileMsg</p>
                }
            </div>
        }
    }
}

@code {
    private UserModel? _user;
    private bool _loading = true, _saving;

    // עברנו להשתמש ב-Enums ישירות
    private string _userName = "", _email = "", _nationalId = "", _phone = "";
    private Gender _gender = Gender.PreferNoAnswer;
    
    private string _gradeId = "", _classNum = "";
    private GenderPreference _prefMentorGender = GenderPreference.NoPreference;
    private GenderPreference _prefMenteeGender = GenderPreference.NoPreference;
    private string _mentorSubjectId = "", _menteeSubjectId = "";

    private string _baseInfoMsg = "", _gradeClassMsg = "", _genderPrefsMsg = "", _mentorProfileMsg = "", _menteeProfileMsg = "";
    private bool _baseInfoOk, _gradeClassOk, _genderPrefsOk, _mentorProfileOk, _menteeProfileOk;

    private List<GradeModel> _grades = new();
    private List<SubjectModel> _subjects = new();

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsAuthenticated)
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }
        
        try
        {
            _user = await Users.GetByIdAsync(Auth.UserId);
            _grades = (await Reference.GetGradesAsync()).ToList();
            _subjects = (await Reference.GetSubjectsAsync()).ToList();
            PopulateForm();
        }
        catch { }
        finally { _loading = false; }
    }

    private void PopulateForm()
    {
        if (_user is null) return;
        _userName = _user.UserName;
        _email = _user.Email;
        _nationalId = _user.NationalId;
        _phone = _user.PhoneNumber ?? "";
        _gender = _user.Gender;

        if (_user is StudentModel s)
        {
            _gradeId = s.Grade?.Id.ToString() ?? "";
            _classNum = s.ClassNum.ToString();
            _prefMentorGender = s.PreferredMentorGender;
            _prefMenteeGender = s.PreferredMenteeGender;
            _mentorSubjectId = s.MentorProfile?.SubjectToTeach.ToString() ?? "";
            _menteeSubjectId = s.MenteeProfile?.SubjectToLearn.ToString() ?? "";
        }
    }

    private async Task SaveBaseInfo()
    {
        _saving = true; _baseInfoMsg = "";
        try
        {
            await Users.UpdateBaseInfoAsync(Auth.UserId, new UpdateBaseInfoRequest(
                _userName, _email, _nationalId,
                string.IsNullOrWhiteSpace(_phone) ? null : _phone,
                (int)_gender));
            _baseInfoMsg = "Saved!"; _baseInfoOk = true;
        }
        catch (Exception ex) { _baseInfoMsg = ex.Message; _baseInfoOk = false; }
        finally { _saving = false; }
    }

    private async Task SaveGradeClass()
    {
        _saving = true; _gradeClassMsg = "";
        if (!int.TryParse(_gradeId, out var gId) || !int.TryParse(_classNum, out var cNum))
        { _gradeClassMsg = "Please select a grade and class number."; _gradeClassOk = false; _saving = false; return; }
        try
        {
            await Users.UpdateGradeClassAsync(Auth.UserId, new UpdateGradeClassRequest(gId, cNum));
            _gradeClassMsg = "Saved!"; _gradeClassOk = true;
        }
        catch (Exception ex) { _gradeClassMsg = ex.Message; _gradeClassOk = false; }
        finally { _saving = false; }
    }

    private async Task SaveGenderPrefs()
    {
        _saving = true; _genderPrefsMsg = "";
        try
        {
            await Users.UpdateGenderPreferencesAsync(Auth.UserId, new UpdateGenderPreferencesRequest(
                (int)_prefMentorGender, (int)_prefMenteeGender));
            _genderPrefsMsg = "Saved!"; _genderPrefsOk = true;
        }
        catch (Exception ex) { _genderPrefsMsg = ex.Message; _genderPrefsOk = false; }
        finally { _saving = false; }
    }

    private async Task SaveMentorProfile()
    {
        _saving = true; _mentorProfileMsg = "";
        if (!int.TryParse(_mentorSubjectId, out var sId))
        { _mentorProfileMsg = "Please select a subject."; _mentorProfileOk = false; _saving = false; return; }
        try
        {
            await Users.UpdateMentorProfileAsync(Auth.UserId, new UpdateMentorProfileRequest(sId));
            _mentorProfileMsg = "Saved!"; _mentorProfileOk = true;
        }
        catch (Exception ex) { _mentorProfileMsg = ex.Message; _mentorProfileOk = false; }
        finally { _saving = false; }
    }

    private async Task SaveMenteeProfile()
    {
        _saving = true; _menteeProfileMsg = "";
        if (!int.TryParse(_menteeSubjectId, out var sId))
        { _menteeProfileMsg = "Please select a subject."; _menteeProfileOk = false; _saving = false; return; }
        try
        {
            await Users.UpdateMenteeProfileAsync(Auth.UserId, new UpdateMenteeProfileRequest(sId));
            _menteeProfileMsg = "Saved!"; _menteeProfileOk = true;
        }
        catch (Exception ex) { _menteeProfileMsg = ex.Message; _menteeProfileOk = false; }
        finally { _saving = false; }
    }
}