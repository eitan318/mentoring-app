@page "/issues"
@inject AuthStateService Auth
@inject NavigationManager Nav
@inject IssueApiClient IssueClient

<PageTitle>Issues – MentoringApp</PageTitle>

@if (!Auth.IsAuthenticated)
{
    <p>Redirecting…</p>
}
else if (_loading)
{
    <div class="empty-state"><div class="loading-spinner"></div></div>
}
else
{
    <div class="page-header">
        <h1>My Issues</h1>
        <button class="btn btn-primary" @onclick="() => _showModal = true">Report Issue</button>
    </div>

    @if (!_issues.Any())
    {
        <div class="empty-state">
            <h3>No issues reported</h3>
            <p>Report an issue to your supervisor if you need help.</p>
        </div>
    }
    else
    {
        @foreach (var issue in _issues)
        {
            <div class="issue-item">
                <div class="issue-header">
                    <span class="badge @(issue.IsResolvedBool ? "badge-resolved" : issue.IsForwardedToAdmin ? "badge-forwarded" : "badge-open")">
                        @(issue.IsResolvedBool ? "Resolved" : issue.IsForwardedToAdmin ? "Forwarded to Admin" : "Open")
                    </span>
                    <span class="badge badge-pending">@CategoryName(issue.CategoryId)</span>
                </div>
                <p class="issue-desc">@issue.Description</p>
                <p class="issue-date">@issue.CreationDate</p>
            </div>
        }
    }

    @if (_showModal)
    {
        <AddIssueModal UserId="@Auth.UserId" OnClose="OnModalClose" />
    }
}

@code {
    private List<IssueResponse> _issues = new();
    private Dictionary<int, string> _categories = new();
    private bool _loading = true, _showModal;

    protected override void OnInitialized()
    {
        if (!Auth.IsAuthenticated) Nav.NavigateTo("/login", replace: true);
    }

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsAuthenticated) return;
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            var issuesTask = IssueClient.GetByUserAsync(Auth.UserId);
            var catsTask = IssueClient.GetCategoriesAsync();
            await Task.WhenAll(issuesTask, catsTask);
            _issues = issuesTask.Result.ToList();
            _categories = catsTask.Result.ToDictionary(c => c.Id, c => c.Name);
        }
        catch { }
        finally { _loading = false; }
    }

    private string CategoryName(int id) =>
        _categories.TryGetValue(id, out var name) ? name : $"Category #{id}";

    private async Task OnModalClose(bool created)
    {
        _showModal = false;
        if (created) await LoadData();
    }
}
