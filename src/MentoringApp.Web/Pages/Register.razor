@page "/register"
@inject AuthApiClient AuthClient
@inject ReferenceApiClient Reference
@inject NavigationManager Nav

<PageTitle>Register – MentoringApp</PageTitle>

<div class="auth-container" style="max-width:520px">
    <h1>Register</h1>

    <div class="card">
        <div class="form-group">
            <label>Username</label>
            <input @bind="_userName" class="form-input" placeholder="Full name" />
        </div>
        <div class="form-group">
            <label>Email</label>
            <input @bind="_email" class="form-input" type="email" placeholder="your@email.com" />
        </div>
        <div class="form-group">
            <label>National ID</label>
            <input @bind="_nationalId" class="form-input" placeholder="National ID number" />
        </div>
        <div class="form-group">
            <label>Phone (optional)</label>
            <input @bind="_phone" class="form-input" placeholder="+972..." />
        </div>
        <div class="form-group">
            <label>Gender</label>
            <select @bind="_gender" class="form-select">
                <option value="1">Male</option>
                <option value="2">Female</option>
                <option value="3">Prefer not to say</option>
            </select>
        </div>

        <hr style="border:none;border-top:1px solid var(--border);margin:1rem 0" />
        <p class="text-sm font-semibold mb-2">School Information</p>

        <div class="form-group">
            <label>Grade</label>
            <select @bind="_gradeId" class="form-select">
                <option value="">Select grade…</option>
                @foreach (var g in _grades)
                {
                    <option value="@g.Id">@g.Name</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label>Class Number</label>
            <input @bind="_classNum" class="form-input" type="number" min="1" max="20" placeholder="e.g. 3" />
        </div>

        <hr style="border:none;border-top:1px solid var(--border);margin:1rem 0" />
        <p class="text-sm font-semibold mb-2">Mentoring Preferences</p>

        <div class="form-group">
            <label>Mentor Role (teaching subject)</label>
            <select @bind="_mentorSubjectId" class="form-select">
                <option value="">Not a mentor</option>
                @foreach (var s in _subjects)
                {
                    <option value="@s.Id">@s.Name</option>
                }
            </select>
        </div>
        @if (!string.IsNullOrEmpty(_mentorSubjectId))
        {
            <div class="form-group">
                <label>Max Mentees</label>
                <input @bind="_maxMentees" class="form-input" type="number" min="1" max="5" placeholder="1" />
            </div>
            <div class="form-group">
                <label>Preferred Mentee Gender</label>
                <select @bind="_preferredMenteeGender" class="form-select">
                    <option value="3">No preference</option>
                    <option value="1">Male</option>
                    <option value="2">Female</option>
                </select>
            </div>
        }
        <div class="form-group">
            <label>Mentee Role (learning subject)</label>
            <select @bind="_menteeSubjectId" class="form-select">
                <option value="">Not a mentee</option>
                @foreach (var s in _subjects)
                {
                    <option value="@s.Id">@s.Name</option>
                }
            </select>
        </div>
        @if (!string.IsNullOrEmpty(_menteeSubjectId))
        {
            <div class="form-group">
                <label>Preferred Mentor Gender</label>
                <select @bind="_preferredMentorGender" class="form-select">
                    <option value="3">No preference</option>
                    <option value="1">Male</option>
                    <option value="2">Female</option>
                </select>
            </div>
        }

        <button class="btn btn-primary btn-full mt-4" @onclick="Submit" disabled="@_loading">
            @(_loading ? "Registering…" : "Register")
        </button>

        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="error-msg">@_error</p>
        }
        @if (!string.IsNullOrEmpty(_success))
        {
            <p class="success-msg">@_success</p>
        }
    </div>

    <p class="text-center text-sm mt-4">
        Already have an account? <a href="/login">Sign in</a>
    </p>
</div>

@code {
    private string _userName = "", _email = "", _nationalId = "", _phone = "";
    private string _gender = "3";
    private string _gradeId = "", _classNum = "";
    private string _mentorSubjectId = "", _menteeSubjectId = "";
    private string _maxMentees = "1";
    private string _preferredMentorGender = "3", _preferredMenteeGender = "3";
    private string _error = "", _success = "";
    private bool _loading;

    private List<GradeResponse> _grades = new();
    private List<SubjectResponse> _subjects = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _grades = (await Reference.GetGradesAsync()).ToList();
            _subjects = (await Reference.GetSubjectsAsync()).ToList();
        }
        catch { }
    }

    private async Task Submit()
    {
        _error = "";
        if (string.IsNullOrWhiteSpace(_userName) || string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_nationalId))
        { _error = "Username, email, and national ID are required."; return; }
        if (!int.TryParse(_gradeId, out var gradeId) || !int.TryParse(_classNum, out var classNum))
        { _error = "Please select a grade and enter a class number."; return; }
        if (string.IsNullOrEmpty(_mentorSubjectId) && string.IsNullOrEmpty(_menteeSubjectId))
        { _error = "You must register as a mentor, a mentee, or both."; return; }

        _loading = true;
        try
        {
            var req = new RegisterRequest(
                UserName: _userName,
                Email: _email,
                NationalId: _nationalId,
                PhoneNumber: string.IsNullOrWhiteSpace(_phone) ? null : _phone,
                Gender: int.Parse(_gender),
                Role: "Student",
                GradeId: gradeId,
                ClassNum: classNum,
                PreferredMentorGender: string.IsNullOrEmpty(_menteeSubjectId) ? null : int.Parse(_preferredMentorGender),
                PreferredMenteeGender: string.IsNullOrEmpty(_mentorSubjectId) ? null : int.Parse(_preferredMenteeGender),
                MentorSubjectId: string.IsNullOrEmpty(_mentorSubjectId) ? null : int.Parse(_mentorSubjectId),
                MaxMentees: string.IsNullOrEmpty(_mentorSubjectId) ? null : int.Parse(_maxMentees),
                MenteeSubjectId: string.IsNullOrEmpty(_menteeSubjectId) ? null : int.Parse(_menteeSubjectId)
            );
            await AuthClient.RegisterAsync(req);
            _success = "Registered successfully! You can now sign in.";
            await Task.Delay(1500);
            Nav.NavigateTo("/login");
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }
}
