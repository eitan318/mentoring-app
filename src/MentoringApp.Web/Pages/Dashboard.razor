@page "/dashboard"
@inject AuthStateService Auth
@inject NavigationManager Nav
@inject UserApiClient Users
@inject PairApiClient Pairs
@inject SettingsApiClient SettingsClient
@implements IDisposable

<PageTitle>Dashboard – MentoringApp</PageTitle>

@if (!Auth.IsAuthenticated)
{
    <p>Redirecting…</p>
}
else if (_loading)
{
    <div class="empty-state"><div class="loading-spinner"></div></div>
}
else if (_user is null)
{
    <p class="error-msg">Failed to load user data.</p>
}
else
{
    <div class="page-header">
        <h1>Welcome, @_user.UserName</h1>
    </div>

    @if (_showBanner)
    {
        <div class="phase-banner @(_isPhase2 ? "phase-banner-2" : "phase-banner-1")">
            <div>
                <span class="phase-label">@(_isPhase2 ? "Phase 2 — Mentor Selection" : "Phase 1 — Browse Mentors")</span>
                <span class="phase-subtitle">@(_isPhase2 ? "Select from your top recommended mentors." : "Browse available mentors and send pairing requests.")</span>
            </div>
            @if (!string.IsNullOrEmpty(_bannerTimer))
            {
                <span class="phase-timer">@_bannerTimer</span>
            }
        </div>
    }

    @if (_tabs.Count > 1)
    {
        <div class="tabs">
            @foreach (var tab in _tabs)
            {
                <button class="tab-btn @(tab == _activeTab ? "active" : "")" @onclick="() => _activeTab = tab">
                    @tab
                </button>
            }
        </div>
    }

    @if (_activeTab == TabMentorPair && _mentorPair is not null)
    {
        <PairDashboard Pair="@_mentorPair" CurrentUser="@_user" IsMentor="true" />
    }
    else if (_activeTab == TabMenteePair && _menteePair is not null)
    {
        <PairDashboard Pair="@_menteePair" CurrentUser="@_user" IsMentor="false" />
    }
    else if (_activeTab == TabBrowseMentors)
    {
        <BrowseMentors UserId="@Auth.UserId" />
    }
    else if (_activeTab == TabMentorRequests)
    {
        <MentorRequests UserId="@Auth.UserId" IsPhase2Active="@_isPhase2" Phase1Deadline="@_settings?.Phase1Deadline" />
    }
    else if (_activeTab == TabGallery)
    {
        <SelectionGallery MenteeId="@Auth.UserId" />
    }
    else
    {
        <div class="empty-state">
            <h3>Waiting for assignment</h3>
            <p>The matching process is complete. Your supervisor will assign you a pair soon.</p>
        </div>
    }
}

@code {
    private const string TabMentorPair = "Mentoring";
    private const string TabMenteePair = "Learning";
    private const string TabBrowseMentors = "Browse Mentors";
    private const string TabMentorRequests = "Incoming Requests";
    private const string TabGallery = "Select Mentor";

    private UserResponse? _user;
    private SettingsResponse? _settings;
    private PairResponse? _mentorPair;
    private PairResponse? _menteePair;
    private List<string> _tabs = new();
    private string _activeTab = "";
    private bool _loading = true;
    private bool _showBanner;
    private bool _isPhase2;
    private string _bannerTimer = "";
    private System.Threading.Timer? _timer;
    private DateTime? _phase1Deadline;
    private DateTime? _phase2Deadline;

    protected override void OnInitialized()
    {
        if (!Auth.IsAuthenticated) Nav.NavigateTo("/login", replace: true);
    }

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsAuthenticated) return;
        try
        {
            _user = await Users.GetByIdAsync(Auth.UserId);
            _settings = await SettingsClient.GetAllAsync();

            if (_settings.Phase1Deadline != null)
                _phase1Deadline = DateTime.Parse(_settings.Phase1Deadline);
            if (_settings.Phase2Deadline != null)
                _phase2Deadline = DateTime.Parse(_settings.Phase2Deadline);

            if (_user.IsMentor)
            {
                try { _mentorPair = await Pairs.GetByMentorAsync(Auth.UserId); }
                catch (ApiException) { _mentorPair = null; }
            }
            if (_user.IsMentee)
            {
                try { _menteePair = await Pairs.GetByMenteeAsync(Auth.UserId); }
                catch (ApiException) { _menteePair = null; }
            }

            BuildTabs();
        }
        catch { }
        finally { _loading = false; }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && _showBanner)
            StartTimer();
    }

    private void StartTimer()
    {
        _timer = new System.Threading.Timer(
            async _ => { UpdateTimer(); await InvokeAsync(StateHasChanged); },
            null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    private void UpdateTimer()
    {
        var deadline = _isPhase2 ? _phase2Deadline : _phase1Deadline;
        if (deadline is null)
        {
            _bannerTimer = _isPhase2 ? "Pending algorithm" : "Pending activation";
            return;
        }
        var diff = deadline.Value - DateTime.Now;
        _bannerTimer = diff.TotalSeconds > 0
            ? $"Ends in: {diff.Days}d {diff.Hours:D2}h {diff.Minutes:D2}m {diff.Seconds:D2}s"
            : "Deadline reached";
    }

    private void BuildTabs()
    {
        _tabs.Clear();
        bool hasPhaseTab = false;

        if (_mentorPair is not null)
            _tabs.Add(TabMentorPair);
        else if (_user!.IsMentor)
        { _tabs.Add(TabMentorRequests); hasPhaseTab = true; }

        if (_menteePair is not null)
            _tabs.Add(TabMenteePair);
        else if (_user!.IsMentee)
        {
            if (_settings?.IsPhase1Complete == true && _settings?.IsProcessComplete == false)
            { _tabs.Add(TabGallery); hasPhaseTab = true; }
            else if (_settings?.IsProcessComplete == false)
            { _tabs.Add(TabBrowseMentors); hasPhaseTab = true; }
        }

        _isPhase2 = _settings?.IsPhase1Complete == true;
        _showBanner = hasPhaseTab;
        if (_showBanner) UpdateTimer();
        _activeTab = _tabs.FirstOrDefault() ?? "";
    }

    public void Dispose() => _timer?.Dispose();
}
