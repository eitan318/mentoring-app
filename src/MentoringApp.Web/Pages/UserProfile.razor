@page "/user/{Id:int}"
@inject AuthStateService Auth
@inject NavigationManager Nav
@inject UserApiClient Users
@inject ReferenceApiClient Reference
@using MentoringApp.Model.User
@using MentoringApp.Model.User.StudentProfiles

<PageTitle>Profile – MentoringApp</PageTitle>

@if (!Auth.IsAuthenticated)
{
    <p>Redirecting…</p>
}
else if (_loading)
{
    <div class="empty-state"><div class="loading-spinner"></div></div>
}
else if (_user is null)
{
    <p class="error-msg">User not found.</p>
}
else
{
    <div class="card" style="margin-bottom:1rem">
        <div class="flex items-center gap-2" style="margin-bottom:1rem">
            <div class="peer-avatar" style="width:64px;height:64px;font-size:1.5rem;flex-shrink:0">
                @_user.UserName[0].ToString().ToUpper()
            </div>
            <div>
                <h2 style="margin-bottom:.25rem">@_user.UserName</h2>
                <div class="flex gap-2" style="flex-wrap:wrap">
                    @* שימוש ב-Pattern Matching כדי לזהות תפקידים מורכבים *@
                    @if (_user is StudentModel s)
                    {
                        <span class="badge badge-accepted">Student</span>
                        @if (s.IsMentor)
                        {
                            <span class="badge badge-pending">Mentor</span>
                        }
                        @if (s.IsMentee)
                        {
                            <span class="badge badge-pending">Mentee</span>
                        }
                    }
                    else if (_user is SupervisorModel)
                    {
                        <span class="badge badge-accepted">Supervisor</span>
                    }
                    else
                    {
                        <span class="badge badge-accepted">Admin</span>
                    }
                </div>
            </div>
        </div>

        <div class="profile-info-grid">
            <div class="profile-info-row">
                <span class="profile-info-label">Email</span>
                <span>@_user.Email</span>
            </div>
            @if (!string.IsNullOrEmpty(_user.PhoneNumber))
            {
                <div class="profile-info-row">
                    <span class="profile-info-label">Phone</span>
                    <span>@_user.PhoneNumber</span>
                </div>
            }
            <div class="profile-info-row">
                <span class="profile-info-label">Gender</span>
                <span>@_user.Gender</span> @* המרה אוטומטית של Enum לטקסט *@
            </div>

            @* הצגת כיתה רק אם מדובר בסטודנט *@
            @if (_user is StudentModel student)
            {
                <div class="profile-info-row">
                    <span class="profile-info-label">Grade / Class</span>
                    <span>@(student.Grade?.Name ?? "N/A") / @student.ClassNum</span>
                </div>
            }
        </div>
    </div>

    @* לוגיקה ספציפית למנטור *@
    @if (_user is StudentModel mentor && mentor.IsMentor && mentor.MentorProfile != null)
    {
        <div class="card" style="margin-bottom:1rem">
            <p class="card-title">Mentor Profile</p>
            <div class="profile-info-row">
                <span class="profile-info-label">Teaching</span>
                <span style="color:#2E7D32;font-weight:500">@SubjectName(mentor.MentorProfile.SubjectToTeach)</span>
            </div>
            <div class="profile-info-row">
                <span class="profile-info-label">Max Mentees</span>
                <span>@mentor.MentorProfile.MaxMentees</span>
            </div>
        </div>
    }

    @* לוגיקה ספציפית למנטי *@
    @if (_user is StudentModel mentee && mentee.IsMentee && mentee.MenteeProfile != null)
    {
        <div class="card" style="margin-bottom:1rem">
            <p class="card-title">Learning Profile</p>
            <div class="profile-info-row">
                <span class="profile-info-label">Learning</span>
                <span style="color:#1565C0;font-weight:500">@SubjectName(mentee.MenteeProfile.SubjectToLearn)</span>
            </div>
        </div>
    }
}

@code {
    [Parameter] public int Id { get; set; }

    private UserModel? _user;
    private Dictionary<int, string> _subjects = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsAuthenticated)
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }

        try
        {
            // בזכות ה-JsonDerivedType, ה-Result כאן יהיה StudentModel/SupervisorModel
            var userTask = Users.GetByIdAsync(Id);
            var subjectsTask = Reference.GetSubjectsAsync();
            
            await Task.WhenAll(userTask, subjectsTask);
            
            _user = userTask.Result;
            _subjects = subjectsTask.Result.ToDictionary(s => s.Id, s => s.Name);
        }
        catch { }
        finally { _loading = false; }
    }

    private string SubjectName(int id) => _subjects.TryGetValue(id, out var n) ? n : $"#{id}";
}