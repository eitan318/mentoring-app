@page "/issues"
@inject IAuthService Auth
@inject IssueApiClient IssueApi
@inject NavigationManager Nav

<h2>Issues</h2>

@if (!string.IsNullOrEmpty(_error)) { <div class="alert alert-error">@_error</div> }

<!-- Report Form (collapsible) -->
<details class="collapsible-form">
    <summary>Report a New Issue</summary>
    <div class="form-body">
        <div class="form-group">
            <label>Category</label>
            <select @bind="_newCategoryId">
                @foreach (var c in _categories)
                {
                    <option value="@c.Id">@c.Name</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label>Description</label>
            <textarea @bind="_newDescription" rows="3"></textarea>
        </div>
        @if (!string.IsNullOrEmpty(_submitMsg)) { <span class="msg">@_submitMsg</span> }
        <button class="btn btn-primary" @onclick="SubmitIssueAsync">Submit</button>
    </div>
</details>

<!-- Filters -->
<div class="filter-row">
    <select @bind="_filterCategory">
        <option value="0">All categories</option>
        @foreach (var c in _categories)
        {
            <option value="@c.Id">@c.Name</option>
        }
    </select>
    <select @bind="_filterStatus">
        <option value="">All statuses</option>
        <option value="open">Open</option>
        <option value="resolved">Resolved</option>
    </select>
</div>

@if (_loading)
{
    <p>Loading issues...</p>
}
else
{
    <table class="data-table">
        <thead>
            <tr><th>ID</th><th>Description</th><th>Category</th><th>Created</th><th>Status</th></tr>
        </thead>
        <tbody>
            @foreach (var issue in FilteredIssues)
            {
                <tr>
                    <td>@issue.Id</td>
                    <td>@issue.Description</td>
                    <td>@CategoryName(issue.CategoryId)</td>
                    <td>@issue.CreationDate</td>
                    <td>@(issue.IsResolved == 1 ? "Resolved" : "Open")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private IEnumerable<IssueResponse> _issues = [];
    private IEnumerable<IssueCategoryResponse> _categories = [];
    private bool _loading = true;
    private string _error = string.Empty;
    private string _submitMsg = string.Empty;
    private string _newDescription = string.Empty;
    private int _newCategoryId;
    private int _filterCategory;
    private string _filterStatus = string.Empty;

    private IEnumerable<IssueResponse> FilteredIssues => _issues
        .Where(i => _filterCategory == 0 || i.CategoryId == _filterCategory)
        .Where(i => _filterStatus switch
        {
            "open" => i.IsResolved == 0,
            "resolved" => i.IsResolved == 1,
            _ => true
        });

    protected override async Task OnInitializedAsync()
    {
        if (Auth.UserId is null) { Nav.NavigateTo("/login"); return; }
        await Task.WhenAll(LoadIssuesAsync(), LoadCategoriesAsync());
    }

    private async Task LoadIssuesAsync()
    {
        _loading = true;
        try { _issues = await IssueApi.GetByUserAsync(Auth.UserId!.Value); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task LoadCategoriesAsync()
    {
        try { _categories = await IssueApi.GetCategoriesAsync(); }
        catch { /* non-critical */ }
    }

    private async Task SubmitIssueAsync()
    {
        _submitMsg = string.Empty;
        if (string.IsNullOrWhiteSpace(_newDescription)) { _submitMsg = "Description is required."; return; }
        if (_newCategoryId <= 0) { _submitMsg = "Select a category."; return; }

        try
        {
            await IssueApi.CreateAsync(new CreateIssueRequest(_newDescription, _newCategoryId, Auth.UserId!.Value));
            _newDescription = string.Empty;
            _submitMsg = "Issue reported successfully.";
            await LoadIssuesAsync();
        }
        catch (Exception ex) { _submitMsg = ex.Message; }
    }

    private string CategoryName(int id) =>
        _categories.FirstOrDefault(c => c.Id == id)?.Name ?? id.ToString();
}
