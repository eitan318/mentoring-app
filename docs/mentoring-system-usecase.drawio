            <mxPoint x="1140" y="110" as="sourcePoint" />
            <mxPoint x="1140" y="780" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- ===== Messages (numbered arrows) ===== -->

        <!-- 1. Mentee -> UI: Login with ID + OTP -->
        <mxCell id="m1" value="1. התחברות (ת.ז + קוד חד-פעמי)" style="endArrow=classic;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=11;align=center;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="140" y="150" as="sourcePoint" />
            <mxPoint x="340" y="150" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 2. UI -> Mentee: Available mentors list -->
        <mxCell id="m2" value="2. רשימת חונכים זמינים במקצוע הנדרש" style="endArrow=open;html=1;strokeColor=#000000;dashed=1;strokeWidth=1.5;fontSize=11;align=center;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="340" y="210" as="sourcePoint" />
            <mxPoint x="140" y="210" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 3. Mentee -> UI: Click "Request mentoring" -->
        <mxCell id="m3" value="3. לחיצה על &quot;בקש חונכות&quot; (mentorId)" style="endArrow=classic;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=11;align=center;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="140" y="270" as="sourcePoint" />
            <mxPoint x="340" y="270" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 4. UI -> PairRequestRepo: Insert request Pending -->
        <mxCell id="m4" value="4. INSERT PairRequest (status = Pending)" style="endArrow=classic;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=11;align=center;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="340" y="330" as="sourcePoint" />
            <mxPoint x="540" y="330" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 5a. UI -> Mentor: Show request in main screen -->
        <mxCell id="m5a" value="5a. הצגת הבקשה במסך הראשי של החונך" style="endArrow=classic;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=11;align=center;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="340" y="390" as="sourcePoint" />
            <mxPoint x="740" y="390" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 5b. Mentor -> UI: Approve / Reject (assume Approve) -->
        <mxCell id="m5b" value="5b. אישור הבקשה (Approve)" style="endArrow=classic;html=1;strokeColor=#006600;strokeWidth=1.8;fontSize=11;align=center;verticalAlign=bottom;fontStyle=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="740" y="450" as="sourcePoint" />
            <mxPoint x="340" y="450" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 6. UI -> PairRepo: Create Pair triple -->
        <mxCell id="m6" value="6. INSERT Pair (Mentor, Mentee, Supervisor של הכיתה)" style="endArrow=classic;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=11;align=center;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="340" y="510" as="sourcePoint" />
            <mxPoint x="940" y="510" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 7a. UI -> EmailService: Send mail to mentor -->
        <mxCell id="m7a" value="7a. שליחת מייל אישור לחונך" style="endArrow=classic;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=11;align=center;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="340" y="570" as="sourcePoint" />
            <mxPoint x="1140" y="570" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 7b. UI -> EmailService: Send mail to mentee -->
        <mxCell id="m7b" value="7b. שליחת מייל אישור לחניך" style="endArrow=classic;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=11;align=center;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="340" y="620" as="sourcePoint" />
            <mxPoint x="1140" y="620" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- ===== Alternative-flow note (Rejection) ===== -->
        <mxCell id="alt_note" value="זרימה חלופית - דחייה:&#10;אם החונך דוחה (Reject) ב-5b → PairRequest מעודכן ל-status = Rejected.&#10;לא נוצר Pair, ונשלח מייל יידוע לחניך עם הצעת חונכים חלופיים." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;align=right;verticalAlign=middle;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="680" width="600" height="80" as="geometry" />
        </mxCell>

        <!-- ===== End-state note ===== -->
        <mxCell id="end_note" value="מצב סופי (Happy Path):&#10;• PairRequest.Status = Approved&#10;• Pairs מכיל רשומה חדשה (Mentor, Mentee, Supervisor)&#10;• 2 מיילים נשלחו" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;align=right;verticalAlign=middle;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="660" y="680" width="580" height="80" as="geometry" />
